# microCMS（お知らせ・ブログで使用）
# microCMSの管理画面 > APIキー から取得
MICROCMS_SERVICE_DOMAIN=your-service-domain-here
MICROCMS_API_KEY=your-api-key-here

# Supabase（勤怠管理 /kintai で使用）
# Supabaseダッシュボード > Project Settings > API から取得
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here
