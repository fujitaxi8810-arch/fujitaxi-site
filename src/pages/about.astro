---
import Layout from '../layouts/Layout.astro';

const pageTitle = '企業情報';
const pageDesc  = '南相馬市小高区の富士タクシー。昭和46年創業、地域に根ざして50年以上。ミッション・ビジョン・バリューと会社概要・アクセス情報をご案内します。';

/* ── 構造化データ: AboutPage + Organization ── */
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': ['AboutPage', 'WebPage'],
  name: '企業情報 | 富士タクシー 南相馬市',
  description: pageDesc,
  url: 'https://fujitaxi-minamisoma.com/about',
  mainEntity: {
    '@type': ['LocalBusiness', 'Organization'],
    name: '有限会社 富士タクシー',
    foundingDate: '1971',
    foundingLocation: {
      '@type': 'Place',
      name: '福島県南相馬市小高区',
    },
    numberOfEmployees: { '@type': 'QuantitativeValue', value: 10 },
    legalName: '有限会社 富士タクシー',
    contactPoint: [
      {
        '@type': 'ContactPoint',
        telephone: '0244-44-2543',
        contactType: '予約・お問い合わせ（本社）',
        areaServed: 'JP',
        availableLanguage: 'Japanese',
        hoursAvailable: { '@type': 'OpeningHoursSpecification', opens: '07:00', closes: '24:00' },
      },
      {
        '@type': 'ContactPoint',
        telephone: '0244-32-0030',
        contactType: '予約・お問い合わせ（原町待機所）',
        areaServed: 'JP',
        availableLanguage: 'Japanese',
      },
    ],
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'JP',
      postalCode: '979-2124',
      addressRegion: '福島県',
      addressLocality: '南相馬市小高区',
      streetAddress: '本町一丁目57番地',
    },
  },
};

const values = [
  {
    label: 'Mission',
    en: 'ミッション',
    title: '安全第一と地域公共交通の担い手',
    body: 'お客様が安心して目的地に到着できるよう輸送の安全を第一に考え、地域の暮らしを支える公共交通としての役割を果たします。',
  },
  {
    label: 'Vision',
    en: 'ビジョン',
    title: 'タクシーを「サードプレイス」へ',
    body: '移動のわずかな時間であってもくつろぎを感じられるような、お客様にとってのサードプレイス（第三の居場所）となることを目指します。',
  },
  {
    label: 'Value',
    en: 'バリュー',
    title: '教育と誠実さで磨くおもてなし',
    body: '定期安全教育・サービス向上教育を徹底し、きめ細やかで満足度の高いサービスを提供します。お客様の笑顔がすべての原点です。',
  },
];

const profile = [
  { label: '会社名',   value: '有限会社 富士タクシー' },
  { label: '設立',     value: '昭和46年5月（1971年）' },
  { label: '代表者名', value: '小林 清人' },
  { label: '資本金',   value: '500万円' },
  { label: '事業内容', value: '一般乗用旅客運送事業、一般乗合旅客運送事業、自動車整備事業' },
  { label: '営業時間', value: '7:00〜24:00（年中無休）' },
];

const locations = [
  {
    name:    '本社',
    zip:     '〒979-2124',
    address: '福島県南相馬市小高区本町一丁目57番地',
    tel:     '0244-44-2543',
    fax:     '0244-44-2463',
    note:    'JR常磐線小高駅から徒歩約5分。青い看板が目印です。',
    mapSrc:  'https://maps.google.com/maps?q=%E7%A6%8F%E5%B3%B6%E7%9C%8C%E5%8D%97%E7%9B%B8%E9%A6%AC%E5%B8%82%E5%B0%8F%E9%AB%98%E5%8C%BA%E6%9C%AC%E7%94%BA%E4%B8%80%E4%B8%81%E7%9B%AE57%E7%95%AA%E5%9C%B0&output=embed&hl=ja',
  },
  {
    name:    '原町待機所',
    zip:     '〒975-0037',
    address: '福島県南相馬市原町区北原字本屋敷181番地1',
    tel:     '0244-32-0030',
    fax:     '0244-32-0008',
    note:    '令和4年3月より原ノ町駅でも当社タクシーが待機しております。',
    mapSrc:  'https://maps.google.com/maps?q=%E7%A6%8F%E5%B3%B6%E7%9C%8C%E5%8D%97%E7%9B%B8%E9%A6%AC%E5%B8%82%E5%8E%9F%E7%94%BA%E5%8C%BA%E5%8C%97%E5%8E%9F%E5%AD%97%E6%9C%AC%E5%B1%8B%E6%95%B7181%E7%95%AA%E5%9C%B01&output=embed&hl=ja',
  },
];

const timeline = [
  { year: '1971', label: '昭和46年', event: '有限会社 富士タクシー 創業。小高区にて営業開始。' },
  { year: '2011', label: '平成23年', event: '東日本大震災・原発事故により一時休業。地域の復興を支援。' },
  { year: '2017', label: '平成29年', event: '小高区避難指示解除後に営業再開。地域の復興を牽引。' },
  { year: '2022', label: '令和4年',  event: '原町待機所を開所。原町区エリアの配車・送迎に本格対応。' },
  { year: '2024', label: '令和6年',  event: '多彩な決済方法（クレカ・QR・電子マネー等）を導入。DX推進。' },
  { year: '2025', label: '令和7年',  event: '現着通知サービス開始。お客様を外で待たせない新サービス。' },
  { year: '2026', label: '令和8年',  event: '営業時間を24時まで延長。さらなる利便性向上を実現。' },
  { year: '2026', label: '令和8年',  event: 'QRコード配車を開始。スマホで読み込むだけで即座に配車依頼が可能に。配車DX推進。', highlight: true },
];

// SDGsホイール生成
const sdgWheelColors = [
  '#E5243B','#DDA63A','#4C9F38','#C5192D','#FF3A21',
  '#26BDE2','#FCC30B','#A21942','#FD6925','#DD1367',
  '#FD9D24','#BF8B2E','#3F7E44','#0A97D9','#56C02B',
  '#00689D','#19486A'
];
const WCX = 90, WCY = 90, WR = 82, WN = 17;
const wheelSegments = sdgWheelColors.map((color, i) => {
  const a1 = (-90 + i * 360 / WN) * Math.PI / 180;
  const a2 = (-90 + (i + 1) * 360 / WN) * Math.PI / 180;
  const x1 = (WCX + WR * Math.cos(a1)).toFixed(2);
  const y1 = (WCY + WR * Math.sin(a1)).toFixed(2);
  const x2 = (WCX + WR * Math.cos(a2)).toFixed(2);
  const y2 = (WCY + WR * Math.sin(a2)).toFixed(2);
  return { color, d: `M ${WCX} ${WCY} L ${x1} ${y1} A ${WR} ${WR} 0 0 1 ${x2} ${y2} Z` };
});

const sdgGoals = [
  {
    num: '3',
    goalEn: 'GOOD HEALTH AND WELL-BEING',
    nameJa1: 'すべての人に',
    nameJa2: '健康と福祉を',
    body: 'デマンドタクシーで高齢者・交通弱者の通院移動を支援。誰もが医療にアクセスできる環境を守ります。',
    color: '#4C9F38',
    icon: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M32 54 C32 54 8 38 8 22 C8 13 15 7 23 7 C27.5 7 31 10 32 12 C33 10 36.5 7 41 7 C49 7 56 13 56 22 C56 38 32 54 32 54Z" fill="rgba(255,255,255,0.25)" stroke="white" stroke-width="2"/>
      <rect x="28" y="16" width="8" height="22" rx="3" fill="white"/>
      <rect x="21" y="23" width="22" height="8" rx="3" fill="white"/>
    </svg>`,
  },
  {
    num: '4',
    goalEn: 'QUALITY EDUCATION',
    nameJa1: '質の高い教育を',
    nameJa2: 'みんなに',
    body: 'スクールタクシーで遠距離通学の子どもたちの教育機会を確保。安全な通学環境を毎日提供しています。',
    color: '#C5192D',
    icon: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="8" y="16" width="48" height="34" rx="3" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="2"/>
      <line x1="32" y1="16" x2="32" y2="50" stroke="white" stroke-width="2"/>
      <line x1="14" y1="26" x2="28" y2="26" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <line x1="14" y1="33" x2="28" y2="33" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <line x1="14" y1="40" x2="28" y2="40" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <line x1="36" y1="26" x2="50" y2="26" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <line x1="36" y1="33" x2="50" y2="33" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <line x1="36" y1="40" x2="50" y2="40" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <rect x="8" y="10" width="48" height="8" rx="2" fill="rgba(255,255,255,0.6)"/>
    </svg>`,
  },
  {
    num: '10',
    goalEn: 'REDUCED INEQUALITIES',
    nameJa1: '人や国の不平等を',
    nameJa2: 'なくそう',
    body: '交通弱者・移動困難者へのサービス提供を通じて、地域内の移動格差をなくす取り組みを続けています。',
    color: '#DD1367',
    icon: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="18" cy="20" r="6" fill="rgba(255,255,255,0.7)"/>
      <path d="M6 46 C6 36 30 36 30 46" fill="rgba(255,255,255,0.7)"/>
      <circle cx="32" cy="16" r="7" fill="white"/>
      <path d="M18 46 C18 34 46 34 46 46" fill="white"/>
      <circle cx="46" cy="20" r="6" fill="rgba(255,255,255,0.7)"/>
      <path d="M34 46 C34 36 58 36 58 46" fill="rgba(255,255,255,0.7)"/>
    </svg>`,
  },
  {
    num: '11',
    goalEn: 'SUSTAINABLE CITIES AND COMMUNITIES',
    nameJa1: '住み続けられる',
    nameJa2: 'まちづくりを',
    body: '地域の移動インフラを担い、南相馬市・小高区が住み続けられる街であり続けるための基盤を支えます。',
    color: '#FD9D24',
    icon: `<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <polygon points="32,8 56,28 52,28 52,54 36,54 36,40 28,40 28,54 12,54 12,28 8,28" fill="rgba(255,255,255,0.25)" stroke="white" stroke-width="2"/>
      <rect x="23" y="18" width="8" height="8" rx="1.5" fill="rgba(255,255,255,0.8)"/>
      <rect x="33" y="18" width="8" height="8" rx="1.5" fill="rgba(255,255,255,0.8)"/>
      <rect x="28" y="40" width="8" height="14" rx="1.5" fill="rgba(255,255,255,0.9)"/>
    </svg>`,
  },
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  structuredData={aboutSchema}
>

<!-- ════════════════════════════════════════
     ページヒーロー
════════════════════════════════════════ -->
<section class="page-hero" aria-label="ページタイトル">
  <div class="container">
    <nav class="page-hero__breadcrumb" aria-label="パンくずリスト">
      <a href="/">ホーム</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">企業情報</span>
    </nav>
    <p class="eyebrow">About Us</p>
    <h1 class="heading-xl about-hero__heading">
      地域とともに、<br />
      <em class="text-yellow" style="font-style:normal;">50年以上。</em>
    </h1>
    <p class="lead" style="max-width:600px; margin-top:1.25rem;">
      昭和46年の創業以来、南相馬市小高区を拠点に地域の移動を支え続けてきました。
      震災を乗り越え、復興とともに歩む富士タクシーの姿をご紹介します。
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════
     経営理念（Mission / Vision / Value）
════════════════════════════════════════ -->
<section class="section philosophy-section bg-black" id="philosophy" aria-labelledby="philosophy-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Philosophy</p>
      <h2 class="heading-lg" id="philosophy-heading">
        富士タクシーの<span class="text-yellow">経営理念</span>
      </h2>
      <p class="lead" style="max-width:560px;">
        ミッション・ビジョン・バリュー——3つの柱を軸に、<br />
        すべての運行・サービスに一貫した姿勢で臨んでいます。
      </p>
    </div>

    <div class="mvv-grid">
      {values.map((v, i) => (
        <div class="mvv-card reveal" style={`transition-delay:${i * 100}ms`}>
          <div class="mvv-card__header">
            <span class="mvv-card__badge">{v.label}</span>
            <span class="mvv-card__en">{v.en}</span>
          </div>
          <h3 class="mvv-card__title">{v.title}</h3>
          <hr class="divider" style="margin: 0.75rem 0;" />
          <p class="mvv-card__body">{v.body}</p>
        </div>
      ))}
    </div>

    <!-- ブランドメッセージ -->
    <div class="brand-message reveal">
      <div class="brand-message__bg" aria-hidden="true"></div>
      <p class="brand-message__label">Brand Message</p>
      <blockquote class="brand-message__quote">
        <p>Drive the Story.<br /><span class="brand-message__quote-sub">移動が、物語になる。</span></p>
      </blockquote>
      <div class="brand-message__divider" aria-hidden="true"></div>
      <p class="brand-message__sub">
        タクシーは、目的地へ運ぶだけの乗り物ではない。<br />
        車内で交わされる言葉、窓の外に流れる景色、<br class="sp-only" />
        ふと立ち寄るあの場所——。<br />
        富士タクシーは、移動そのものを<br />
        <strong class="brand-message__highlight">「第三の居場所（サードプレイス）」</strong>として、<br />
        人と地域が出会い、つながる時間を創り続けます。
      </p>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════
     歴史・沿革
════════════════════════════════════════ -->
<section class="section timeline-section bg-soft" id="history" aria-labelledby="history-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">History</p>
      <h2 class="heading-lg" id="history-heading">
        富士タクシーの<span class="text-yellow">歩み</span>
      </h2>
    </div>

    <ol class="timeline" aria-label="沿革タイムライン">
      {timeline.map((item, i) => (
        <li class={`timeline__item reveal${item.highlight ? ' timeline__item--highlight' : ''}`} style={`transition-delay:${i * 70}ms`}>
          <div class="timeline__year" aria-label={item.label}>
            <span class="timeline__y-en" aria-hidden="true">{item.year}</span>
            <span class="timeline__y-ja">{item.label}</span>
          </div>
          <div class={`timeline__dot${item.highlight ? ' timeline__dot--highlight' : ''}`} aria-hidden="true"></div>
          <div class="timeline__content">
            {item.highlight && (
              <span class="timeline__badge">NEW</span>
            )}
            <p class="timeline__event">{item.event}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ════════════════════════════════════════
     会社概要
════════════════════════════════════════ -->
<section class="section profile-section bg-black" id="company" aria-labelledby="profile-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Company Profile</p>
      <h2 class="heading-lg" id="profile-heading">
        <span class="text-yellow">会社概要</span>
      </h2>
    </div>

    <div class="profile-grid reveal">
      <div class="profile-table-wrap">
        <table class="profile-table">
          <caption class="sr-only">富士タクシー 会社情報一覧</caption>
          <tbody>
            {profile.map(row => (
              <tr>
                <th scope="row">{row.label}</th>
                <td>{row.value}</td>
              </tr>
            ))}
            <tr>
              <th scope="row">メール</th>
              <td>
                <a href="mailto:fuji-taxi.odaka@white.plala.or.jp" class="profile-email">
                  fuji-taxi.odaka@white.plala.or.jp
                </a>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="profile-aside">
        <div class="profile-aside__card">
          <p class="profile-aside__label">お客様の声</p>
          <p class="profile-aside__body">
            富士タクシーでは、サービス向上のためにお客様アンケートを実施しています。
            ご意見・ご要望はGoogleフォームからお寄せください。
          </p>
          <a
            href="https://forms.gle/YcmYJ7LUXSyuwQ9p6"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--outline btn--sm"
            style="margin-top:1rem; align-self:flex-start;"
          >
            アンケートに答える →
          </a>
        </div>
        <div class="profile-aside__card">
          <p class="profile-aside__label">採用情報</p>
          <p class="profile-aside__body">
            富士タクシーでは未経験者も歓迎。資格取得支援・完全週休2日・社会保険完備。
          </p>
          <a href="/recruit" class="btn btn--primary btn--sm" style="margin-top:1rem; align-self:flex-start;">
            採用情報を見る
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════
     アクセス（本社・原町待機所）
════════════════════════════════════════ -->
<section class="section access-section bg-soft" id="access" aria-labelledby="access-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Access</p>
      <h2 class="heading-lg" id="access-heading">
        <span class="text-yellow">アクセス</span>
      </h2>
    </div>

    <div class="access-grid">
      {locations.map((loc, i) => (
        <div class="access-card reveal" style={`transition-delay:${i * 100}ms`}>
          {i === 0 && (
            <div class="access-card__photo-wrap">
              <img
                src="/images/photo-honsha-exterior-opt.webp"
                alt="富士タクシー 本社 外観"
                class="access-card__photo"
                width="800"
                height="600"
                loading="lazy"
              />
            </div>
          )}
          {i === 1 && (
            <div class="access-card__photo-wrap">
              <img
                src="/images/photo-haramachi-exterior-opt.webp"
                alt="富士タクシー 原町待機所 外観"
                class="access-card__photo"
                width="800"
                height="500"
                loading="lazy"
              />
            </div>
          )}
          <div class="access-card__header">
            <h3 class="access-card__name">{loc.name}</h3>
            <a href={`tel:${loc.tel.replace(/-/g,'')}`} class="access-card__tel">
              {loc.tel}
            </a>
          </div>
          <address class="access-card__address">
            <span class="access-card__zip">{loc.zip}</span><br />
            {loc.address}
          </address>
          <p class="access-card__fax">FAX: {loc.fax}</p>
          <p class="access-card__note">{loc.note}</p>
          <div class="access-card__map" aria-label={`${loc.name}の地図`}>
            <iframe
              title={`${loc.name} 地図`}
              src={loc.mapSrc}
              width="100%"
              height="280"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════
     SDGs
════════════════════════════════════════ -->
<section class="section sdg-section bg-black" id="sdgs" aria-labelledby="sdg-heading">
  <div class="container">
    <div class="sdg-header reveal">
      <div class="sdg-header__text">
        <p class="eyebrow">SDGs</p>
        <h2 class="heading-lg" id="sdg-heading">
          富士タクシーの<span class="text-yellow">SDGsへの取り組み</span>
        </h2>
        <p class="lead" style="max-width:520px;">
          国連が掲げる持続可能な開発目標（SDGs）に沿って、地域社会・環境への責任を果たします。
        </p>
      </div>
      <!-- SDGsホイールロゴ -->
      <div class="sdg-wheel-wrap" aria-label="SDGs持続可能な開発目標ホイール">
        <svg viewBox="0 0 180 180" width="200" height="200" xmlns="http://www.w3.org/2000/svg" role="img">
          {wheelSegments.map(s => (
            <path d={s.d} fill={s.color} stroke="#fff" stroke-width="1" />
          ))}
          <circle cx="90" cy="90" r="34" fill="#fff" />
          <text x="90" y="83" text-anchor="middle" font-size="7.5" font-weight="900" fill="#333" font-family="sans-serif" letter-spacing="0.5">SUSTAINABLE</text>
