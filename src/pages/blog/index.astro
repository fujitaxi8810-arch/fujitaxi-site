---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';
import type { BlogItem } from '../../lib/microcms';

let blogItems: BlogItem[] = [];
let fetchError = false;

try {
  const data = await client.get({
    endpoint: 'blog',
    queries: { orders: '-publishedAt', limit: 12 },
  });
  blogItems = data.contents;
} catch (e) {
  fetchError = true;
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}年${String(d.getMonth() + 1).padStart(2, '0')}月${String(d.getDate()).padStart(2, '0')}日`;
}

const categories = ['すべて', '地域情報', 'サービス', '採用', 'SDGs'];
---

<Layout
  title="ブログ"
  description="富士タクシーのブログ。南相馬市の地域情報・お役立ち情報・ドライバー日記・観光スポット紹介など。"
>

  <!-- ページヒーロー -->
  <section class="page-hero bg-black">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <ol>
          <li><a href="/">ホーム</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">ブログ</li>
        </ol>
      </nav>
      <p class="eyebrow reveal">Blog</p>
      <h1 class="reveal">富士タクシーからの情報発信</h1>
    </div>
  </section>

  <!-- カテゴリフィルター -->
  <section class="section--sm bg-soft" style="padding-bottom: 0;">
    <div class="container">
      <div class="category-filter reveal" role="group" aria-label="カテゴリフィルター">
        {categories.map((cat) => (
          <button
            class={`cat-btn${cat === 'すべて' ? ' cat-btn--active' : ''}`}
            data-category={cat}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ブログ一覧 -->
  <section class="section bg-soft">
    <div class="container">
      {fetchError ? (
        <div class="message-box">
          <p>現在ブログを読み込めません。しばらく時間をおいて再度アクセスしてください。</p>
        </div>
      ) : blogItems.length === 0 ? (
        <div class="message-box">
          <p>記事を準備中です。しばらくお待ちください。</p>
        </div>
      ) : (
        <div class="blog-grid reveal" id="blog-grid">
          {blogItems.map((item) => (
            <a href={`/blog/${item.id}`} class="blog-card" data-category={item.category}>
              <div class="blog-card__thumb">
                {item.thumbnail ? (
                  <img
                    src={item.thumbnail.url}
                    alt={item.title}
                    width={item.thumbnail.width}
                    height={item.thumbnail.height}
                    loading="lazy"
                  />
                ) : (
                  <div class="blog-card__placeholder" aria-hidden="true">富士タクシー</div>
                )}
              </div>
              <div class="blog-card__body">
                <span class="blog-card__badge">{item.category}</span>
                <h2 class="blog-card__title">{item.title}</h2>
                <div class="blog-card__meta">
                  <span class="blog-card__author">{item.author}</span>
                  <time class="blog-card__date" datetime={item.publishedAt}>
                    {formatDate(item.publishedAt || item.createdAt)}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</Layout>

<script>
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'すべて';

      catBtns.forEach(b => b.classList.remove('cat-btn--active'));
      btn.classList.add('cat-btn--active');

      cards.forEach(card => {
        const cardCat = card.dataset.category ?? '';
        if (cat === 'すべて' || cardCat === cat) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .page-hero {
    padding-block: 5rem 4rem;
  }
  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: var(--fuji-white);
    margin-block: 1rem;
  }
  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--fuji-gray-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fuji-yellow); }

  /* カテゴリフィルター */
  .category-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-bottom: 2rem;
  }
  .cat-btn {
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--fuji-gray-light);
    border-radius: var(--radius-full);
    background: var(--fuji-white);
    color: #555;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: var(--font-ja);
  }
  .cat-btn:hover {
    border-color: var(--fuji-yellow-dark);
    color: var(--fuji-yellow-dark);
  }
  .cat-btn--active {
    background: var(--fuji-yellow);
    border-color: var(--fuji-yellow);
    color: var(--fuji-black);
  }

  /* ブロググリッド */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .blog-card {
    background: var(--fuji-white);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--fuji-gray-light);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }
  .blog-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    transform: translateY(-4px);
  }
  .blog-card__thumb {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--fuji-yellow);
    position: relative;
  }
  .blog-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-en);
    font-weight: 900;
    font-size: var(--text-xl);
    color: var(--fuji-black);
    background: var(--fuji-yellow);
  }
  .blog-card__body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .blog-card__badge {
    display: inline-block;
    padding: 0.2rem 0.75rem;
    background: var(--fuji-yellow);
    color: var(--fuji-black);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
    align-self: flex-start;
  }
  .blog-card__title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--fuji-black);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .blog-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .blog-card__author {
    font-size: var(--text-xs);
    color: #777;
  }
  .blog-card__date {
    font-family: var(--font-en);
    font-size: var(--text-xs);
    color: var(--fuji-gray-muted);
  }

  .message-box {
    text-align: center;
    padding: 4rem 2rem;
    color: #555;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }
</style>
