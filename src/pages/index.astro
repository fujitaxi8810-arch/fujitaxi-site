<style>
/* ─────────────────────────────
   フォトギャラリー（ベントボックス型）
───────────────────────────── */
.photo-gallery {
  display: grid;
  grid-template-columns: 1.15fr 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  height: clamp(520px, 65vw, 800px);
  background: transparent;
  gap: 10px;
  padding: 0;
  border-top: 4px solid var(--fuji-yellow);
}

/* A: 左列 縦全体 */
.pg--main { grid-column: 1; grid-row: 1 / 3; }
/* B: 右上左 */
.pg--b    { grid-column: 2; grid-row: 1; }
/* C: 右上右 */
.pg--c    { grid-column: 3; grid-row: 1; }
/* D: 右下ワイド */
.pg--d    { grid-column: 2 / 4; grid-row: 2; }

.pg {
  position: relative;
  overflow: hidden;
}

.pg__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              filter 0.7s ease;
  filter: brightness(0.78) saturate(0.9);
}

.pg__img--crop {
  object-position: center 47%;
  transform-origin: center 47%;
}

.pg:hover .pg__img {
  transform: scale(1.06);
  filter: brightness(0.95) saturate(1.1);
}
.pg--d:hover .pg__img--crop {
  transform: scale(1.06);
  transform-origin: center 47%;
}

/* キャプション */
.pg__caption {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1rem 1.1rem;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.82) 0%,
    rgba(0,0,0,0.3) 45%,
    transparent 100%
  );
  pointer-events: none;
}

.pg__caption--lg {
  padding: 1.75rem 2rem;
}

.pg__caption--wide {
  flex-direction: row;
  align-items: flex-end;
  gap: 1.5rem;
}

/* 震災セルはキャプション下部のみ薄めにオーバーレイ */
.pg--d-disaster .pg__caption {
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.72) 0%,
    rgba(0,0,0,0.15) 35%,
    transparent 60%
  );
}

/* 震災写真2枚並べ */
.pg__disaster-pair {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: 3fr 5fr;
  gap: 2px;
}
.pg__disaster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 20%;
  display: block;
}

.pg__tag {
  display: inline-block;
  font-family: var(--font-en);
  font-size: 0.65rem;
  font-weight: 900;
  letter-spacing: 0.2em;
  color: var(--fuji-yellow);
  background: rgba(245,200,0,0.12);
  border: 1px solid rgba(245,200,0,0.35);
  border-radius: var(--radius-full);
  padding: 0.2rem 0.6rem;
  margin-bottom: 0.5rem;
  width: fit-content;
}

.pg__title {
  font-size: clamp(0.8rem, 1.4vw, 1rem);
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  text-shadow: 0 1px 6px rgba(0,0,0,0.7);
}

.pg--main .pg__title {
  font-size: clamp(1rem, 1.8vw, 1.35rem);
}

.pg__sub {
  font-size: clamp(0.65rem, 0.9vw, 0.75rem);
  color: rgba(255,255,255,0.6);
  margin-top: 0.2rem;
  letter-spacing: 0.03em;
}

/* セパレーターライン（黄色アクセント） */
.pg--main::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 3px;
  height: 40%;
  background: linear-gradient(to top, var(--fuji-yellow), transparent);
}

@media (max-width: 768px) {
  .photo-gallery {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1.3fr 1fr 1fr;
    height: auto;
  }
  .pg--main { grid-column: 1 / 3; grid-row: 1; min-height: 260px; }
  .pg--b    { grid-column: 1; grid-row: 2; min-height: 180px; }
  .pg--c    { grid-column: 2; grid-row: 2; min-height: 180px; }
  .pg--d    { grid-column: 1 / 3; grid-row: 3; min-height: 180px; }
  .pg--main::after { display: none; }
}

/* 仕切り線 */
.photo-gallery__main  { border-right: 2px solid var(--fuji-black); }
.photo-gallery__sub-item { border: 1px solid rgba(0,0,0,0.3); }

@media (max-width: 768px) {
  .photo-gallery {
    grid-template-columns: 1fr;
    height: auto;
  }
  .photo-gallery__main { height: 300px; }
  .photo-gallery__sub {
    grid-template-columns: 1fr 1fr;
    height: 320px;
  }
  .photo-gallery__sub-item--wide { display: none; }
}

/* ─────────────────────────────
   ヒーロー（A+Bハイブリッド）
───────────────────────────── */
.hero {
  position: relative;
  background: var(--fuji-black);
  overflow: hidden;
  padding-block: clamp(4rem, 10vh, 7rem);
}

.hero__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-size: cover;
  background-position: center 35%;
}
.hero__bg--1 {
  background-image: url('/images/uploads/hero-spring-river.webp');
  animation: hero-fade-1 28s ease-in-out infinite;
}
.hero__bg--2 {
  background-image: url('/images/uploads/hero-taxi-minamisoma.webp');
  animation: hero-fade-2 28s ease-in-out infinite;
}
.hero__bg--3 {
  background-image: url('/images/uploads/hero-taxi-sunset.webp');
  animation: hero-fade-3 28s ease-in-out infinite;
}
.hero__bg--4 {
  background-image: url('/images/uploads/7D2C5A3E-653A-4943-8B83-E2798D952F30.webp');
  background-position: center center;
  animation: hero-fade-4 28s ease-in-out infinite;
}
/* 4枚を順番にフェード（各5秒表示・20sサイクル） */
@keyframes hero-fade-1 {
  0%, 22%   { opacity: 1; }
  27%, 97%  { opacity: 0; }
  100%      { opacity: 1; }
}
@keyframes hero-fade-2 {
  0%, 22%   { opacity: 0; }
  27%, 47%  { opacity: 1; }
  52%, 100% { opacity: 0; }
}
@keyframes hero-fade-3 {
  0%, 47%   { opacity: 0; }
  52%, 72%  { opacity: 1; }
  77%, 100% { opacity: 0; }
}
@keyframes hero-fade-4 {
  0%, 72%   { opacity: 0; }
  77%, 97%  { opacity: 1; }
  100%      { opacity: 0; }
}

.hero__bg--1::before,
.hero__bg--2::before,
.hero__bg--3::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    rgba(10,10,10,0.55) 0%,
    rgba(10,10,10,0.25) 50%,
    rgba(10,10,10,0.05) 100%
  );
}
/* 子ども写真：全体を暗くして顔を判別不可に */
.hero__bg--4::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    rgba(10,10,10,0.60) 0%,
    rgba(10,10,10,0.30) 50%,
    rgba(10,10,10,0.10) 100%
  );
}

.hero__bg--1::after,
.hero__bg--2::after,
.hero__bg--3::after,
.hero__bg--4::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,10,10,0.35) 0%, transparent 50%);
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 3rem;
  align-items: center;
}

.hero__content {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

/* 英語タグライン */
.hero__tagline {
  display: flex;
  flex-direction: column;
  line-height: 1.15;
  gap: 0.1em;
}
/* ヒーロー順番フェードイン */
.hero-ani {
  opacity: 0;
  transform: translateY(20px);
  animation: hero-in 0.7s ease forwards;
  animation-delay: var(--ani-delay, 0s);
}
@keyframes hero-in {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ── スライドテキスト ── */
.hero__slides {
  position: relative;
  min-height: clamp(18rem, 55vw, 26rem);
  margin-bottom: 2rem;
}
.hero__slide {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  opacity: 0;
  pointer-events: none;
}
.hero__slide--1 {
  animation: slide-show-1 28s ease-in-out infinite;
}
.hero__slide--2 {
  animation: slide-show-2 28s ease-in-out infinite;
}
.hero__slide--3 {
  animation: slide-show-3 28s ease-in-out infinite;
}
.hero__slide--4 {
  animation: slide-show-4 28s ease-in-out infinite;
}
/* 4枚 × 7秒表示 = 28秒サイクル（各遷移約1.4秒） */
@keyframes slide-show-1 {
  0%   { opacity: 0; transform: translateY(18px); }
  3%   { opacity: 1; transform: translateY(0); }
  22%  { opacity: 1; transform: translateY(0); }
  26%  { opacity: 0; transform: translateY(-12px); }
  97%  { opacity: 0; transform: translateY(18px); }
  100% { opacity: 0; transform: translateY(18px); }
}
@keyframes slide-show-2 {
  0%,22%  { opacity: 0; transform: translateY(18px); }
  26%     { opacity: 1; transform: translateY(0); }
  47%     { opacity: 1; transform: translateY(0); }
  51%     { opacity: 0; transform: translateY(-12px); }
  100%    { opacity: 0; transform: translateY(-12px); }
}
@keyframes slide-show-3 {
  0%,47% { opacity: 0; transform: translateY(18px); }
  51%    { opacity: 1; transform: translateY(0); }
  72%    { opacity: 1; transform: translateY(0); }
  76%    { opacity: 0; transform: translateY(-12px); }
  100%   { opacity: 0; transform: translateY(-12px); }
}
@keyframes slide-show-4 {
  0%,72% { opacity: 0; transform: translateY(18px); }
  76%    { opacity: 1; transform: translateY(0); }
  97%    { opacity: 1; transform: translateY(0); }
  100%   { opacity: 0; transform: translateY(-12px); }
}
.hero__brand-en {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: clamp(2.8rem, 7vw, 5.5rem);
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 0.02em;
  line-height: 1;
  text-shadow: 0 0 20px rgba(245,200,0,0.3), 0 2px 8px rgba(0,0,0,0.7);
  animation: script-flow 1.6s cubic-bezier(0.22, 1, 0.36, 1) both;
  animation-delay: var(--ani-delay, 0s);
}
@keyframes script-flow {
  0%   { opacity: 0; transform: translateX(-20px) skewX(-6deg); filter: blur(4px); }
  60%  { opacity: 1; filter: blur(0); }
  100% { opacity: 1; transform: translateX(0) skewX(0deg); }
}
.hero__brand-en--accent {
  color: #F5C800;
  text-shadow: 0 0 60px rgba(245,200,0,0.6), 0 3px 12px rgba(0,0,0,0.5);
  font-size: clamp(2.5rem, 6.5vw, 5rem);
}
.hero__brand-ja {
  font-size: clamp(1rem, 2vw, 1.4rem);
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.1em;
  padding-left: 0.2rem;
}
.hero__brand-ja--accent {
  color: rgba(245,200,0,0.75);
}
.hero__brand-sep {
  width: 3rem;
  height: 2px;
  background: linear-gradient(to right, #F5C800, transparent);
  margin: 0.25rem 0;
}
@media (min-width: 481px) and (max-width: 900px) {
  .hero__slides { min-height: 20rem; }
}
@media (max-width: 480px) {
  .hero__brand-en { font-size: 1.4rem; }
  .hero__brand-en--accent { font-size: 1.5rem; }
  .hero__brand-ja { font-size: 0.75rem; }
  .hero__heading { font-size: 1.4rem; }
  .hero__slides { min-height: 14rem; }
}

/* H1 */
.hero__heading {
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -0.03em;
  color: rgba(255,255,255,0.75);
  font-size: clamp(1.4rem, 3.5vw, 2.4rem);
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.hero__accent {
  color: var(--fuji-yellow);
  font-style: normal;
  font-size: clamp(2.2rem, 5.5vw, 4rem);
  line-height: 1.1;
  display: block;
}

/* 一時停止ボタン */
.hero__pause-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 0.5rem;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 2rem;
  color: rgba(255,255,255,0.75);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  padding: 0.6rem 1.2rem;
  min-height: 44px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.hero__pause-btn:hover,
.hero__pause-btn:focus-visible {
  background: rgba(255,255,255,0.22);
  color: #fff;
  outline: 2px solid var(--fuji-yellow);
  outline-offset: 2px;
}
.hero.is-paused .hero__bg,
.hero.is-paused .hero__slide {
  animation-play-state: paused;
}

.hero__lead {
  font-size: clamp(var(--text-sm), 1.8vw, var(--text-base));
  color: var(--fuji-gray-muted);
  line-height: 1.9;
}

/* CTAボタン */
.hero__actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.hero__tel-btn {
  font-family: var(--font-en);
  font-size: 1.125rem;
  letter-spacing: 0.02em;
}
.hero__contact-btn {
  border-color: rgba(255,255,255,0.6);
  backdrop-filter: blur(4px);
