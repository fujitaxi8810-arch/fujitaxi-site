  align-items: center;
  justify-content: center;
  padding: 10px;
  transition: background var(--transition-base), border-color var(--transition-base);
}

.service-card__icon svg {
  width: 100%;
  height: 100%;
  stroke: var(--fuji-yellow);
}

.service-card:hover .service-card__icon {
  background: rgba(245, 200, 0, 0.15);
  border-color: var(--fuji-yellow);
}

.service-card__name {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--fuji-white);
}

.service-card__desc {
  font-size: var(--text-sm);
  color: var(--fuji-gray-muted);
  line-height: 1.7;
  flex: 1;
}

.service-card__link {
  font-size: var(--text-xs);
  color: var(--fuji-yellow);
  font-weight: 700;
  margin-top: auto;
}

.service-card--featured {
