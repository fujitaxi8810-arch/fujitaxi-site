  right: 1.25rem;
  background: var(--fuji-yellow);
  color: var(--fuji-black);
  font-size: 0.65rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  padding: 0.2rem 0.6rem;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
}

.services-cta {
