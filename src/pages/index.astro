</style>

<script>
  // ── ヒーロースライドショー一時停止ボタン
  const pauseBtn = document.getElementById('heroPauseBtn') as HTMLButtonElement | null;
  const heroSection = document.querySelector('.hero') as HTMLElement | null;
  if (pauseBtn && heroSection) {
    pauseBtn.addEventListener('click', () => {
      const isPaused = heroSection.classList.toggle('is-paused');
      pauseBtn.setAttribute('aria-pressed', String(isPaused));
      const iconPause = pauseBtn.querySelector('.hero__pause-icon--pause') as HTMLElement;
      const iconPlay  = pauseBtn.querySelector('.hero__pause-icon--play') as HTMLElement;
      const label     = pauseBtn.querySelector('.hero__pause-label') as HTMLElement;
      if (isPaused) {
        iconPause.style.display = 'none';
        iconPlay.style.display  = '';
        label.textContent = '再生';
        pauseBtn.setAttribute('aria-label', 'スライドショーを再生');
      } else {
        iconPause.style.display = '';
        iconPlay.style.display  = 'none';
        label.textContent = '一時停止';
        pauseBtn.setAttribute('aria-label', 'スライドショーを一時停止');
      }
    });
  }
</script>
