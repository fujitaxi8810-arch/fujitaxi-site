---
import Layout from '../layouts/Layout.astro';

const pageTitle = '南相馬市のタクシーなら富士タクシー｜小高区・原町区 予約・配車';
const pageDesc  = '南相馬市小高区・原町区のタクシーなら富士タクシー。初乗り700円〜、年中無休7:00〜24:00。ジャンボタクシー・デマンド乗合・スクール送迎・観光タクシー対応。クレカ・QR・電子マネー全対応。';

/* ── FAQPage 構造化データ ── */
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '南相馬市でタクシーを呼ぶにはどうすればいいですか？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '富士タクシー本社（0244-44-2543）または原町待機所（0244-32-0030）にお電話ください。現着通知サービスにより、車が到着する前に音声でお知らせします。',
      },
    },
    {
      '@type': 'Question',
      name: '富士タクシーの初乗り料金はいくらですか？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '普通車タクシーは初乗り700円、ジャンボタクシー（特大車）は980円です。貸切料金は利用時間・行先によってお見積りします。',
      },
    },
    {
      '@type': 'Question',
      name: 'クレジットカードや電子マネーは使えますか？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'はい、クレジットカード・PayPay等のQR決済・交通系ICカードなどの電子マネー・JTBタクシーチケットに対応しています。',
      },
    },
    {
      '@type': 'Question',
      name: 'ジャンボタクシーは何名まで乗れますか？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '最大9名様までご乗車いただけます。冠婚葬祭・家族旅行・空港送迎・観光などにご利用ください。事前予約が必要です。',
      },
    },
    {
      '@type': 'Question',
      name: '小高区から仙台や県外まで行けますか？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '小高区・原町区を出発地として、県外への長距離移動も対応しています。料金は利用時間・行先によってお見積りしますので、お電話またはメールでお問い合わせください。',
      },
    },
  ],
};

/* ── Review 構造化データ ── */
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '有限会社 富士タクシー',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '4',
  },
  review: [
    {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      author: { '@type': 'Person', name: '小高区在住・60代女性' },
      reviewBody: '朝7時に電話したらすぐ来てくれました。運転手さんが荷物も手伝ってくださり、高齢の母も安心して病院へ行けました。',
    },
    {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      author: { '@type': 'Person', name: '原町区在住・50代男性' },
      reviewBody: '法事で親族9名を乗せていただきました。ゆったり乗れて、移動中も和やかに話ができました。次もお願いします。',
    },
    {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      author: { '@type': 'Person', name: '小高区在住・保護者' },
      reviewBody: '統合後の小学校が遠くなり不安でしたが、毎日安全に送り届けてくれています。子どもも運転手さんが大好きです。',
    },
    {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      author: { '@type': 'Person', name: '南相馬市在住・70代男性' },
      reviewBody: '到着前に電話で知らせてくれるので、玄関前で待たずに済みます。足が悪い私には本当にありがたいサービスです。',
    },
  ],
};

const services = [
  { id: 'general',     name: '一般乗用タクシー',  desc: '初乗り700円〜。小高・原町区内から県外まで対応。', href: '/services#general' },
  { id: 'jumbo',       name: 'ジャンボタクシー',  desc: '最大9名、地域最多の7台保有。冠婚葬祭・旅行・空港送迎に。', href: '/services#jumbo' },
  { id: 'demand',      name: 'デマンド乗合',      desc: '高齢者・帰還住民の通院・買い物を支える乗合タクシー。', href: '/services#demand' },
  { id: 'school',      name: 'スクールタクシー',  desc: '小高区の児童・生徒を毎日安全に送迎。部活動にも対応。', href: '/services#school' },
  { id: 'sightseeing', name: '観光タクシー',       desc: '相馬野馬追・小高神社・海岸線を地元ドライバーがご案内。', href: '/services#sightseeing' },
  { id: 'corporate',   name: '法人・空港送迎',    desc: 'ビジネス・研修・重要顧客の送迎。JTBチケット対応。', href: '/corporate' },
];

const strengths = [
  { num: '50', unit: '年', label: '創業からの歴史', desc: '昭和46年創業。地域とともに半世紀以上歩んできた信頼。' },
  { num: '7',   unit: '台', label: 'ジャンボタクシー保有', desc: '地域最大級のジャンボタクシー保有数。大人数にも対応。' },
  { num: '7-24', unit: '時', label: '年中無休営業',  desc: '毎日7:00〜24:00まで対応。急な移動もお任せください。' },
  { num: '10',  unit: '種類以上', label: '決済方法対応',     desc: 'クレカ・QR・IC・JTBチケット等、全ての主要決済に対応。' },
];

const tourism = [
  { name: '小高の海岸線',         desc: '水平線から昇る朝陽。貝塚など古代の歴史も感じられる。', season: '通年' },
  { name: '小高神社 桜まつり',     desc: 'ソメイヨシノ・しだれ桜が咲き誇る名所。野馬懸も。',   season: '4月頃' },
  { name: '相馬野馬追',           desc: '国重要無形民俗文化財。勇壮な騎馬武者が集う夏祭り。',   season: '毎年5月' },
  { name: 'おだかイルミネーション', desc: '平成14年から続く冬の光の祭典。地域の絆を深める。',   season: '12〜1月' },
];

---

<Layout
  title={pageTitle}
  description={pageDesc}
  structuredData={[faqSchema, reviewSchema]}
>

<!-- ════════════════════════════════════════
     ヒーローセクション
════════════════════════════════════════ -->
<section class="hero" aria-label="メインビジュアル">
  <div class="hero__bg hero__bg--1" aria-hidden="true"></div>
  <div class="hero__bg hero__bg--2" aria-hidden="true"></div>
  <div class="hero__bg hero__bg--3" aria-hidden="true"></div>
  <div class="hero__bg hero__bg--4" aria-hidden="true"></div>
  <div class="container hero__inner">

    <!-- 左: メインコンテンツ -->
    <div class="hero__content">
      <div class="hero__slides" aria-live="polite" aria-atomic="true">

      <!-- スライド1テキスト（65333） -->
      <div class="hero__slide hero__slide--1">
        <p class="hero__brand-en">Drive the Future.</p>
        <p class="hero__brand-ja">移動の力で、地域の未来を動かす。</p>
        <div class="hero__brand-sep"></div>
        <h1 class="hero__heading">南相馬で、<br /><em class="hero__accent">いちばん頼れるタクシーがいる。</em></h1>
      </div>

      <!-- スライド2テキスト（65335） -->
      <div class="hero__slide hero__slide--2">
        <p class="hero__brand-en hero__brand-en--accent">Drive the Story.</p>
        <p class="hero__brand-ja hero__brand-ja--accent">移動が、物語になる。</p>
        <div class="hero__brand-sep"></div>
        <p class="hero__heading">乗った瞬間、<em class="hero__accent" style="font-size:clamp(1.8rem,4.5vw,3.2rem)">「頼んでよかった」と思える。</em></p>
      </div>

      <!-- スライド3テキスト（65330） -->
      <div class="hero__slide hero__slide--3">
        <p class="hero__brand-en">Since 1971.</p>
        <p class="hero__brand-ja">2011年の震災を乗り越え、南相馬とともに歩んできた。</p>
        <div class="hero__brand-sep"></div>
        <p class="hero__heading">あの日も、今日も、<br /><em class="hero__accent">この街を走り続ける。</em></p>
      </div>

      <!-- スライド4テキスト（子どもたち） -->
      <div class="hero__slide hero__slide--4">
        <p class="hero__brand-en">For Minamisoma.</p>
        <p class="hero__brand-ja">子どもから高齢者まで、全ての移動を守る。</p>
        <div class="hero__brand-sep"></div>
        <p class="hero__heading">富士タクシーは、<br /><em class="hero__accent">南相馬の「足」であり続ける。</em></p>
      </div>

      </div><!-- /.hero__slides -->

      <!-- 常時表示：CTA -->
      <div class="hero__actions hero-ani" style="--ani-delay:1.8s">
        <a href="tel:0244442543" class="btn btn--primary btn--lg hero__tel-btn" aria-label="富士タクシー本社に電話する">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l.54-.54a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 16.92z"/>
          </svg>
          0244-44-2543
        </a>
        <a href="/contact" class="btn btn--outline btn--lg hero__contact-btn">
          お問い合わせ
        </a>
      </div>

      <p class="hero__note hero-ani" style="--ani-delay:2.2s">初乗り700円〜 ｜ 現着通知サービス対応 ｜ クレカ・QR対応</p>
      <div class="hero__area hero-ani" style="--ani-delay:2.5s">
        <span>小高区・原町区 2拠点 ／ 創業昭和46年 ／ ジャンボ7台保有</span>
        <button class="hero__pause-btn" id="heroPauseBtn" aria-label="スライドショーを一時停止" aria-pressed="false">
          <svg class="hero__pause-icon hero__pause-icon--pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          <svg class="hero__pause-icon hero__pause-icon--play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><polygon points="5,3 19,12 5,21"/></svg>
          <span class="hero__pause-label">一時停止</span>
        </button>
      </div>
    </div>

  </div>
</section>

<!-- ════════════════════════════════════════
     フォトギャラリー
════════════════════════════════════════ -->
<section class="photo-gallery" aria-label="富士タクシーの現場写真">

  <!-- A: 縦長メイン（社長＋店舗） -->
  <div class="pg pg--main">
    <img src="/images/photo-staff-exterior-opt.webp" alt="富士タクシー 社長と車両・店舗外観" class="pg__img" width="800" height="600" loading="lazy" />
    <div class="pg__caption pg__caption--lg">
      <p class="pg__tag">Since 1971</p>
      <p class="pg__title">信頼の顔、地域の足。</p>
      <p class="pg__sub">南相馬市原町区の待機所にて</p>
    </div>
  </div>

  <!-- B: 右上左（車両ラインアップ） -->
  <div class="pg pg--b">
    <img src="/images/photo-cars-lineup-opt.webp" alt="富士タクシー 車両ラインアップ 黒・黄・ジャンボ3台" class="pg__img" width="600" height="450" loading="lazy" />
    <div class="pg__caption">
      <p class="pg__title">多彩な車両で、あらゆる場面に。</p>
      <p class="pg__sub">普通車・デマンド車・ジャンボタクシー</p>
    </div>
  </div>

  <!-- C: 右上右（小高駅前） -->
  <div class="pg pg--c">
    <img src="/images/photo-car-odaka-opt.webp" alt="小高駅前に停車する富士タクシー車両" class="pg__img" width="600" height="450" loading="lazy" />
    <div class="pg__caption">
      <p class="pg__title">小高駅から、どこへでも。</p>
      <p class="pg__sub">JR小高駅前 送迎対応</p>
    </div>
  </div>

  <!-- D: 右下ワイド（震災・復興） -->
  <div class="pg pg--d pg--d-disaster">
    <div class="pg__disaster-pair">
      <img src="/images/uploads/disaster-fuji-taxi-1.webp" alt="震災で倒壊した富士タクシー社屋（小高区）" class="pg__img pg__img--crop pg__disaster-img" width="768" height="1280" loading="lazy" />
      <img src="/images/uploads/disaster-fuji-taxi-2.webp" alt="震災直後の富士タクシー社屋全景" class="pg__img pg__img--crop pg__disaster-img" width="1280" height="768" loading="lazy" />
    </div>
    <div class="pg__caption pg__caption--wide">
      <p class="pg__title">震災を乗り越え、復興とともに歩んできた。</p>
      <p class="pg__sub">2011年 震災直後の富士タクシー本社</p>
    </div>
  </div>

</section>

<!-- ════════════════════════════════════════
     ブランドステートメント
════════════════════════════════════════ -->
<section class="brand-statement" aria-label="ブランドメッセージ">
  <div class="container brand-statement__inner">
    <p class="brand-statement__en">Drive the Story.</p>
    <p class="brand-statement__ja">移動が、物語になる。</p>
    <div class="brand-statement__line"></div>
    <p class="brand-statement__desc">
      一度の乗車が、誰かの人生の一場面になる。<br />
      富士タクシーは、移動を通じて南相馬の物語をつくり続けます。
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════
     子どもの未来セクション
════════════════════════════════════════ -->
<section class="children-section" aria-label="地域の子どもたちへの取り組み">
  <div class="children-section__img-wrap">
    <img
      src="/images/photo-children-sakura-opt.webp"
      alt="小高川沿いの桜並木を歩く子どもたち"
      class="children-section__img"
      width="1080" height="1350"
      loading="lazy"
    />
  </div>
  <div class="children-section__overlay">
    <div class="children-section__content">
      <div class="children-section__heading-wrap">
        <h2 class="children-section__heading">
          <span class="children-section__heading-line1">子どもたちの未来のために、</span>
        </h2>
      </div>
      <p class="children-section__lead">
        スクールタクシーで安全な通学を支える。<br />
        デマンドタクシーで高齢者の生活を守る。<br />
        富士タクシーは、移動を通じて南相馬市の未来をつくります。
      </p>
      <a href="/community" class="btn btn--primary btn--lg">地域への取り組みを見る</a>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════
     お客様の声
════════════════════════════════════════ -->
<section class="section bg-black" aria-labelledby="reviews-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Reviews</p>
      <h2 class="heading-lg section-title" id="reviews-heading">
        お客様の<span class="text-yellow">声</span>
      </h2>
    </div>
    <div class="reviews-grid reveal">
      <div class="review-card">
        <div class="review-card__stars" aria-label="5つ星"><span aria-hidden="true">★★★★★</span></div>
        <p class="review-card__use">通院送迎</p>
        <p class="review-card__text">「朝7時に電話したらすぐ来てくれました。運転手さんが荷物も手伝ってくださり、高齢の母も安心して病院へ行けました。」</p>
        <p class="review-card__author">— 小高区在住・60代女性</p>
      </div>
      <div class="review-card">
        <div class="review-card__stars" aria-label="5つ星"><span aria-hidden="true">★★★★★</span></div>
        <p class="review-card__use">ジャンボタクシー</p>
        <p class="review-card__text">「法事で親族9名を乗せていただきました。ゆったり乗れて、移動中も和やかに話ができました。次もお願いします。」</p>
        <p class="review-card__author">— 原町区在住・50代男性</p>
      </div>
      <div class="review-card">
        <div class="review-card__stars" aria-label="5つ星"><span aria-hidden="true">★★★★★</span></div>
        <p class="review-card__use">スクールタクシー</p>
        <p class="review-card__text">「統合後の小学校が遠くなり不安でしたが、毎日安全に送り届けてくれています。子どもも運転手さんが大好きです。」</p>
        <p class="review-card__author">— 小高区在住・保護者</p>
      </div>
      <div class="review-card">
        <div class="review-card__stars" aria-label="5つ星"><span aria-hidden="true">★★★★★</span></div>
        <p class="review-card__use">現着通知サービス</p>
        <p class="review-card__text">「到着前に電話で知らせてくれるので、玄関前で待たずに済みます。足が悪い私には本当にありがたいサービスです。」</p>
        <p class="review-card__author">— 南相馬市在住・70代男性</p>
      </div>
    </div>
    <p class="reviews-scroll-hint">← スワイプして全ての口コミを見る →</p>
    <div class="reviews-cta reveal">
      <p class="reviews-cta__label">実際のお客様の口コミはこちらからご確認いただけます</p>
      <div class="reviews-cta__btns">
        <a href="https://share.google/NKXIRazpjfWqHbWd8" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
          本社（小高区）の口コミ →
        </a>
        <a href="https://share.google/OuOLfGxyT5DaGiKc8" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
          原町待機所の口コミ →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════
     サービス一覧
════════════════════════════════════════ -->
<section class="section services-section bg-soft" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Services</p>
      <h2 class="heading-lg section-title" id="services-heading">
        富士タクシーの<span class="text-yellow">全サービス</span>
      </h2>
      <p class="lead" style="max-width:560px; white-space:nowrap;">
        一般乗車から観光・福祉・スクールまで、南相馬市の移動をワンストップで。
      </p>
    </div>

    <div class="services-grid">

      <a href="/services#general" class="service-card reveal" style="transition-delay:0ms">
        <div class="service-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 17H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h13l4 4v6a2 2 0 0 1-2 2h-2"/>
            <circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>
            <path d="M1 9h16"/>
          </svg>
        </div>
        <h3 class="service-card__name">一般乗用タクシー</h3>
        <p class="service-card__desc">初乗り700円〜。小高・原町区内から県外まで対応。</p>
        <span class="service-card__link" aria-hidden="true">詳しく見る →</span>
      </a>

      <a href="/services#jumbo" class="service-card reveal" style="transition-delay:60ms">
        <div class="service-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="6" width="22" height="12" rx="2"/>
            <path d="M1 10h22M5 6V4M19 6V4"/>
            <circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/>
            <path d="M8 10v4M12 10v4M16 10v4"/>
          </svg>
        </div>
        <h3 class="service-card__name">ジャンボタクシー</h3>
        <p class="service-card__desc">最大9名、地域最多の7台保有。冠婚葬祭・旅行・空港送迎に。</p>
        <span class="service-card__link" aria-hidden="true">詳しく見る →</span>
      </a>

