.strength-card:hover { border-right-color: var(--fuji-yellow); }

.strength-card__num {
  display: flex;
  align-items: baseline;
  gap: 0.25rem;
  flex-shrink: 0;
}

.strength-card__figure {
  font-family: var(--font-en);
  font-size: 3rem;
  font-weight: 800;
  color: var(--fuji-yellow);
  line-height: 1;
}

.strength-card__unit {
  font-family: var(--font-en);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--fuji-yellow);
  opacity: 0.7;
}

.strength-card__label {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--fuji-white);
  margin-bottom: 0.4rem;
}

.strength-card__desc {
  font-size: var(--text-sm);
  color: var(--fuji-gray-muted);
  line-height: 1.7;
}

/* ─────────────────────────────
   決済バナー
───────────────────────────── */
.payment-banner { padding-block: var(--space-8); }
.payment-banner__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.payment-banner__title {
  font-size: var(--text-lg);
  font-weight: 700;
}
.payment-banner__sub {
  font-size: var(--text-sm);
  opacity: 0.7;
  margin-top: 0.25rem;
}

/* ─────────────────────────────
   ブランドステートメント
───────────────────────────── */
.brand-statement {
  background: #000;
  padding: 4rem 0;
  text-align: center;
  border-top: 1px solid rgba(245,200,0,0.15);
  border-bottom: 1px solid rgba(245,200,0,0.15);
}
.brand-statement__inner {
  max-width: 720px;
}
.brand-statement__en {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: clamp(3.5rem, 9vw, 7.5rem);
  font-weight: 900;
  color: var(--fuji-yellow);
  letter-spacing: -0.04em;
  line-height: 1;
  margin-bottom: 0.5rem;
  text-shadow: 0 0 80px rgba(245,200,0,0.3);
}
.brand-statement__ja {
  font-size: clamp(1.4rem, 3.5vw, 2.2rem);
  font-weight: 700;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.1em;
  margin-bottom: 2rem;
}
.brand-statement__line {
  width: 3rem;
  height: 2px;
  background: var(--fuji-yellow);
  margin: 0 auto 2rem;
}
.brand-statement__desc {
  font-size: clamp(0.9rem, 2vw, 1.1rem);
  color: rgba(255,255,255,0.55);
  line-height: 2;
  letter-spacing: 0.04em;
}

/* ─────────────────────────────
   子どもの未来セクション
───────────────────────────── */
.children-section {
  position: relative;
  min-height: clamp(500px, 75vh, 800px);
  display: flex;
  align-items: center;
}

.children-section__img-wrap {
  position: absolute;
  inset: 0;
}

.children-section__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: right 30%;
  display: block;
  filter: brightness(0.55);
  transition: transform 8s ease;
}

.children-section:hover .children-section__img {
  transform: scale(1.04);
}

.children-section__overlay {
  position: relative;
  z-index: 1;
  width: 100%;
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.65) 0%,
    rgba(0,0,0,0.3) 60%,
    transparent 100%
  );
  padding-block: 4rem;
}

.children-section__content {
  max-width: 600px;
  margin: 0;
  margin-left: 4vw;
  padding-inline: 2rem;
}

/* ── 口コミセクション ── */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-bottom: var(--space-10);
}
.review-card {
  background: var(--fuji-black-card);
  border: 1px solid var(--fuji-gray-border);
  border-radius: 0.75rem;
  padding: 1.5rem;
}
.review-card__stars {
  color: var(--fuji-yellow);
  font-size: 1rem;
  letter-spacing: 0.1em;
  margin-bottom: 0.5rem;
}
.review-card__use {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--fuji-yellow);
  border: 1px solid rgba(245,200,0,0.4);
  border-radius: 2rem;
  padding: 0.1rem 0.6rem;
  margin-bottom: 0.75rem;
}
.review-card__text {
  color: var(--fuji-off-white);
  font-size: 0.9rem;
  line-height: 1.8;
  margin-bottom: 1rem;
}
.review-card__author {
  color: var(--fuji-gray-muted);
  font-size: 0.8rem;
}
.reviews-cta {
  text-align: center;
}
.reviews-cta__label {
  color: rgba(255,255,255,0.7);
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 1rem;
  letter-spacing: 0.03em;
}
.reviews-cta__btns {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}
@media (max-width: 900px) {
  .reviews-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 640px) {
  .reviews-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 1rem;
    padding-bottom: 1.25rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--fuji-yellow) rgba(255,255,255,0.1);
  }
  .reviews-grid::-webkit-scrollbar {
    height: 4px;
  }
  .reviews-grid::-webkit-scrollbar-track {
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
  }
  .reviews-grid::-webkit-scrollbar-thumb {
    background: var(--fuji-yellow);
    border-radius: 2px;
  }
  .review-card {
    min-width: 85vw;
    scroll-snap-align: start;
    flex-shrink: 0;
  }
}
.reviews-scroll-hint {
  display: none;
  text-align: center;
  color: var(--fuji-gray-muted);
  font-size: 0.78rem;
  margin-top: -0.5rem;
  margin-bottom: 1rem;
  letter-spacing: 0.04em;
}
@media (max-width: 640px) {
  .reviews-scroll-hint { display: block; }
}

/* ── children-section ── */
.children-section__heading-wrap {
  margin-bottom: 1.25rem;
}

.children-section__eyebrow-inline {
  display: block;
  font-family: var(--font-en);
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--fuji-yellow);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 0.2rem;
}

.children-section__heading {
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.children-section__heading-line1 {
  font-size: clamp(2.2rem, 6vw, 4.2rem);
  color: #fff;
  display: block;
  line-height: 1.1;
  letter-spacing: -0.03em;
  text-shadow: 0 2px 24px rgba(0,0,0,0.5);
}

.children-section__heading-line2 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-style: normal;
  color: var(--fuji-yellow);
  display: block;
}

.children-section__lead {
  font-size: var(--text-base);
  color: rgba(255,255,255,0.85);
  line-height: 2;
  margin-bottom: 2rem;
}

@media (max-width: 640px) {
  .children-section { height: auto; min-height: 480px; }
  .children-section__overlay { background: rgba(0,0,0,0.55); }
  .children-section__content { max-width: 100%; }
}

/* ─────────────────────────────
   DX配車（富士タクQ）
───────────────────────────── */
.dx-section { overflow: hidden; }

.dx-inner {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 4rem;
  align-items: center;
}

.dx-badge {
  display: inline-flex;
  align-items: center;
  background: var(--fuji-yellow);
  color: var(--fuji-black);
  font-family: var(--font-en);
  font-size: var(--text-xs);
  font-weight: 900;
  letter-spacing: 0.12em;
  padding: 0.3rem 0.9rem;
  border-radius: var(--radius-full);
  margin-bottom: 0.75rem;
}

.dx-heading {
  color: var(--fuji-white);
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-block: 0.75rem;
}

.dx-lead {
  color: var(--fuji-gray-muted);
  line-height: 1.9;
  font-size: var(--text-base);
  max-width: 560px;
  margin-bottom: 2rem;
}
.dx-lead strong { color: var(--fuji-white); }

/* 3特徴 */
.dx-features {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2rem;
}

.dx-feature {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
  padding: 1rem 1.25rem;
}

.dx-feature__icon {
  width: 40px;
  height: 40px;
  background: rgba(245,200,0,0.12);
  border: 1px solid rgba(245,200,0,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--fuji-yellow);
}
.dx-feature__icon svg { width: 18px; height: 18px; }

.dx-feature__title {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--fuji-white);
  margin-bottom: 0.2rem;
}
.dx-feature__desc {
  font-size: var(--text-sm);
  color: var(--fuji-gray-muted);
  line-height: 1.6;
}

/* 専門家インサイト */
.dx-insight {
  display: flex;
  gap: 1rem;
  background: rgba(245,200,0,0.06);
  border: 1px solid rgba(245,200,0,0.2);
  border-left: 3px solid var(--fuji-yellow);
  border-radius: var(--radius-lg);
  padding: 1rem 1.25rem;
}
.dx-insight__icon {
  width: 20px;
  height: 20px;
  color: var(--fuji-yellow);
  flex-shrink: 0;
  margin-top: 0.1rem;
}
.dx-insight__icon svg { width: 100%; height: 100%; }
.dx-insight__text {
  font-size: var(--text-sm);
  color: var(--fuji-gray-muted);
  line-height: 1.8;
}

/* 画像エリア */
.dx-image {
  position: relative;
}

.dx-image__img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-xl);
  box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  display: block;
}

.dx-image__label {
  position: absolute;
  bottom: -1rem;
  left: 50%;
  transform: translateX(-50%);
  background: var(--fuji-yellow);
  color: var(--fuji-black);
  border-radius: var(--radius-full);
  padding: 0.5rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  white-space: nowrap;
  box-shadow: 0 4px 16px rgba(0,0,0,0.3);
}
.dx-image__label-text {
  font-size: var(--text-base);
  font-weight: 900;
}
.dx-image__label-sub {
  font-size: var(--text-xs);
  font-weight: 700;
  opacity: 0.75;
}

@media (max-width: 900px) {
  .dx-inner {
    grid-template-columns: 1fr;
  }
  .dx-image { order: -1; }
  .dx-image__label { bottom: 0.75rem; }
}

/* ─────────────────────────────
   観光セクション
───────────────────────────── */
.tourism-section {
  background: var(--fuji-black);
  color: var(--fuji-white);
}
.tourism-section__inner {
  display: grid;
  grid-template-columns: 360px 1fr;
  align-items: stretch;
  min-height: clamp(480px, 70vw, 820px);
}
.tourism-section__header {
  padding: 3.5rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1.25rem;
  border-right: 1px solid rgba(255,255,255,0.1);
  background: linear-gradient(160deg, rgba(245,200,0,0.04) 0%, transparent 60%);
}
.tourism-section__sub-eyebrow {
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.08em;
  margin-top: -0.75rem;
}
.tourism-section__heading {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 900;
  line-height: 1.35;
  color: var(--fuji-white);
  letter-spacing: -0.01em;
}
.tourism-section__heading-em {
  color: var(--fuji-yellow);
  font-size: clamp(1.9rem, 3.5vw, 2.6rem);
}
.tourism-section__divider {
  width: 2.5rem;
  height: 3px;
  background: var(--fuji-yellow);
  border-radius: 2px;
}
.tourism-section__desc {
  font-size: var(--text-sm);
  line-height: 2;
  color: rgba(255,255,255,0.6);
}
.tourism-section__cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  margin-top: 0.5rem;
  padding: 0.85rem 1.5rem;
  background: var(--fuji-yellow);
  color: var(--fuji-black);
  font-weight: 800;
  font-size: var(--text-sm);
  border-radius: var(--radius-full);
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: background 0.2s, transform 0.2s;
  align-self: flex-start;
}
.tourism-section__cta-btn:hover {
  background: var(--fuji-yellow-dark);
  transform: translateX(3px);
}
.tourism-section__cta-arrow {
  font-size: 1.1em;
  transition: transform 0.2s;
}
.tourism-section__cta-btn:hover .tourism-section__cta-arrow {
  transform: translateX(4px);
}
@media (max-width: 900px) {
  .tourism-section__inner {
    grid-template-columns: 1fr;
  }
  .tourism-section__header {
    padding: 2.5rem 1.5rem;
    border-right: none;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
}
.tourism-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

/* イルミネーション写真 */
.illum-photos {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 1.5rem;
  align-items: center;
  background: var(--fuji-black);
  border-radius: var(--radius-xl);
  padding: 1.75rem;
}
.illum-photos__label {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.illum-photos__season {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--fuji-yellow);
  border: 1px solid var(--fuji-yellow);
  border-radius: var(--radius-full);
  padding: 0.2rem 0.7rem;
  width: fit-content;
  letter-spacing: 0.05em;
}
.illum-photos__title {
  font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  font-weight: 900;
  color: var(--fuji-white);
  line-height: 1.3;
}
.illum-photos__desc {
  font-size: var(--text-sm);
  color: var(--fuji-gray-muted);
  line-height: 1.8;
}
.illum-photos__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
}
.illum-photos__grid--3 {
  grid-template-columns: 1fr 1fr 1fr;
}
.illum-photos__img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  border-radius: var(--radius-lg);
  max-height: 180px;
}
@media (max-width: 700px) {
  .illum-photos { grid-template-columns: 1fr; }
  .illum-photos__grid { grid-template-columns: 1fr 1fr; }
}

/* 観光写真ベントーグリッド */
.tpg {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  grid-template-rows: 1fr 1fr 1fr;
  height: 100%;
  min-height: clamp(480px, 70vw, 820px);
  background: #0a0a0a;
  gap: 6px;
}
/* 野馬追1: 左縦長 */
.tpg--a { grid-column: 1; grid-row: 1 / 3; }
/* 野馬追2 */
.tpg--b { grid-column: 2; grid-row: 1; }
/* 野馬追3 */
.tpg--c { grid-column: 3; grid-row: 1; }
/* 小高神社1: 右ワイド */
.tpg--d { grid-column: 2 / 4; grid-row: 2; }
/* 小高神社2 */
.tpg--e { grid-column: 1; grid-row: 3; }
/* 小高神社3 */
.tpg--f { grid-column: 2; grid-row: 3; }
/* イルミ1 */
.tpg--g { grid-column: 3; grid-row: 3; }
/* イルミ2: 非表示（3行グリッドに収まらないため） */
.tpg--h { display: none; }

@media (max-width: 700px) {
  .tpg {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: repeat(4, 160px);
    height: auto;
  }
  .tpg--a { grid-column: 1 / 3; grid-row: 1; }
  .tpg--b { grid-column: 1; grid-row: 2; }
  .tpg--c { grid-column: 2; grid-row: 2; }
  .tpg--d { grid-column: 1 / 3; grid-row: 3; }
  .tpg--e { grid-column: 1; grid-row: 4; }
  .tpg--f { grid-column: 2; grid-row: 4; }
  .tpg--g { display: none; }
}

.tourism-card {
  background: var(--fuji-white);
  border: 1px solid var(--fuji-gray-light);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  transition: border-color var(--transition-base), transform var(--transition-base);
}

.tourism-card:hover {
  border-color: var(--fuji-yellow-dark);
  transform: translateY(-2px);
}

.tourism-card__season {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--fuji-black);
  background: var(--fuji-yellow);
  padding: 0.2rem 0.75rem;
  border-radius: var(--radius-full);
  margin-bottom: 0.875rem;
}

.tourism-card__name {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--fuji-black);
  margin-bottom: 0.5rem;
}

.tourism-card__desc {
  font-size: var(--text-sm);
  color: #555;
  line-height: 1.7;
}

/* ─────────────────────────────
   地域活動ティーザー
───────────────────────────── */
.community-teaser__inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
}

.community-teaser__stats {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  flex-shrink: 0;
}

.community-stat {
  background: var(--fuji-black-card);
  border: 1px solid var(--fuji-gray-border);
  border-left: 3px solid var(--fuji-yellow);
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  padding: 1.25rem 1.5rem;
  min-width: 180px;
}

.community-stat__label {
  display: block;
  font-size: var(--text-xs);
  color: var(--fuji-gray-muted);
  margin-bottom: 0.375rem;
}

.community-stat__value {
  font-size: var(--text-xl);
  font-weight: 800;
  color: var(--fuji-yellow);
  line-height: 1.3;
}

/* ─────────────────────────────
   FAQ
───────────────────────────── */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--fuji-gray-border);
}

.faq-item {
  background: var(--fuji-black-card);
}

.faq-item[open] {
  border-bottom: 1px solid var(--fuji-gray-border);
}

.faq-question {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.375rem 1.75rem;
  cursor: pointer;
  list-style: none;
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--fuji-white);
  transition: background var(--transition-fast);
  border-bottom: 1px solid var(--fuji-gray-border);
}

.faq-question:hover { background: rgba(245,200,0,0.04); }

.faq-question::-webkit-details-marker { display: none; }

.faq-q-mark {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  background: var(--fuji-yellow);
  color: var(--fuji-black);
  font-size: var(--text-xs);
  font-weight: 900;
  font-family: var(--font-en);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.faq-chevron {
  margin-left: auto;
  flex-shrink: 0;
  color: var(--fuji-gray-muted);
  transition: transform var(--transition-base);
}

.faq-item[open] .faq-chevron { transform: rotate(180deg); }

.faq-answer {
  display: flex;
  gap: 1rem;
  padding: 1.375rem 1.75rem;
  align-items: flex-start;
}

.faq-a-mark {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  border: 1.5px solid var(--fuji-gray-border);
  color: var(--fuji-gray-muted);
  font-size: var(--text-xs);
  font-weight: 900;
  font-family: var(--font-en);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.faq-answer p {
  font-size: var(--text-sm);
  color: var(--fuji-gray-muted);
  line-height: 1.8;
}

/* ─────────────────────────────
   CTAバナー
───────────────────────────── */
.cta-banner {
  padding-block: var(--space-12);
}

.cta-banner__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

.cta-banner__actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.cta-banner__phones {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.cta-banner__tel {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  font-family: var(--font-en);
  font-size: 1.5rem;
  font-weight: 900;
  color: var(--fuji-black);
  text-decoration: none;
  letter-spacing: 0.02em;
  line-height: 1.2;
}
.cta-banner__tel:hover { text-decoration: underline; }
.cta-banner__branch {
