---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="勤怠管理 – 富士タクシー（社内用）"
  description="富士タクシー社内用の勤怠管理アプリ。出勤・退勤の打刻、シフト日給・歩合給の給与計算、CSV出力ができます。"
>

  <section class="page-hero bg-black">
    <div class="container">
      <p class="eyebrow">Staff Only</p>
      <h1>勤怠<span class="text-yellow">管理</span></h1>
      <p class="page-hero__lead">出勤・退勤をワンタップで記録。このページは社内用です。</p>
      <p class="kintai-clock" id="clock" aria-live="polite">--:--:--</p>
      <p class="kintai-date" id="today"></p>
    </div>
  </section>

  <section class="section bg-black" style="padding-top: 1rem;">
    <div class="container kintai-wrap">

      <!-- 管理者ロック -->
      <div class="kt-adminbar">
        <span class="kt-adminbar__label" id="adminState">🔒 売上・給与データは非表示中</span>
        <button type="button" class="kt-btn kt-btn--ghost" id="adminToggleBtn">管理者ロック解除</button>
      </div>

      <!-- スタッフ選択 -->
      <div class="kt-panel">
        <div class="kt-panel__head">
          <h2 class="kt-title">スタッフ</h2>
          <button type="button" class="kt-btn kt-btn--ghost" id="addStaffBtn">＋ 追加</button>
        </div>
        <div class="kt-staff-list" id="staffList"></div>
        <p class="kt-empty" id="staffEmpty">「＋ 追加」からスタッフを登録してください。</p>
      </div>

      <!-- 打刻パネル -->
      <div class="kt-panel kt-panel--punch" id="punchPanel" hidden>
        <p class="kt-selected">選択中：<strong id="selectedName"></strong></p>
        <p class="kt-status" id="statusLabel"></p>

        <!-- 出勤前：シフト選択 -->
        <div class="kt-shift-select" id="shiftSelect">
          <p class="kt-shift-select__label">① 電話番を担当する場合はチェック</p>
          <label class="kt-check">
            <input type="checkbox" id="phoneDutyCheck" />
            <span>電話番を担当する<small id="phoneAllowanceLabel"></small></span>
          </label>
          <p class="kt-shift-select__label">② シフトを選んで出勤</p>
          <div class="kt-shift-grid">
            <button type="button" class="kt-shift-btn kt-shift-btn--normal" id="punchInNormal">
              <span class="kt-shift-btn__name">普通番で出勤</span>
              <span class="kt-shift-btn__sub" id="normalWageLabel"></span>
            </button>
            <button type="button" class="kt-shift-btn kt-shift-btn--late" id="punchInLate">
              <span class="kt-shift-btn__name">遅番で出勤</span>
              <span class="kt-shift-btn__sub" id="lateWageLabel"></span>
            </button>
          </div>
        </div>

        <!-- 出勤後：通常の打刻グリッド -->
        <div class="kt-punch-grid" id="punchGrid" hidden>
          <button type="button" class="kt-punch kt-punch--out" id="punchOut">退勤</button>
          <button type="button" class="kt-punch kt-punch--break" id="punchBreakStart">休憩 開始</button>
          <button type="button" class="kt-punch kt-punch--break" id="punchBreakEnd">休憩 終了</button>
          <button type="button" class="kt-punch kt-punch--away" id="punchAwayStart">時間内退勤</button>
          <button type="button" class="kt-punch kt-punch--away" id="punchAwayEnd">時間内出勤</button>
        </div>

        <p class="kt-msg" id="punchMsg" aria-live="polite"></p>
      </div>

      <!-- 本日の状況 -->
      <div class="kt-panel">
        <h2 class="kt-title">本日の状況</h2>
        <div class="kt-today" id="todayBoard"></div>
        <p class="kt-empty" id="todayEmpty">本日の打刻はまだありません。</p>
      </div>

      <!-- 履歴 -->
      <div class="kt-panel">
        <div class="kt-panel__head">
          <h2 class="kt-title">勤務履歴</h2>
          <div class="kt-panel__tools">
            <input type="month" id="monthPick" class="kt-input" />
            <button type="button" class="kt-btn" id="csvBtn">CSV出力</button>
          </div>
        </div>
        <div class="kt-table-wrap">
          <table class="kt-table" id="histTable">
            <thead>
              <tr><th>日付</th><th>名前</th><th>シフト</th><th>出勤</th><th>退勤</th><th>休憩</th><th>時間内外出</th><th>実働</th><th>売上(税抜)</th><th>カード手数料</th><th>日給</th><th>歩合給</th><th>合計</th><th>時給換算</th></tr>
            </thead>
            <tbody id="histBody"></tbody>
          </table>
        </div>
        <p class="kt-empty" id="histEmpty">この月の記録はありません。</p>
      </div>

      <!-- 月次給与サマリー -->
      <div class="kt-panel">
        <h2 class="kt-title">月次給与サマリー</h2>
        <div class="kt-table-wrap">
          <table class="kt-table" id="wageTable">
            <thead>
              <tr><th>名前</th><th>出勤日数</th><th>実働合計</th><th>日給合計</th><th>売上合計</th><th>歩合給合計</th><th>総支給額</th></tr>
            </thead>
            <tbody id="wageBody"></tbody>
          </table>
        </div>
        <p class="kt-empty" id="wageEmpty">この月の記録はありません。</p>
        <p class="kt-note" id="wageFormula">※ 総支給額 ＝ シフト日給 ＋ 電話番手当 ＋ 歩合給｛（売上税抜 − カード手数料等）× 歩合率｝<br />※ 勤務履歴の「時給換算」は 総支給額 ÷ 実働時間 で算出し、最低賃金（設定値）を下回った日は赤色で警告表示します。</p>
      </div>

      <!-- 給与設定 -->
      <div class="kt-panel" id="settingsPanel" hidden>
        <h2 class="kt-title">給与設定（管理者）</h2>
        <div class="kt-settings-grid">
          <label class="kt-field">
            <span>普通番 基本日給（円）</span>
            <input type="number" id="setNormalWage" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>遅番 基本日給（円）</span>
            <input type="number" id="setLateWage" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>遅番 割増賃金（円）</span>
            <input type="number" id="setLateBonus" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>電話番手当（円）</span>
            <input type="number" id="setPhoneAllowance" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>歩合率（％）</span>
            <input type="number" id="setCommissionRate" class="kt-input" min="0" max="100" step="0.01" />
          </label>
          <label class="kt-field">
            <span>クレジットカード手数料率（％）</span>
            <input type="number" id="setCardFeeRate" class="kt-input" min="0" max="100" step="0.01" />
          </label>
          <label class="kt-field">
            <span>PayPay手数料率（％）</span>
            <input type="number" id="setPaypayFeeRate" class="kt-input" min="0" max="100" step="0.01" />
          </label>
          <label class="kt-field">
            <span>d払い手数料率（％）</span>
            <input type="number" id="setDbaraiFeeRate" class="kt-input" min="0" max="100" step="0.01" />
          </label>
          <label class="kt-field">
            <span>メルペイ手数料率（％）</span>
            <input type="number" id="setMerpayFeeRate" class="kt-input" min="0" max="100" step="0.01" />
          </label>
          <label class="kt-field">
            <span>最低賃金（円・確認用）</span>
            <input type="number" id="setMinWage" class="kt-input" min="0" />
          </label>
        </div>
        <button type="button" class="kt-btn" id="saveSettingsBtn">設定を保存</button>
        <p class="kt-note">※ ここで設定した金額・歩合率が、すべてのスタッフの給与計算に使われます。退勤時に決済方法ごとの内訳（クレジット・PayPay・d払い・メルペイ）を入力すると、それぞれの手数料率で自動計算した金額が目安として入力欄に表示されます。必要に応じて手入力で修正してください。</p>
      </div>
      <button type="button" class="kt-btn kt-btn--ghost" id="settingsToggleBtn" hidden>⚙ 給与設定を開く</button>

      <p class="kt-note">※ データはこの端末のブラウザ内にのみ保存されます。端末を変えると記録は引き継がれません。月末にCSV出力して保管してください。</p>

    </div>
  </section>

</Layout>

<script>
  const LS_STAFF = 'fuji-kintai-staff';
  const LS_LOG = 'fuji-kintai-log';
  const LS_SETTINGS = 'fuji-kintai-settings';
  const SS_ADMIN = 'fuji-kintai-admin';

  const DEFAULT_SETTINGS = {
    normalWage: 8400,
    lateWage: 8400,
    lateBonus: 700,
    phoneAllowance: 300,
    commissionRate: 16.57,
    cardFeeRate: 3.1, // SBペイメントサービス収納明細書（2026/06/16-06/30分）の実績に基づく目安。月額固定費を除く決済手数料の平均。決済手段の内訳で変動するため手入力で調整可。
    paypayFeeRate: 2.18, // PayPay（別端末決済）の実際の手数料率
    dbaraiFeeRate: 2.6,  // d払い（別端末決済）の実際の手数料率
    merpayFeeRate: 2.6,  // メルペイ（別端末決済）の実際の手数料率
    minWage: 1033, // 福島県の地域別最低賃金（確認用）
    adminPassword: '',
  };

  let staff = JSON.parse(localStorage.getItem(LS_STAFF) || '[]');
  let log = JSON.parse(localStorage.getItem(LS_LOG) || '[]');
  let settings = Object.assign({}, DEFAULT_SETTINGS, JSON.parse(localStorage.getItem(LS_SETTINGS) || '{}'));
  let selectedId = null;

  const $ = (id) => document.getElementById(id);

  // ── 時計 ──
  function tick() {
    const now = new Date();
    $('clock').textContent = now.toLocaleTimeString('ja-JP');
    $('today').textContent = now.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
  }
  tick();
  setInterval(tick, 1000);

  function save() {
    localStorage.setItem(LS_STAFF, JSON.stringify(staff));
    localStorage.setItem(LS_LOG, JSON.stringify(log));
  }
  function saveSettings() {
    localStorage.setItem(LS_SETTINGS, JSON.stringify(settings));
  }

  function dateKey(d) {
    const dt = d ? new Date(d) : new Date();
    return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
  }
  function timeStr(iso) {
    return new Date(iso).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
  }
  function yen(n) {
    return Math.round(n).toLocaleString('ja-JP');
  }

  // ── 管理者ロック ──
  function isAdmin() {
    return sessionStorage.getItem(SS_ADMIN) === '1';
  }
  function requireAdmin() {
    if (isAdmin()) return true;
    if (!settings.adminPassword) {
      const p1 = prompt('初めて管理者機能を使います。管理者パスワードを設定してください。');
      if (!p1) return false;
      const p2 = prompt('確認のため、もう一度入力してください。');
      if (p1 !== p2) { alert('パスワードが一致しませんでした。もう一度お試しください。'); return false; }
      settings.adminPassword = p1;
      saveSettings();
      sessionStorage.setItem(SS_ADMIN, '1');
      return true;
    }
    const input = prompt('管理者パスワードを入力してください。');
    if (input === settings.adminPassword) {
      sessionStorage.setItem(SS_ADMIN, '1');
      return true;
    }
    if (input !== null) alert('パスワードが違います。');
    return false;
  }
  function renderAdminBar() {
    const unlocked = isAdmin();
    $('adminState').textContent = unlocked ? '🔓 売上・給与データを表示中' : '🔒 売上・給与データは非表示中';
    $('adminToggleBtn').textContent = unlocked ? 'ロックする' : '管理者ロック解除';
    $('settingsToggleBtn').hidden = !unlocked;
    if (!unlocked) $('settingsPanel').hidden = true;
  }
  $('adminToggleBtn').onclick = () => {
    if (isAdmin()) {
      sessionStorage.removeItem(SS_ADMIN);
    } else {
      requireAdmin();
    }
    renderAdminBar(); renderToday(); renderHist(); renderWage();
  };
  $('settingsToggleBtn').onclick = () => {
    $('settingsPanel').hidden = !$('settingsPanel').hidden;
    if (!$('settingsPanel').hidden) fillSettingsForm();
  };
  function fillSettingsForm() {
    $('setNormalWage').value = settings.normalWage;
    $('setLateWage').value = settings.lateWage;
    $('setLateBonus').value = settings.lateBonus;
    $('setPhoneAllowance').value = settings.phoneAllowance;
    $('setCommissionRate').value = settings.commissionRate;
    $('setCardFeeRate').value = settings.cardFeeRate;
    $('setPaypayFeeRate').value = settings.paypayFeeRate;
    $('setDbaraiFeeRate').value = settings.dbaraiFeeRate;
    $('setMerpayFeeRate').value = settings.merpayFeeRate;
    $('setMinWage').value = settings.minWage;
  }
  $('saveSettingsBtn').onclick = () => {
    settings.normalWage = parseInt($('setNormalWage').value, 10) || 0;
    settings.lateWage = parseInt($('setLateWage').value, 10) || 0;
    settings.lateBonus = parseInt($('setLateBonus').value, 10) || 0;
    settings.phoneAllowance = parseInt($('setPhoneAllowance').value, 10) || 0;
    settings.cardFeeRate = parseFloat($('setCardFeeRate').value) || 0;
    settings.paypayFeeRate = parseFloat($('setPaypayFeeRate').value) || 0;
    settings.dbaraiFeeRate = parseFloat($('setDbaraiFeeRate').value) || 0;
    settings.merpayFeeRate = parseFloat($('setMerpayFeeRate').value) || 0;
    settings.commissionRate = parseFloat($('setCommissionRate').value) || 0;
    settings.minWage = parseInt($('setMinWage').value, 10) || 0;
    saveSettings();
    alert('設定を保存しました。');
    renderPunch(); renderToday(); renderHist(); renderWage();
  };

  // ── スタッフ ──
  function renderStaff() {
    const list = $('staffList');
    list.innerHTML = '';
    $('staffEmpty').hidden = staff.length > 0;
    for (const s of staff) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'kt-staff' + (s.id === selectedId ? ' is-active' : '');
      const nameSpan = document.createElement('span');
      nameSpan.textContent = s.name;
      btn.appendChild(nameSpan);
      btn.onclick = () => { selectedId = s.id; renderStaff(); renderPunch(); };
      const del = document.createElement('span');
      del.className = 'kt-staff__del';
      del.textContent = '×';
      del.setAttribute('role', 'button');
      del.setAttribute('aria-label', `${s.name}を削除`);
      del.onclick = (e) => {
        e.stopPropagation();
        if (confirm(`${s.name} を削除しますか？（打刻履歴は残ります）`)) {
          staff = staff.filter(x => x.id !== s.id);
          if (selectedId === s.id) selectedId = null;
          save(); renderStaff(); renderPunch();
        }
      };
      btn.appendChild(del);
      list.appendChild(btn);
    }
  }

  $('addStaffBtn').onclick = () => {
    const name = prompt('スタッフの名前を入力してください');
    if (!name || !name.trim()) return;
    staff.push({ id: 'st' + Date.now(), name: name.trim() });
    save(); renderStaff();
  };

  // ── 状態判定 ──
  function todayRec(staffId) {
    return log.find(r => r.staffId === staffId && r.date === dateKey());
  }
  function statusOf(rec) {
    if (!rec || !rec.in) return 'before';        // 未出勤
    if (rec.out) return 'done';                  // 退勤済み
    const lastBreak = rec.breaks[rec.breaks.length - 1];
    if (lastBreak && !lastBreak.end) return 'break'; // 休憩中
    const leaves = rec.leaves || [];
    const lastLeave = leaves[leaves.length - 1];
    if (lastLeave && !lastLeave.end) return 'away'; // 時間内退勤中
    return 'working';                            // 勤務中
  }
  const STATUS_LABEL = { before: '未出勤', working: '勤務中', break: '休憩中', away: '時間内退勤中', done: '退勤済み' };
  const SHIFT_LABEL = { normal: '普通番', late: '遅番' };

  function renderPunch() {
    const panel = $('punchPanel');
    if (!selectedId) { panel.hidden = true; return; }
    const s = staff.find(x => x.id === selectedId);
    if (!s) { panel.hidden = true; return; }
    panel.hidden = false;
    $('selectedName').textContent = s.name;
    const rec = todayRec(selectedId);
    const st = statusOf(rec);
    $('statusLabel').textContent = `現在：${STATUS_LABEL[st]}${rec && rec.shiftType ? '（' + SHIFT_LABEL[rec.shiftType] + '）' : ''}`;

    $('normalWageLabel').textContent = `${yen(settings.normalWage)}円`;
    $('lateWageLabel').textContent = `${yen(settings.lateWage + settings.lateBonus)}円`;
    $('phoneAllowanceLabel').textContent = `（+${yen(settings.phoneAllowance)}円）`;

    const canPunchIn = st === 'before';
    $('shiftSelect').hidden = !canPunchIn;
    $('punchGrid').hidden = canPunchIn;

    $('punchOut').disabled = st !== 'working';
    $('punchBreakStart').disabled = st !== 'working';
    $('punchBreakEnd').disabled = st !== 'break';
    $('punchAwayStart').disabled = st !== 'working';
    $('punchAwayEnd').disabled = st !== 'away';
  }

  function punchIn(shiftType) {
    if (!selectedId) return;
    const now = new Date().toISOString();
    let rec = todayRec(selectedId);
    if (!rec) {
      rec = { staffId: selectedId, date: dateKey(), in: null, out: null, breaks: [], leaves: [] };
      log.push(rec);
    }
    rec.in = now;
    rec.shiftType = shiftType;
    rec.phoneDuty = $('phoneDutyCheck').checked;
    save();
    const s = staff.find(x => x.id === selectedId);
    $('punchMsg').textContent = `✅ ${s.name} さんが${SHIFT_LABEL[shiftType]}で出勤しました（${timeStr(now)}）`;
    $('phoneDutyCheck').checked = false;
    renderPunch(); renderToday(); renderHist(); renderWage();
  }

  function punch(type) {
    if (!selectedId) return;
    const now = new Date().toISOString();
    let rec = todayRec(selectedId);
    if (!rec) return;
    if (!rec.leaves) rec.leaves = [];

    if (type === 'out') {
      const salesInput = prompt('本日の売上（税抜）を入力してください（円）※不明な場合は空欄でOK');
      if (salesInput !== null && salesInput.trim() !== '') {
        const sales = parseFloat(salesInput);
        if (!isNaN(sales) && sales >= 0) {
          rec.sales = sales;

          const num = (v) => { const n = parseFloat(v); return (!isNaN(n) && n >= 0) ? n : 0; };
          const creditInput = prompt('うちクレジットカード決済分（円）を入力してください\n※現金・その他はここに含めなくてOK', '0');
          if (creditInput === null) { /* キャンセルなら手数料0円のまま進む */ }
          const credit = num(creditInput);
          const paypayInput = prompt('うちPayPay決済分（円）を入力してください', '0');
          const paypay = num(paypayInput);
          const dbaraiInput = prompt('うちd払い決済分（円）を入力してください', '0');
          const dbarai = num(dbaraiInput);
          const merpayInput = prompt('うちメルペイ決済分（円）を入力してください', '0');
          const merpay = num(merpayInput);

          const suggestedFee = Math.round(
            credit * (settings.cardFeeRate / 100) +
            paypay * (settings.paypayFeeRate / 100) +
            dbarai * (settings.dbaraiFeeRate / 100) +
            merpay * (settings.merpayFeeRate / 100)
          );
          const feeInput = prompt(`カード決済手数料等（差し引く金額）を入力してください（円）\n※入力内容から自動計算した目安です。実際の金額が分かれば書き換えてください。`, String(suggestedFee));
          const fee = parseFloat(feeInput);
          rec.cardFee = (!isNaN(fee) && fee >= 0) ? fee : suggestedFee;
        }
      }
      rec.out = now;
    }
    if (type === 'breakStart') rec.breaks.push({ start: now, end: null });
    if (type === 'breakEnd') {
      const b = rec.breaks[rec.breaks.length - 1];
      if (b && !b.end) b.end = now;
    }
    if (type === 'awayStart') rec.leaves.push({ start: now, end: null });
    if (type === 'awayEnd') {
      const l = rec.leaves[rec.leaves.length - 1];
      if (l && !l.end) l.end = now;
    }
    save();
    const s = staff.find(x => x.id === selectedId);
    const labels = { out: '退勤', breakStart: '休憩開始', breakEnd: '休憩終了', awayStart: '時間内退勤', awayEnd: '時間内出勤' };
    $('punchMsg').textContent = `✅ ${s.name} さんの${labels[type]}を ${timeStr(now)} に記録しました`;
    renderPunch(); renderToday(); renderHist(); renderWage();
  }
  $('punchInNormal').onclick = () => punchIn('normal');
  $('punchInLate').onclick = () => punchIn('late');
  $('punchOut').onclick = () => punch('out');
  $('punchBreakStart').onclick = () => punch('breakStart');
  $('punchBreakEnd').onclick = () => punch('breakEnd');
  $('punchAwayStart').onclick = () => punch('awayStart');
  $('punchAwayEnd').onclick = () => punch('awayEnd');

  // ── 実働計算 ──
  function workMinutes(rec) {
    if (!rec.in) return null;
    const end = rec.out ? new Date(rec.out) : new Date();
    let ms = end - new Date(rec.in);
    for (const b of rec.breaks) {
      const bEnd = b.end ? new Date(b.end) : new Date();
      ms -= (bEnd - new Date(b.start));
    }
    for (const l of (rec.leaves || [])) {
      const lEnd = l.end ? new Date(l.end) : new Date();
      ms -= (lEnd - new Date(l.start));
    }
    return Math.max(0, Math.round(ms / 60000));
  }
  function breakMinutes(rec) {
    let ms = 0;
    for (const b of rec.breaks) {
      const bEnd = b.end ? new Date(b.end) : new Date();
      ms += (bEnd - new Date(b.start));
    }
    return Math.round(ms / 60000);
  }
  function awayMinutes(rec) {
    let ms = 0;
    for (const l of (rec.leaves || [])) {
      const lEnd = l.end ? new Date(l.end) : new Date();
      ms += (lEnd - new Date(l.start));
    }
    return Math.round(ms / 60000);
  }
  function hm(min) {
    if (min === null) return '—';
    return `${Math.floor(min / 60)}:${String(min % 60).padStart(2, '0')}`;
  }

  // ── 給与計算 ──
  function shiftWage(rec) {
    if (!rec.shiftType) return 0;
    let w = rec.shiftType === 'late' ? (settings.lateWage + settings.lateBonus) : settings.normalWage;
    if (rec.phoneDuty) w += settings.phoneAllowance;
    return w;
  }
  function commissionPay(rec) {
    if (rec.sales == null) return 0;
    const net = Math.max(0, (rec.sales || 0) - (rec.cardFee || 0));
    return net * (settings.commissionRate / 100);
  }
  function totalPay(rec) {
    return shiftWage(rec) + commissionPay(rec);
  }
  function hourlyRate(rec) {
    if (!rec.out) return null;
    const min = workMinutes(rec);
    if (!min || min <= 0) return null;
    return totalPay(rec) / (min / 60);
  }
  function isBelowMinWage(rec) {
    const rate = hourlyRate(rec);
    return rate !== null && rate < settings.minWage;
  }
  function mask(text) {
    return isAdmin() ? text : '••••';
  }

  // ── 本日の状況 ──
  function renderToday() {
    const board = $('todayBoard');
    board.innerHTML = '';
    const recs = log.filter(r => r.date === dateKey());
    $('todayEmpty').hidden = recs.length > 0;
    for (const rec of recs) {
      const s = staff.find(x => x.id === rec.staffId);
      const st = statusOf(rec);
      const div = document.createElement('div');
      div.className = `kt-today-card kt-today-card--${st}`;
      div.innerHTML = `
        <p class="kt-today-card__name">${s ? s.name : '（削除済み）'}</p>
        <p class="kt-today-card__status">${STATUS_LABEL[st]}${rec.shiftType ? '・' + SHIFT_LABEL[rec.shiftType] : ''}</p>
        <p class="kt-today-card__times">出勤 ${rec.in ? timeStr(rec.in) : '—'} ／ 退勤 ${rec.out ? timeStr(rec.out) : '—'}</p>
      `;
      board.appendChild(div);
    }
  }

  // ── 履歴 ──
  function currentMonth() {
    return $('monthPick').value || dateKey().slice(0, 7);
  }
  function renderHist() {
    const month = currentMonth();
    const body = $('histBody');
    body.innerHTML = '';
    const recs = log.filter(r => r.date.startsWith(month)).sort((a, b) => b.date.localeCompare(a.date));
    $('histEmpty').hidden = recs.length > 0;
    $('histTable').style.display = recs.length ? '' : 'none';
    for (const rec of recs) {
      const s = staff.find(x => x.id === rec.staffId);
      const w = rec.out ? workMinutes(rec) : null;
      const belowMin = isAdmin() && isBelowMinWage(rec);
      const rate = hourlyRate(rec);
      const tr = document.createElement('tr');
      if (belowMin) tr.className = 'kt-table__row--warn';
      tr.innerHTML = `
        <td>${rec.date.slice(5).replace('-', '/')}</td>
        <td>${s ? s.name : '（削除済み）'}</td>
        <td>${rec.shiftType ? SHIFT_LABEL[rec.shiftType] + (rec.phoneDuty ? '＋電話番' : '') : '—'}</td>
        <td>${rec.in ? timeStr(rec.in) : '—'}</td>
        <td>${rec.out ? timeStr(rec.out) : '—'}</td>
        <td>${hm(breakMinutes(rec))}</td>
        <td>${hm(awayMinutes(rec))}</td>
        <td class="kt-table__work">${rec.out ? hm(w) : '勤務中'}</td>
        <td>${mask(rec.sales != null ? yen(rec.sales) + '円' : '—')}</td>
        <td>${mask(rec.cardFee != null ? yen(rec.cardFee) + '円' : '—')}</td>
        <td>${mask(rec.shiftType ? yen(shiftWage(rec)) + '円' : '—')}</td>
        <td>${mask(rec.sales != null ? yen(commissionPay(rec)) + '円' : '—')}</td>
        <td class="kt-table__total">${rec.out ? mask(yen(totalPay(rec)) + '円') : '—'}</td>
        <td>${mask(rate !== null ? yen(rate) + '円' + (belowMin ? ' ⚠️最低賃金未満' : '') : '—')}</td>
      `;
      body.appendChild(tr);
    }
  }

  // ── 月次給与サマリー ──
  function renderWage() {
    const month = currentMonth();
    const body = $('wageBody');
    body.innerHTML = '';
    const recs = log.filter(r => r.date.startsWith(month) && r.out);
    const totals = {};
    for (const rec of recs) {
      if (!totals[rec.staffId]) totals[rec.staffId] = { days: 0, minutes: 0, wage: 0, sales: 0, commission: 0 };
      const t = totals[rec.staffId];
      t.days += 1;
      t.minutes += workMinutes(rec);
      t.wage += shiftWage(rec);
      t.sales += (rec.sales || 0);
      t.commission += commissionPay(rec);
    }
    const ids = Object.keys(totals);
    $('wageEmpty').hidden = ids.length > 0;
    $('wageTable').style.display = ids.length ? '' : 'none';
    for (const id of ids) {
      const s = staff.find(x => x.id === id);
      const t = totals[id];
      const total = t.wage + t.commission;
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${s ? s.name : '（削除済み）'}</td>
        <td>${t.days}日</td>
        <td>${hm(t.minutes)}</td>
        <td>${mask(yen(t.wage) + '円')}</td>
        <td>${mask(yen(t.sales) + '円')}</td>
        <td>${mask(yen(t.commission) + '円')}</td>
        <td class="kt-table__total">${mask(yen(total) + '円')}</td>
      `;
      body.appendChild(tr);
    }
  }

  $('monthPick').value = dateKey().slice(0, 7);
  $('monthPick').onchange = () => { renderHist(); renderWage(); };

  // ── CSV出力 ──
  $('csvBtn').onclick = () => {
    if (!requireAdmin()) return;
    renderAdminBar();
    const month = currentMonth();
    const recs = log.filter(r => r.date.startsWith(month)).sort((a, b) => a.date.localeCompare(b.date));
    if (!recs.length) { alert('この月の記録がありません'); return; }
    let csv = '﻿日付,名前,シフト,電話番,出勤,退勤,休憩(分),時間内外出(分),実働(分),実働(時:分),売上税抜(円),カード手数料等(円),シフト日給(円),歩合給(円),合計支給額(円),時給換算(円),最低賃金判定\n';
    for (const rec of recs) {
      const s = staff.find(x => x.id === rec.staffId);
      const w = rec.out ? workMinutes(rec) : '';
      const rate = hourlyRate(rec);
      csv += [
        rec.date,
        s ? s.name : '削除済み',
        rec.shiftType ? SHIFT_LABEL[rec.shiftType] : '',
        rec.phoneDuty ? '有' : '',
        rec.in ? timeStr(rec.in) : '',
        rec.out ? timeStr(rec.out) : '',
        breakMinutes(rec),
        awayMinutes(rec),
        w,
        rec.out ? hm(w) : '',
        rec.sales != null ? rec.sales : '',
        rec.cardFee != null ? rec.cardFee : '',
        rec.shiftType ? Math.round(shiftWage(rec)) : '',
        rec.sales != null ? Math.round(commissionPay(rec)) : '',
        rec.out ? Math.round(totalPay(rec)) : '',
        rate !== null ? Math.round(rate) : '',
        rate !== null ? (isBelowMinWage(rec) ? '最低賃金未満' : 'OK') : '',
      ].join(',') + '\n';
    }

    csv += `\n設定：普通番日給${settings.normalWage}円／遅番日給${settings.lateWage + settings.lateBonus}円／電話番手当${settings.phoneAllowance}円／歩合率${settings.commissionRate}%／最低賃金${settings.minWage}円\n`;
    csv += '\n月次サマリー\n名前,出勤日数,実働合計(分),実働合計(時:分),シフト日給合計(円),売上合計(円),歩合給合計(円),総支給額(円)\n';
    const totals = {};
    for (const rec of recs) {
      if (!rec.out) continue;
      if (!totals[rec.staffId]) totals[rec.staffId] = { days: 0, minutes: 0, wage: 0, sales: 0, commission: 0 };
      const t = totals[rec.staffId];
      t.days += 1;
      t.minutes += workMinutes(rec);
      t.wage += shiftWage(rec);
      t.sales += (rec.sales || 0);
      t.commission += commissionPay(rec);
    }
    for (const id of Object.keys(totals)) {
      const s = staff.find(x => x.id === id);
      const t = totals[id];
      csv += [
        s ? s.name : '削除済み',
        t.days,
        t.minutes,
        hm(t.minutes),
        Math.round(t.wage),
        Math.round(t.sales),
        Math.round(t.commission),
        Math.round(t.wage + t.commission),
      ].join(',') + '\n';
    }

    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `勤怠給与_${month}.csv`;
    a.click();
    URL.revokeObjectURL(a.href);
  };

  renderAdminBar();
  renderStaff();
  renderPunch();
  renderToday();
  renderHist();
  renderWage();
</script>

