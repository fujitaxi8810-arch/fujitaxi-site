---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="勤怠管理 – 富士タクシー（社内用）"
  description="富士タクシー社内用の勤怠管理アプリ。出勤・退勤の打刻、シフト日給・歩合給の給与計算、CSV出力ができます。"
>

  <section class="page-hero bg-black">
    <div class="container">
      <p class="eyebrow">Staff Only</p>
      <h1>勤怠<span class="text-yellow">管理</span></h1>
      <p class="page-hero__lead">出勤・退勤をワンタップで記録。このページは社内用です。</p>
      <p class="kintai-clock" id="clock" aria-live="polite">--:--:--</p>
      <p class="kintai-date" id="today"></p>
    </div>
  </section>

  <section class="section bg-black" style="padding-top: 1rem;">
    <div class="container kintai-wrap">

      <!-- スタッフ選択 -->
      <div class="kt-panel">
        <div class="kt-panel__head">
          <h2 class="kt-title">スタッフ</h2>
          <button type="button" class="kt-btn kt-btn--ghost" id="addStaffBtn">＋ 追加</button>
        </div>
        <div class="kt-staff-list" id="staffList"></div>
        <p class="kt-empty" id="staffEmpty">「＋ 追加」からスタッフを登録してください。</p>
      </div>

      <!-- 打刻パネル -->
      <div class="kt-panel kt-panel--punch" id="punchPanel" hidden>
        <p class="kt-selected">選択中：<strong id="selectedName"></strong></p>
        <p class="kt-status" id="statusLabel"></p>

        <!-- 出勤前：シフト選択（正社員） -->
        <div class="kt-shift-select" id="shiftSelect">
          <div id="phoneDutyBlock">
            <p class="kt-shift-select__label">① 電話番を担当する場合はチェック</p>
            <label class="kt-check">
              <input type="checkbox" id="phoneDutyCheck" />
              <span>電話番を担当する</span>
            </label>
            <p class="kt-shift-select__label">② シフトを選んで出勤</p>
          </div>
          <div class="kt-shift-grid" id="fulltimeShiftGrid">
            <button type="button" class="kt-shift-btn kt-shift-btn--normal" id="punchInNormal">
              <span class="kt-shift-btn__name">普通番で出勤</span>
            </button>
            <button type="button" class="kt-shift-btn kt-shift-btn--late" id="punchInLate">
              <span class="kt-shift-btn__name">遅番で出勤</span>
            </button>
          </div>
          <!-- 出勤前（パート）：シフトなしの単一出勤ボタン -->
          <div class="kt-shift-grid" id="partShiftGrid" hidden>
            <button type="button" class="kt-shift-btn kt-shift-btn--normal" id="punchInPart">
              <span class="kt-shift-btn__name">出勤</span>
            </button>
          </div>
        </div>

        <!-- 出勤後：通常の打刻グリッド -->
        <div class="kt-punch-grid" id="punchGrid" hidden>
          <button type="button" class="kt-punch kt-punch--out" id="punchOut">退勤</button>
          <button type="button" class="kt-punch kt-punch--break" id="punchBreakStart">休憩 開始</button>
          <button type="button" class="kt-punch kt-punch--break" id="punchBreakEnd">休憩 終了</button>
          <button type="button" class="kt-punch kt-punch--away" id="punchAwayStart">時間内退勤</button>
          <button type="button" class="kt-punch kt-punch--away" id="punchAwayEnd">時間内出勤</button>
        </div>

        <p class="kt-msg" id="punchMsg" aria-live="polite"></p>
      </div>

      <!-- 売上入力モーダル（管理者専用・履歴から開く） -->
      <div class="kt-modal-overlay" id="salesModal" hidden>
        <div class="kt-modal" role="dialog" aria-modal="true" aria-labelledby="salesModalTitle">
          <h2 class="kt-title" id="salesModalTitle">売上の入力（管理者）</h2>
          <p class="kt-modal__staff" id="salesModalStaff"></p>

          <label class="kt-field kt-field--sales">
            <span>その日の売上合計（税込・円）</span>
            <input type="number" id="salesTotalInput" class="kt-input" min="0" inputmode="numeric" placeholder="例: 30000" />
          </label>
          <p class="kt-modal__taxnote" id="salesNetPreview">税抜：0円（歩合給の計算に使用）</p>

          <label class="kt-field">
            <span>未収（円・掛け／請求書払いなど当日未回収分）</span>
            <input type="number" id="salesUncollectedInput" class="kt-input" min="0" inputmode="numeric" placeholder="例: 0" />
          </label>

          <p class="kt-shift-select__label">決済方法ごとの内訳（該当分のみ入力・現金は不要）</p>
          <div class="kt-modal__methods" id="salesMethodFields"></div>

          <div class="kt-modal__summary">
            <div class="kt-modal__summary-row">
              <span>手数料合計（自動計算）</span>
              <strong id="salesFeeAuto">0円</strong>
            </div>
            <label class="kt-field">
              <span>手数料合計を手修正する場合（円）</span>
              <input type="number" id="salesFeeOverride" class="kt-input" min="0" inputmode="numeric" placeholder="空欄なら自動計算を使用" />
            </label>
          </div>

          <div class="kt-modal__actions">
            <button type="button" class="kt-punch kt-punch--out" id="salesModalSubmit">保存する</button>
            <button type="button" class="kt-btn kt-btn--ghost" id="salesModalCancel">キャンセル</button>
          </div>
        </div>
      </div>

      <!-- 本日の状況 -->
      <div class="kt-panel">
        <h2 class="kt-title">本日の状況</h2>
        <div class="kt-today" id="todayBoard"></div>
        <p class="kt-empty" id="todayEmpty">本日の打刻はまだありません。</p>
      </div>

      <!-- 管理者ロック -->
      <div class="kt-adminbar">
        <span class="kt-adminbar__label" id="adminState">🔒 売上・給与データは非表示中</span>
        <button type="button" class="kt-btn kt-btn--ghost" id="adminToggleBtn">管理者ロック解除</button>
      </div>

      <!-- 履歴（管理者のみ） -->
      <div class="kt-panel" id="histPanel" hidden>
        <div class="kt-panel__head">
          <h2 class="kt-title">勤務履歴（管理者）</h2>
          <div class="kt-panel__tools">
            <input type="month" id="monthPick" class="kt-input" />
            <button type="button" class="kt-btn" id="csvBtn">CSV出力</button>
            <button type="button" class="kt-btn" id="timecardBtn">給与計算Excel出力</button>
          </div>
        </div>
        <div class="kt-excelsync" id="excelSyncBox" hidden>
          <span class="kt-excelsync__label" id="excelSyncState">Excel自動保存：未設定</span>
          <div class="kt-excelsync__btns">
            <button type="button" class="kt-btn kt-btn--ghost" id="excelPickBtn">Excelファイルを選択</button>
            <button type="button" class="kt-btn kt-btn--ghost" id="excelSyncNowBtn">未反映分を書き込む</button>
          </div>
        </div>
        <div class="kt-table-wrap">
          <table class="kt-table" id="histTable">
            <thead>
              <tr><th>日付</th><th>名前</th><th>区分</th><th>出勤</th><th>退勤</th><th>休憩</th><th>時間内外出</th><th>実働</th><th>売上(税込)</th><th>未収</th><th>カード手数料</th><th>基本給</th><th>歩合・手当</th><th>合計</th><th>時給換算</th><th>操作</th></tr>
            </thead>
            <tbody id="histBody"></tbody>
          </table>
        </div>
        <p class="kt-empty" id="histEmpty">この月の記録はありません。</p>
      </div>

      <!-- 月次給与サマリー（管理者のみ） -->
      <div class="kt-panel" id="wagePanel" hidden>
        <h2 class="kt-title">月次給与サマリー（管理者）</h2>
        <div class="kt-table-wrap">
          <table class="kt-table" id="wageTable">
            <thead>
              <tr><th>名前</th><th>区分</th><th>出勤日数</th><th>実働合計</th><th>基本給合計</th><th>売上合計</th><th>歩合・手当合計</th><th>総支給額</th></tr>
            </thead>
            <tbody id="wageBody"></tbody>
          </table>
        </div>
        <p class="kt-empty" id="wageEmpty">この月の記録はありません。</p>
        <p class="kt-note" id="wageFormula">※ 正社員：総支給額 ＝ シフト日給 ＋ 電話番手当 ＋ 歩合給｛（売上税抜 − カード手数料等）× 歩合率｝＋ 交通費（設定した場合）<br />※ 正社員（基本給のみ）：総支給額 ＝ シフト日給 ＋ 電話番手当 ＋ 交通費（設定した場合）｛歩合給なし｝<br />※ 時給制（パート・正社員(時給)）：総支給額 ＝ 時間給 × 実働時間 ＋ 残業割増（8時間超×25%）＋ 深夜割増（22時以降×25%）＋ 交通費（日額）<br />※ 月給制（正社員(月給)）：総支給額 ＝ 月給（固定）＋ 交通費（日額）<br />※ 勤務履歴の「時給換算」は 総支給額 ÷ 実働時間 で算出し、最低賃金（設定値）を下回った日は赤色で警告表示します（月給制は対象外）。<br />※ 売上は税込で入力すると税抜が自動計算されます（歩合給の計算には税抜額を使用）。未収（掛け・請求書払いなど当日未回収分）は歩合給の計算には影響しません。</p>
      </div>

      <!-- 給与設定 -->
      <div class="kt-panel" id="settingsPanel" hidden>
        <h2 class="kt-title">給与設定（管理者）</h2>
        <div class="kt-settings-grid">
          <label class="kt-field">
            <span>普通番 基本日給（円）</span>
            <input type="number" id="setNormalWage" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>遅番 基本日給（円）</span>
            <input type="number" id="setLateWage" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>遅番 割増賃金（円）</span>
            <input type="number" id="setLateBonus" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>電話番手当（円）</span>
            <input type="number" id="setPhoneAllowance" class="kt-input" min="0" />
          </label>
          <label class="kt-field">
            <span>歩合率（％）</span>
            <input type="number" id="setCommissionRate" class="kt-input" min="0" max="100" step="0.01" />
          </label>
          <label class="kt-field">
            <span>最低賃金（円・確認用）</span>
            <input type="number" id="setMinWage" class="kt-input" min="0" />
          </label>
        </div>
        <p class="kt-shift-select__label" style="margin-top:1rem;">決済方法ごとの手数料率（％）</p>
        <div class="kt-settings-grid" id="feeRateFields"></div>
        <button type="button" class="kt-btn" id="saveSettingsBtn">設定を保存</button>
        <p class="kt-note">※ ここで設定した金額・歩合率・手数料率が、すべてのスタッフの給与計算に使われます。手数料率はSBペイメントサービス収納明細書（2026年6月分）の実績値を初期値にしています。料率改定があった場合はここで更新してください。</p>
      </div>
      <button type="button" class="kt-btn kt-btn--ghost" id="settingsToggleBtn" hidden>⚙ 給与設定を開く</button>
      <button type="button" class="kt-btn kt-btn--danger" id="clearLogBtn" hidden>🗑 全打刻データを削除</button>

      <p class="kt-note">※ データは全端末で共有されます。月末に「給与計算Excel出力」またはCSV出力で保管してください。</p>

    </div>
  </section>

</Layout>

<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<script>
  import {
    initAuth, isAdmin, signInAdmin, signOutToKiosk,
    fetchStaff, insertStaff, updateStaff, deactivateStaff,
    fetchSettings, updateSettings as dbUpdateSettings,
    fetchMonth, fetchToday, upsertAttendance, deleteAllAttendance,
  } from '../lib/kintai-db';

  // 決済方法マスタ。rateはSBペイメントサービス収納明細書（2026/06/16-06/30分）の実績値。
  // 楽天Pay・au PAYは決済手数料3.24%＋決済サービス利用料0.15%の合算。
  const PAY_METHODS = [
    { id: 'visa',       label: 'VISA / Mastercard',              rate: 2.8 },
    { id: 'jcb',        label: 'JCB / AMEX / Diners',            rate: 3.24 },
    { id: 'transit',    label: '交通系IC',                        rate: 2.0 },
    { id: 'emoney',     label: '電子マネー（Edy・iD・WAON・nanaco）', rate: 2.9 },
    { id: 'quicpay',    label: 'QUICPay',                        rate: 3.24 },
    { id: 'rakuten',    label: '楽天Pay / au PAY',               rate: 3.39 },
    { id: 'paypay',     label: 'PayPay（別端末）',                rate: 2.18 },
    { id: 'dbarai',     label: 'd払い（別端末）',                 rate: 2.6 },
    { id: 'merpay',     label: 'メルペイ（別端末）',               rate: 2.6 },
    { id: 'aiticket',   label: '愛のタクシーチケット',             rate: 5 },
    { id: 'jcbticket',  label: 'JCBタクシーチケット',             rate: 4 },
  ];

  // データはSupabaseが正。起動時にboot()でまとめて読み込む
  let staff = [];
  let settings = null;
  let log = [];       // 表示中の月（monthPick）の打刻データ
  let todayLog = [];  // 本日分の打刻データ（全スタッフ）
  let selectedId = null;

  const $ = (id) => document.getElementById(id);
  $('monthPick').value = dateKey().slice(0, 7);

  // ── 時計 ──
  function tick() {
    const now = new Date();
    $('clock').textContent = now.toLocaleTimeString('ja-JP');
    $('today').textContent = now.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
  }
  tick();
  setInterval(tick, 1000);

  function currentMonth() {
    return $('monthPick').value || dateKey().slice(0, 7);
  }

  /** 本日分（todayLog）と表示中の月（log）をSupabaseから再取得する */
  async function refreshData() {
    const [t, m] = await Promise.all([
      fetchToday(dateKey()),
      fetchMonth(currentMonth()),
    ]);
    todayLog = t;
    log = m;
  }
  const SAVE_FAIL_MSG = '通信エラーで保存できませんでした。電波状況を確認してもう一度お試しください。';

  function dateKey(d) {
    const dt = d ? new Date(d) : new Date();
    return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
  }
  function timeStr(iso) {
    return new Date(iso).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
  }
  function yen(n) {
    return Math.round(n).toLocaleString('ja-JP');
  }

  // ── Excel自動保存（ファイルシステムアクセスAPI） ──
  const EXCEL_SHEET_NAME = 'CSV貼り付け';
  const EXCEL_SUPPORTED = typeof window.showOpenFilePicker === 'function';
  const IDB_NAME = 'fuji-kintai-db';
  const IDB_STORE = 'handles';
  const IDB_KEY = 'excelFile';

  function idbOpen() {
    return new Promise((resolve, reject) => {
      const req = indexedDB.open(IDB_NAME, 1);
      req.onupgradeneeded = () => { req.result.createObjectStore(IDB_STORE); };
      req.onsuccess = () => resolve(req.result);
      req.onerror = () => reject(req.error);
    });
  }
  async function idbSet(key, value) {
    const db = await idbOpen();
    return new Promise((resolve, reject) => {
      const tx = db.transaction(IDB_STORE, 'readwrite');
      tx.objectStore(IDB_STORE).put(value, key);
      tx.oncomplete = () => resolve();
      tx.onerror = () => reject(tx.error);
    });
  }
  async function idbGet(key) {
    const db = await idbOpen();
    return new Promise((resolve, reject) => {
      const tx = db.transaction(IDB_STORE, 'readonly');
      const req = tx.objectStore(IDB_STORE).get(key);
      req.onsuccess = () => resolve(req.result);
      req.onerror = () => reject(req.error);
    });
  }

  async function pickExcelFile() {
    if (!EXCEL_SUPPORTED) {
      alert('お使いのブラウザはこの機能に対応していません。Google ChromeまたはMicrosoft Edgeでお試しください。');
      return;
    }
    try {
      const [handle] = await window.showOpenFilePicker({
        types: [{ description: 'Excelファイル', accept: { 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': ['.xlsx'] } }],
        excludeAcceptAllOption: false,
      });
      await idbSet(IDB_KEY, handle);
      $('excelSyncState').textContent = `📄 ${handle.name} に接続済み`;
      renderExcelSyncBox();
    } catch (e) {
      if (e.name !== 'AbortError') alert('ファイルの選択に失敗しました：' + e.message);
    }
  }

  async function getExcelHandle() {
    try { return await idbGet(IDB_KEY); } catch { return undefined; }
  }

  async function ensureExcelPermission(handle) {
    const opts = { mode: 'readwrite' };
    if ((await handle.queryPermission(opts)) === 'granted') return true;
    if ((await handle.requestPermission(opts)) === 'granted') return true;
    return false;
  }

  function excelRowFromRec(rec) {
    const s = staff.find(x => x.id === rec.staffId);
    const w = rec.out ? workMinutes(rec) : '';
    const rate = hourlyRate(rec);
    const p = payParts(rec);
    const isSimple = usesSimplePunch(recEmpType(rec));
    const showsSales = hasCommission(recEmpType(rec));
    return [
      rec.date,
      s ? s.name : '削除済み',
      isSimple ? EMP_LABEL[recEmpType(rec)] : (rec.shiftType ? SHIFT_LABEL[rec.shiftType] : ''),
      rec.phoneDuty ? '有' : '',
      rec.in ? timeStr(rec.in) : '',
      rec.out ? timeStr(rec.out) : '',
      breakMinutes(rec),
      awayMinutes(rec),
      w,
      rec.out ? hm(w) : '',
      showsSales && rec.salesGross != null ? rec.salesGross : '',
      showsSales && rec.sales != null ? rec.sales : '',
      showsSales && rec.uncollected ? rec.uncollected : '',
      showsSales && rec.cardFee != null ? rec.cardFee : '',
      rec.out || rec.shiftType ? Math.round(p.base) : '',
      rec.out ? Math.round(p.extra) : '',
      rec.out ? Math.round(totalPay(rec)) : '',
      rate !== null ? Math.round(rate) : '',
      rate !== null ? (isBelowMinWage(rec) ? '最低賃金未満' : 'OK') : '',
    ];
  }

  function nextEmptyRowIndex(worksheet) {
    const ref = worksheet['!ref'] || 'A1:A1';
    const range = XLSX.utils.decode_range(ref);
    let lastFilled = 1; // 見出し行（0始まりで0）
    for (let r = range.s.r; r <= range.e.r; r++) {
      const cell = worksheet[XLSX.utils.encode_cell({ r, c: 0 })];
      if (cell && cell.v !== undefined && cell.v !== '') lastFilled = r;
    }
    return lastFilled + 1; // 次の空行（0始まり）
  }

  async function appendRecordsToExcel(recs) {
    if (!recs.length) return { ok: true, count: 0 };
    const handle = await getExcelHandle();
    if (!handle) return { ok: false, reason: 'no-handle' };
    if (!(await ensureExcelPermission(handle))) return { ok: false, reason: 'no-permission' };

    const file = await handle.getFile();
    const buf = await file.arrayBuffer();
    const wb = XLSX.read(buf, { type: 'array', cellFormula: true });
    if (!wb.SheetNames.includes(EXCEL_SHEET_NAME)) return { ok: false, reason: 'no-sheet' };
    const ws = wb.Sheets[EXCEL_SHEET_NAME];

    const startRow = nextEmptyRowIndex(ws);
    const rows = recs.map(excelRowFromRec);
    XLSX.utils.sheet_add_aoa(ws, rows, { origin: { r: startRow, c: 0 } });

    const wbout = XLSX.write(wb, { type: 'array', bookType: 'xlsx' });
    const writable = await handle.createWritable();
    await writable.write(wbout);
    await writable.close();
    return { ok: true, count: recs.length };
  }

  // Excel自動保存の「送信済み」フラグはこの端末だけのローカルな状態（データ本体はSupabase共有のため、
  // 打刻レコードにフラグを持たせると他端末にも波及してしまう）
  const EXCEL_SYNCED_KEY = 'fuji-kintai-excel-synced-ids';
  function getSyncedIds() {
    try { return new Set(JSON.parse(localStorage.getItem(EXCEL_SYNCED_KEY) || '[]')); } catch { return new Set(); }
  }
  function markSynced(ids) {
    const cur = getSyncedIds();
    for (const id of ids) cur.add(id);
    localStorage.setItem(EXCEL_SYNCED_KEY, JSON.stringify([...cur]));
  }

  async function syncUnsyncedToExcel(showAlert) {
    const syncedIds = getSyncedIds();
    const unsynced = log.filter(r => r.out && !syncedIds.has(r.id));
    const result = await appendRecordsToExcel(unsynced);
    if (result.ok) {
      if (result.count) markSynced(unsynced.map(r => r.id));
      if (showAlert) alert(result.count ? `${result.count}件をExcelに書き込みました。` : '未反映のデータはありませんでした。');
    } else if (showAlert) {
      const messages = {
        'no-handle': 'Excelファイルが選択されていません。「Excelファイルを選択」から設定してください。',
        'no-permission': 'ファイルへのアクセス許可が得られませんでした。',
        'no-sheet': `選択したファイルに「${EXCEL_SHEET_NAME}」シートが見つかりません。`,
      };
      alert(messages[result.reason] || 'Excelへの書き込みに失敗しました。');
    }
    return result;
  }

  async function renderExcelSyncBox() {
    const box = $('excelSyncBox');
    box.hidden = !isAdmin();
    if (!isAdmin()) return;
    if (!EXCEL_SUPPORTED) {
      $('excelSyncState').textContent = '⚠️ このブラウザは自動保存に非対応（Chrome/Edgeでご利用ください）';
      $('excelPickBtn').disabled = true;
      $('excelSyncNowBtn').disabled = true;
      return;
    }
    const handle = await getExcelHandle();
    $('excelSyncState').textContent = handle ? `📄 ${handle.name} に接続済み` : 'Excel自動保存：未設定';
  }
  $('excelPickBtn').onclick = () => pickExcelFile();
  $('excelSyncNowBtn').onclick = () => syncUnsyncedToExcel(true);

  // ── 管理者ロック（Supabase Authのadminアカウントへのサインインで解除） ──
  async function requireAdmin() {
    if (isAdmin()) return true;
    const email = prompt('管理者アカウントのメールアドレスを入力してください。', 'admin@fujitaxi.local');
    if (!email) return false;
    const password = prompt('管理者パスワードを入力してください。');
    if (!password) return false;
    const result = await signInAdmin(email.trim(), password);
    if (!result.ok) { alert(result.error || 'ログインに失敗しました。'); return false; }
    return true;
  }
  function renderAdminBar() {
    const unlocked = isAdmin();
    $('adminState').textContent = unlocked ? '🔓 売上・給与データを表示中' : '🔒 売上・給与データは非表示中';
    $('adminToggleBtn').textContent = unlocked ? 'ロックする' : '管理者ロック解除';
    $('settingsToggleBtn').hidden = !unlocked;
    if (!unlocked) $('settingsPanel').hidden = true;
    $('histPanel').hidden = !unlocked;
    $('wagePanel').hidden = !unlocked;
    $('clearLogBtn').hidden = !unlocked;
    renderExcelSyncBox();
  }
  $('adminToggleBtn').onclick = async () => {
    if (isAdmin()) {
      await signOutToKiosk();
    } else {
      await requireAdmin();
    }
    renderAdminBar(); renderStaff(); renderPunch(); renderToday(); renderHist(); renderWage();
  };
  $('settingsToggleBtn').onclick = () => {
    $('settingsPanel').hidden = !$('settingsPanel').hidden;
    if (!$('settingsPanel').hidden) fillSettingsForm();
  };
  function fillSettingsForm() {
    $('setNormalWage').value = settings.normalWage;
    $('setLateWage').value = settings.lateWage;
    $('setLateBonus').value = settings.lateBonus;
    $('setPhoneAllowance').value = settings.phoneAllowance;
    $('setCommissionRate').value = settings.commissionRate;
    $('setMinWage').value = settings.minWage;

    const wrap = $('feeRateFields');
    wrap.innerHTML = '';
    for (const m of PAY_METHODS) {
      const label = document.createElement('label');
      label.className = 'kt-field';
      const span = document.createElement('span');
      span.textContent = m.label;
      const input = document.createElement('input');
      input.type = 'number';
      input.className = 'kt-input';
      input.min = '0'; input.max = '100'; input.step = '0.01';
      input.dataset.feeId = m.id;
      input.value = settings.feeRates[m.id];
      label.appendChild(span);
      label.appendChild(input);
      wrap.appendChild(label);
    }
  }
  $('saveSettingsBtn').onclick = async () => {
    const newSettings = {
      normalWage: parseInt($('setNormalWage').value, 10) || 0,
      lateWage: parseInt($('setLateWage').value, 10) || 0,
      lateBonus: parseInt($('setLateBonus').value, 10) || 0,
      phoneAllowance: parseInt($('setPhoneAllowance').value, 10) || 0,
      commissionRate: parseFloat($('setCommissionRate').value) || 0,
      minWage: parseInt($('setMinWage').value, 10) || 0,
      feeRates: { ...settings.feeRates },
    };
    for (const input of $('feeRateFields').querySelectorAll('input[data-fee-id]')) {
      const v = parseFloat(input.value);
      newSettings.feeRates[input.dataset.feeId] = (!isNaN(v) && v >= 0) ? v : 0;
    }
    try {
      await dbUpdateSettings(newSettings);
      settings = await fetchSettings();
      alert('設定を保存しました。');
      renderPunch(); renderToday(); renderHist(); renderWage();
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    }
  };

  $('clearLogBtn').onclick = async () => {
    if (!confirm('本当にすべての打刻データ（出勤・退勤・売上・給与の記録）を削除しますか？\nこの操作は取り消せません。')) return;
    if (!confirm('最終確認：削除すると元に戻せません。CSV出力やExcelへの反映は済んでいますか？\n本当に削除してよろしいですか？')) return;
    try {
      await deleteAllAttendance();
      selectedId = null;
      await refreshData();
      renderStaff(); renderPunch(); renderToday(); renderHist(); renderWage();
      alert('すべての打刻データを削除しました。');
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    }
  };

  // ── スタッフ ──
  function makeStaffChip(s) {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'kt-staff' + (s.id === selectedId ? ' is-active' : '');
    const nameSpan = document.createElement('span');
    nameSpan.textContent = s.name;
    btn.appendChild(nameSpan);
    btn.onclick = () => {
      // もう一度タップで選択解除
      selectedId = (selectedId === s.id) ? null : s.id;
      renderStaff(); renderPunch();
    };
    if (isAdmin()) {
      const edit = document.createElement('span');
      edit.className = 'kt-staff__edit';
      edit.textContent = '✎';
      edit.setAttribute('role', 'button');
      edit.setAttribute('aria-label', `${s.name}の区分を変更`);
      edit.onclick = async (e) => {
        e.stopPropagation();
        await editStaff(s);
      };
      btn.appendChild(edit);
      const del = document.createElement('span');
      del.className = 'kt-staff__del';
      del.textContent = '×';
      del.setAttribute('role', 'button');
      del.setAttribute('aria-label', `${s.name}を削除`);
      del.onclick = async (e) => {
        e.stopPropagation();
        if (!confirm(`${s.name} を削除しますか？（打刻履歴は残ります）`)) return;
        try {
          await deactivateStaff(s.id);
          staff = await fetchStaff();
          if (selectedId === s.id) selectedId = null;
          renderStaff(); renderPunch();
        } catch (err) {
          alert(SAVE_FAIL_MSG);
        }
      };
      btn.appendChild(del);
    }
    return btn;
  }
  function renderStaff() {
    const list = $('staffList');
    list.innerHTML = '';
    $('staffEmpty').hidden = staff.length > 0;
    // 正社員グループには時給制の正社員も含める（区分表示は雇用形態、計算方式は別）
    const fulltime = staff.filter(s => staffType(s) !== 'part');
    const part = staff.filter(s => staffType(s) === 'part');
    const groups = [['正社員', fulltime], ['パート', part]];
    for (const [label, members] of groups) {
      if (!members.length) continue;
      if (part.length) { // 両区分あるときだけ見出しを表示
        const head = document.createElement('p');
        head.className = 'kt-staff-group';
        head.textContent = label;
        list.appendChild(head);
      }
      const wrap = document.createElement('div');
      wrap.className = 'kt-staff-grid';
      for (const s of members) wrap.appendChild(makeStaffChip(s));
      list.appendChild(wrap);
    }
  }

  // 区分・時給・月給・交通費の入力（管理者のみ）
  function promptEmpType(s) {
    const cur = staffType(s);
    const defAnsMap = { part: '2', 'fulltime-hourly': '3', monthly: '4', 'fulltime-base': '5' };
    const defAns = defAnsMap[cur] || '1';
    const input = prompt(`${s.name} の区分を選んでください（現在：${EMP_LABEL[cur]}）\n1 = 正社員（シフト日給＋歩合）\n2 = パート（時給制）\n3 = 正社員（時給制）\n4 = 正社員（月給制）\n5 = 正社員（基本給のみ・歩合なし）`, defAns);
    if (input === null) return null;
    if (input.trim() === '1') return 'fulltime';
    if (input.trim() === '2') return 'part';
    if (input.trim() === '3') return 'fulltime-hourly';
    if (input.trim() === '4') return 'monthly';
    if (input.trim() === '5') return 'fulltime-base';
    alert('1〜5 の番号を入力してください。');
    return null;
  }
  function promptCommute(s) {
    const cm = prompt(`${s.name} の交通費（1日あたり・円）を入力してください（なければ 0）`, s.commuteAllowance != null ? String(s.commuteAllowance) : '0');
    if (cm === null) return false;
    const cmNum = parseInt(cm, 10);
    if (isNaN(cmNum) || cmNum < 0) { alert('交通費は 0 以上の数字で入力してください。'); return false; }
    s.commuteAllowance = cmNum;
    return true;
  }
  function promptPartWages(s) {
    const hw = prompt(`${s.name} の時間給（円）を入力してください`, s.hourlyWage != null ? String(s.hourlyWage) : String(settings.minWage));
    if (hw === null) return false;
    const hwNum = parseInt(hw, 10);
    if (isNaN(hwNum) || hwNum <= 0) { alert('時間給は正の数字で入力してください。'); return false; }
    s.hourlyWage = hwNum;
    return promptCommute(s);
  }
  function promptMonthlyWage(s) {
    const mw = prompt(`${s.name} の月給（円）を入力してください`, s.monthlyWage != null ? String(s.monthlyWage) : '300000');
    if (mw === null) return false;
    const mwNum = parseInt(mw, 10);
    if (isNaN(mwNum) || mwNum <= 0) { alert('月給は正の数字で入力してください。'); return false; }
    s.monthlyWage = mwNum;
    return promptCommute(s);
  }
  function promptDailyWage(s) {
    const dw = prompt(`${s.name} の基本日給（円・普通番／遅番に関わらず固定）を入力してください`, s.dailyWage != null ? String(s.dailyWage) : String(settings.normalWage));
    if (dw === null) return false;
    const dwNum = parseInt(dw, 10);
    if (isNaN(dwNum) || dwNum <= 0) { alert('基本日給は正の数字で入力してください。'); return false; }
    s.dailyWage = dwNum;
    return promptCommute(s);
  }
  function promptWagesFor(type, s) {
    if (isHourlyType(type)) return promptPartWages(s);
    if (isMonthlyType(type)) return promptMonthlyWage(s);
    if (type === 'fulltime-base') return promptDailyWage(s);
    return promptCommute(s);
  }
  function wageNoteFor(type, s) {
    if (isHourlyType(type)) return `（時間給 ${yen(s.hourlyWage)}円／交通費 ${yen(s.commuteAllowance)}円）`;
    if (isMonthlyType(type)) return `（月給 ${yen(s.monthlyWage)}円／交通費 ${yen(s.commuteAllowance)}円）`;
    if (type === 'fulltime-base') return `（基本日給 ${yen(s.dailyWage)}円／交通費 ${yen(s.commuteAllowance)}円）`;
    return `（交通費 ${yen(s.commuteAllowance)}円）`;
  }
  async function editStaff(s) {
    if (!(await requireAdmin())) return;
    renderAdminBar();
    const type = promptEmpType(s);
    if (type === null) return;
    if (!promptWagesFor(type, s)) return;
    try {
      await updateStaff(s.id, {
        type,
        hourlyWage: s.hourlyWage ?? null,
        monthlyWage: s.monthlyWage ?? null,
        dailyWage: s.dailyWage ?? null,
        commuteAllowance: s.commuteAllowance ?? 0,
      });
      staff = await fetchStaff();
      renderStaff(); renderPunch();
      alert(`${s.name} を ${EMP_LABEL[type]} に設定しました。${wageNoteFor(type, s)}`);
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    }
  }

  $('addStaffBtn').onclick = async () => {
    const name = prompt('スタッフの名前を入力してください');
    if (!name || !name.trim()) return;
    const s = { name: name.trim() };
    const type = promptEmpType(s);
    if (type === null) return;
    if (isHourlyType(type) || isMonthlyType(type) || type === 'fulltime-base') {
      if (!(await requireAdmin())) { alert('時給・月給・基本日給の設定には管理者パスワードが必要です。'); return; }
      renderAdminBar();
      if (!promptWagesFor(type, s)) return;
    }
    s.type = type;
    try {
      await insertStaff({
        name: s.name,
        type: s.type,
        hourlyWage: s.hourlyWage ?? null,
        monthlyWage: s.monthlyWage ?? null,
        dailyWage: s.dailyWage ?? null,
        commuteAllowance: s.commuteAllowance ?? 0,
      });
      staff = await fetchStaff();
      renderStaff();
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    }
  };

  // ── 状態判定 ──
  function todayRec(staffId) {
    return todayLog.find(r => r.staffId === staffId);
  }
  function statusOf(rec) {
    if (!rec || !rec.in) return 'before';        // 未出勤
    if (rec.out) return 'done';                  // 退勤済み
    const lastBreak = rec.breaks[rec.breaks.length - 1];
    if (lastBreak && !lastBreak.end) return 'break'; // 休憩中
    const leaves = rec.leaves || [];
    const lastLeave = leaves[leaves.length - 1];
    if (lastLeave && !lastLeave.end) return 'away'; // 時間内退勤中
    return 'working';                            // 勤務中
  }
  const STATUS_LABEL = { before: '未出勤', working: '勤務中', break: '休憩中', away: '時間内退勤中', done: '退勤済み' };
  const SHIFT_LABEL = { normal: '普通番', late: '遅番', part: 'パート' };

  // ── 雇用区分（正社員＝日給＋歩合／パート・正社員(時給)＝時給制／正社員(月給)＝固定給／正社員(基本給のみ)＝日給のみ・歩合なし） ──
  const EMP_LABEL = { fulltime: '正社員', part: 'パート', 'fulltime-hourly': '正社員（時給）', monthly: '正社員（月給）', 'fulltime-base': '正社員（基本給のみ）' };
  // 時給制（時間給×実働＋割増＋交通費）で計算する区分か。パートと「正社員だが時給制」の両方が該当
  function isHourlyType(t) { return t === 'part' || t === 'fulltime-hourly'; }
  function isMonthlyType(t) { return t === 'monthly'; }
  // シフト選択なしの単一出勤ボタンを使う区分（時給制・月給制）
  function usesSimplePunch(t) { return isHourlyType(t) || isMonthlyType(t); }
  // 歩合給（売上連動）を計算する区分か。通常の正社員のみ対象
  function hasCommission(t) { return t === 'fulltime'; }
  const OT_RATE = 0.25;    // 残業割増率（8時間超）
  const NIGHT_RATE = 0.25; // 深夜割増率（22時以降）
  const NIGHT_START_HOUR = 22;

  function staffType(s) {
    const t = s && s.type;
    return (t === 'part' || t === 'fulltime-hourly' || t === 'monthly' || t === 'fulltime-base') ? t : 'fulltime';
  }
  function recEmpType(rec) {
    if (rec.empType) return rec.empType;
    return staffType(staff.find(x => x.id === rec.staffId));
  }
  function recHourlyWage(rec) {
    if (rec.hourlyWage != null) return rec.hourlyWage;
    const s = staff.find(x => x.id === rec.staffId);
    return (s && s.hourlyWage != null) ? s.hourlyWage : settings.minWage;
  }
  function recMonthlyWage(rec) {
    if (rec.monthlyWage != null) return rec.monthlyWage;
    const s = staff.find(x => x.id === rec.staffId);
    return (s && s.monthlyWage != null) ? s.monthlyWage : 0;
  }
  function recCommute(rec) {
    if (rec.commute != null) return rec.commute;
    const s = staff.find(x => x.id === rec.staffId);
    return (s && s.commuteAllowance != null) ? s.commuteAllowance : 0;
  }
  // 22時以降の勤務分（分）。退勤時刻ベースの近似（22時以降の休憩は考慮しない）
  function nightMinutes(rec) {
    if (!rec.out) return 0;
    const out = new Date(rec.out);
    const t22 = new Date(out);
    t22.setHours(NIGHT_START_HOUR, 0, 0, 0);
    return Math.max(0, Math.round((out - t22) / 60000));
  }

  function renderPunch() {
    const panel = $('punchPanel');
    if (!selectedId) { panel.hidden = true; return; }
    const s = staff.find(x => x.id === selectedId);
    if (!s) { panel.hidden = true; return; }
    panel.hidden = false;
    // 選択中ラベルは表示を簡略化（正社員（時給）／正社員（月給）は単に「正社員」と表示。区分自体・計算方法は変更なし）
    const SIMPLIFIED_PUNCH_TYPES = ['fulltime-hourly', 'monthly', 'fulltime-base'];
    const punchLabel = SIMPLIFIED_PUNCH_TYPES.includes(staffType(s)) ? '正社員' : EMP_LABEL[staffType(s)];
    $('selectedName').textContent = `${s.name}（${punchLabel}）`;
    const rec = todayRec(selectedId);
    const st = statusOf(rec);
    const shiftNote = rec && rec.shiftType
      ? '（' + (rec.shiftType === 'part' ? EMP_LABEL[recEmpType(rec)] : SHIFT_LABEL[rec.shiftType]) + '）'
      : '';
    $('statusLabel').textContent = `現在：${STATUS_LABEL[st]}${shiftNote}`;

    const isSimple = usesSimplePunch(staffType(s));
    $('phoneDutyBlock').hidden = isSimple || !!s.phoneDutyDisabled;
    $('fulltimeShiftGrid').hidden = isSimple;
    $('fulltimeShiftGrid').classList.toggle('kt-shift-grid--single', !!s.lateShiftDisabled);
    $('punchInLate').hidden = !!s.lateShiftDisabled;
    $('partShiftGrid').hidden = !isSimple;

    const canPunchIn = st === 'before';
    $('shiftSelect').hidden = !canPunchIn;
    $('punchGrid').hidden = canPunchIn;

    $('punchOut').disabled = st !== 'working';
    $('punchBreakStart').disabled = st !== 'working';
    $('punchBreakEnd').disabled = st !== 'break';
    $('punchAwayStart').disabled = st !== 'working';
    $('punchAwayEnd').disabled = st !== 'away';
  }

  async function punchIn(shiftType) {
    if (!selectedId) return;
    const s = staff.find(x => x.id === selectedId);
    if (!s) return;
    const now = new Date().toISOString();
    const existing = todayRec(selectedId);
    const empType = staffType(s);
    const patch = {
      staffId: selectedId,
      date: dateKey(),
      in: now,
      shiftType,
      phoneDuty: (shiftType === 'part' || s.phoneDutyDisabled) ? false : $('phoneDutyCheck').checked,
      // 給与計算条件を出勤時点でレコードに固定（後から区分や時給・交通費を変えても過去分に影響しない）
      empType,
      commute: s.commuteAllowance != null ? s.commuteAllowance : 0,
    };
    if (!existing) { patch.breaks = []; patch.leaves = []; }
    if (isHourlyType(empType)) patch.hourlyWage = s.hourlyWage != null ? s.hourlyWage : settings.minWage;
    if (isMonthlyType(empType)) patch.monthlyWage = s.monthlyWage != null ? s.monthlyWage : 0;
    if (s.dailyWage != null) patch.dailyWage = s.dailyWage;

    const shiftBtnIds = ['punchInNormal', 'punchInLate', 'punchInPart'];
    shiftBtnIds.forEach(id => { $(id).disabled = true; });
    try {
      await upsertAttendance(patch);
      await refreshData();
      $('punchMsg').textContent = shiftType === 'part'
        ? `✅ ${s.name} さんが出勤しました（${timeStr(now)}）`
        : `✅ ${s.name} さんが${SHIFT_LABEL[shiftType]}で出勤しました（${timeStr(now)}）`;
      $('phoneDutyCheck').checked = false;
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    } finally {
      shiftBtnIds.forEach(id => { $(id).disabled = false; });
    }
    renderPunch(); renderToday(); renderHist(); renderWage();
  }

  // ── 退勤・売上入力モーダル ──
  const CONSUMPTION_TAX_RATE = 0.10; // 消費税率（標準10%）
  function taxExcluded(gross) {
    return Math.round(gross / (1 + CONSUMPTION_TAX_RATE));
  }
  function updateSalesNetPreview() {
    const gross = parseFloat($('salesTotalInput').value);
    const net = (!isNaN(gross) && gross >= 0) ? taxExcluded(gross) : 0;
    $('salesNetPreview').textContent = `税抜：${yen(net)}円（歩合給の計算に使用）`;
  }
  function feeAmounts() {
    const amounts = {};
    for (const input of $('salesMethodFields').querySelectorAll('input[data-pay-id]')) {
      const v = parseFloat(input.value);
      amounts[input.dataset.payId] = (!isNaN(v) && v >= 0) ? v : 0;
    }
    return amounts;
  }
  function autoFee(amounts) {
    let total = 0;
    for (const m of PAY_METHODS) {
      const rate = settings.feeRates?.[m.id] ?? m.rate;
      total += (amounts[m.id] || 0) * (rate / 100);
    }
    return Math.round(total);
  }
  function updateFeePreview() {
    $('salesFeeAuto').textContent = `${yen(autoFee(feeAmounts()))}円`;
  }
  let salesModalTargetKey = null; // "staffId|date" 形式で編集対象を保持

  function openSalesModal(staffId, date) {
    const rec = log.find(r => r.staffId === staffId && r.date === date);
    if (!rec) return;
    salesModalTargetKey = `${staffId}|${date}`;
    const s = staff.find(x => x.id === staffId);
    $('salesModalStaff').textContent = `${s ? s.name : '（削除済み）'} さん・${date.slice(5).replace('-', '/')}`;
    $('salesTotalInput').value = rec.salesGross != null ? rec.salesGross : (rec.sales != null ? rec.sales : '');
    $('salesUncollectedInput').value = rec.uncollected != null ? rec.uncollected : '';
    $('salesFeeOverride').value = rec.cardFee != null ? rec.cardFee : '';
    updateSalesNetPreview();
    const wrap = $('salesMethodFields');
    wrap.innerHTML = '';
    const payments = rec.payments || {};
    for (const m of PAY_METHODS) {
      const label = document.createElement('label');
      label.className = 'kt-field';
      const span = document.createElement('span');
      span.textContent = `${m.label}（${settings.feeRates?.[m.id] ?? m.rate}%）`;
      const input = document.createElement('input');
      input.type = 'number';
      input.className = 'kt-input';
      input.min = '0';
      input.inputMode = 'numeric';
      input.placeholder = '0';
      input.dataset.payId = m.id;
      input.value = payments[m.id] || '';
      input.addEventListener('input', updateFeePreview);
      label.appendChild(span);
      label.appendChild(input);
      wrap.appendChild(label);
    }
    updateFeePreview();
    $('salesModal').hidden = false;
    $('salesTotalInput').focus();
  }
  function closeSalesModal() {
    $('salesModal').hidden = true;
    salesModalTargetKey = null;
  }
  $('salesModal').addEventListener('click', (e) => {
    if (e.target.id === 'salesModal') closeSalesModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !$('salesModal').hidden) closeSalesModal();
  });
  async function saveSalesModal() {
    if (!salesModalTargetKey) { closeSalesModal(); return; }
    const [staffId, date] = salesModalTargetKey.split('|');
    const rec = log.find(r => r.staffId === staffId && r.date === date);
    if (!rec) { closeSalesModal(); return; }

    const gross = parseFloat($('salesTotalInput').value);
    if (isNaN(gross) || gross < 0) {
      alert('売上合計（税込）を入力してください。');
      return;
    }
    const amounts = feeAmounts();
    const breakdownTotal = PAY_METHODS.reduce((sum, m) => sum + (amounts[m.id] || 0), 0);
    if (breakdownTotal > gross) {
      if (!confirm(`決済内訳の合計（${yen(breakdownTotal)}円）が売上合計（${yen(gross)}円）を超えています。このまま保存しますか？`)) return;
    }
    const uncollectedRaw = parseFloat($('salesUncollectedInput').value);
    const override = parseFloat($('salesFeeOverride').value);
    const patch = {
      staffId, date,
      salesGross: gross,
      sales: taxExcluded(gross),
      uncollected: (!isNaN(uncollectedRaw) && uncollectedRaw >= 0) ? uncollectedRaw : 0,
      payments: amounts,
      cardFee: (!isNaN(override) && override >= 0) ? override : autoFee(amounts),
    };
    $('salesModalSubmit').disabled = true;
    try {
      await upsertAttendance(patch);
      await refreshData();
      closeSalesModal();
      renderHist(); renderWage();
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    } finally {
      $('salesModalSubmit').disabled = false;
    }
  }
  $('salesModalSubmit').onclick = () => saveSalesModal();
  $('salesModalCancel').onclick = () => closeSalesModal();
  $('salesTotalInput').addEventListener('input', updateSalesNetPreview);

  async function punch(type) {
    if (!selectedId) return;
    const rec = todayRec(selectedId);
    if (!rec) return;
    const s = staff.find(x => x.id === selectedId);
    if (!s) return;
    const now = new Date().toISOString();
    const breaks = [...(rec.breaks || [])];
    const leaves = [...(rec.leaves || [])];
    const patch = { staffId: selectedId, date: dateKey() };

    if (type === 'out') {
      patch.out = now;
    } else if (type === 'breakStart') {
      breaks.push({ start: now, end: null });
      patch.breaks = breaks;
    } else if (type === 'breakEnd') {
      const b = breaks[breaks.length - 1];
      if (b && !b.end) b.end = now;
      patch.breaks = breaks;
    } else if (type === 'awayStart') {
      leaves.push({ start: now, end: null });
      patch.leaves = leaves;
    } else if (type === 'awayEnd') {
      const l = leaves[leaves.length - 1];
      if (l && !l.end) l.end = now;
      patch.leaves = leaves;
    }

    const btnIds = ['punchOut', 'punchBreakStart', 'punchBreakEnd', 'punchAwayStart', 'punchAwayEnd'];
    btnIds.forEach(id => { $(id).disabled = true; });
    try {
      await upsertAttendance(patch);
      await refreshData();
      if (type === 'out') {
        $('punchMsg').textContent = `✅ ${s.name} さんの退勤を ${timeStr(now)} に記録しました。売上は後ほど管理者が入力します。`;
        if (isAdmin()) {
          const handle = await getExcelHandle();
          if (handle) {
            const result = await syncUnsyncedToExcel(false);
            if (result.ok && result.count) $('punchMsg').textContent += `（Excelにも自動記録しました）`;
          }
        }
      } else {
        const labels = { breakStart: '休憩開始', breakEnd: '休憩終了', awayStart: '時間内退勤', awayEnd: '時間内出勤' };
        $('punchMsg').textContent = `✅ ${s.name} さんの${labels[type]}を ${timeStr(now)} に記録しました`;
      }
    } catch (e) {
      alert(SAVE_FAIL_MSG);
    }
    renderPunch(); renderToday(); renderHist(); renderWage();
  }
  $('punchInNormal').onclick = () => punchIn('normal');
  $('punchInLate').onclick = () => punchIn('late');
  $('punchInPart').onclick = () => punchIn('part');
  $('punchOut').onclick = () => punch('out');
  $('punchBreakStart').onclick = () => punch('breakStart');
  $('punchBreakEnd').onclick = () => punch('breakEnd');
  $('punchAwayStart').onclick = () => punch('awayStart');
  $('punchAwayEnd').onclick = () => punch('awayEnd');

  // ── 実働計算 ──
  function workMinutes(rec) {
    if (!rec.in) return null;
    const end = rec.out ? new Date(rec.out) : new Date();
    let ms = end - new Date(rec.in);
    for (const b of rec.breaks) {
      const bEnd = b.end ? new Date(b.end) : new Date();
      ms -= (bEnd - new Date(b.start));
    }
    for (const l of (rec.leaves || [])) {
      const lEnd = l.end ? new Date(l.end) : new Date();
      ms -= (lEnd - new Date(l.start));
    }
    return Math.max(0, Math.round(ms / 60000));
  }
  function breakMinutes(rec) {
    let ms = 0;
    for (const b of rec.breaks) {
      const bEnd = b.end ? new Date(b.end) : new Date();
      ms += (bEnd - new Date(b.start));
    }
    return Math.round(ms / 60000);
  }
  function awayMinutes(rec) {
    let ms = 0;
    for (const l of (rec.leaves || [])) {
      const lEnd = l.end ? new Date(l.end) : new Date();
      ms += (lEnd - new Date(l.start));
    }
    return Math.round(ms / 60000);
  }
  function hm(min) {
    if (min === null) return '—';
    return `${Math.floor(min / 60)}:${String(min % 60).padStart(2, '0')}`;
  }

  // ── 給与計算 ──
  // 個人固定の基本日給（シフトに関わらず一定）。未設定なら会社共通の設定値を使用
  function recDailyWage(rec) {
    if (rec.dailyWage != null) return rec.dailyWage;
    const s = staff.find(x => x.id === rec.staffId);
    return (s && s.dailyWage != null) ? s.dailyWage : null;
  }
  function shiftWage(rec) {
    if (!rec.shiftType || rec.shiftType === 'part') return 0;
    const override = recDailyWage(rec);
    let w = override != null ? override : (rec.shiftType === 'late' ? (settings.lateWage + settings.lateBonus) : settings.normalWage);
    if (rec.phoneDuty) w += settings.phoneAllowance;
    return w;
  }
  function commissionPay(rec) {
    if (rec.sales == null) return 0;
    const net = Math.max(0, (rec.sales || 0) - (rec.cardFee || 0));
    return net * (settings.commissionRate / 100);
  }
  // 区分ごとの内訳。base＝基本給（正社員：シフト日給＋電話番手当／パート：時給×実働）
  // extra＝歩合・手当（正社員：歩合給／パート：残業・深夜割増＋交通費）
  function payParts(rec) {
    const commute = rec.in ? recCommute(rec) : 0;
    if (isHourlyType(recEmpType(rec))) {
      const min = workMinutes(rec) || 0;
      const hw = recHourlyWage(rec);
      const base = Math.round(hw * min / 60);
      const ot = Math.round(Math.max(0, min / 60 - 8) * hw * OT_RATE);
      const night = Math.round(nightMinutes(rec) / 60 * hw * NIGHT_RATE);
      return { base, extra: ot + night + commute, ot, night, commute };
    }
    const commission = hasCommission(recEmpType(rec)) ? commissionPay(rec) : 0;
    return { base: shiftWage(rec), extra: commission + commute, ot: 0, night: 0, commute };
  }
  function totalPay(rec) {
    const p = payParts(rec);
    return p.base + p.extra;
  }
  function hourlyRate(rec) {
    if (!rec.out) return null;
    if (isMonthlyType(recEmpType(rec))) return null; // 月給制は時給換算・最低賃金判定の対象外
    const min = workMinutes(rec);
    if (!min || min <= 0) return null;
    return totalPay(rec) / (min / 60);
  }
  function isBelowMinWage(rec) {
    const rate = hourlyRate(rec);
    return rate !== null && rate < settings.minWage;
  }
  function mask(text) {
    return isAdmin() ? text : '••••';
  }

  // ── 本日の状況 ──
  function renderToday() {
    const board = $('todayBoard');
    board.innerHTML = '';
    const recs = log.filter(r => r.date === dateKey());
    $('todayEmpty').hidden = recs.length > 0;
    for (const rec of recs) {
      const s = staff.find(x => x.id === rec.staffId);
      const st = statusOf(rec);
      const div = document.createElement('div');
      div.className = `kt-today-card kt-today-card--${st}`;
      div.innerHTML = `
        <p class="kt-today-card__name">${s ? s.name : '（削除済み）'}</p>
        <p class="kt-today-card__status">${STATUS_LABEL[st]}${rec.shiftType ? '・' + (rec.shiftType === 'part' ? EMP_LABEL[recEmpType(rec)] : SHIFT_LABEL[rec.shiftType]) : ''}</p>
        <p class="kt-today-card__times">出勤 ${rec.in ? timeStr(rec.in) : '—'} ／ 退勤 ${rec.out ? timeStr(rec.out) : '—'}</p>
      `;
      board.appendChild(div);
    }
  }

  // ── 履歴 ──
  function renderHist() {
    const month = currentMonth();
    const body = $('histBody');
    body.innerHTML = '';
    const recs = log.filter(r => r.date.startsWith(month)).sort((a, b) => b.date.localeCompare(a.date));
    $('histEmpty').hidden = recs.length > 0;
    $('histTable').style.display = recs.length ? '' : 'none';
    for (const rec of recs) {
      const s = staff.find(x => x.id === rec.staffId);
      const w = rec.out ? workMinutes(rec) : null;
      const belowMin = isAdmin() && isBelowMinWage(rec);
      const rate = hourlyRate(rec);
      const isSimple = usesSimplePunch(recEmpType(rec));
      const showsSales = hasCommission(recEmpType(rec));
      const p = payParts(rec);
      const kubun = isSimple
        ? EMP_LABEL[recEmpType(rec)]
        : (rec.shiftType ? SHIFT_LABEL[rec.shiftType] + (rec.phoneDuty ? '＋電話番' : '') : '—');
      const tr = document.createElement('tr');
      if (belowMin) tr.className = 'kt-table__row--warn';
      tr.innerHTML = `
        <td>${rec.date.slice(5).replace('-', '/')}</td>
        <td>${s ? s.name : '（削除済み）'}</td>
        <td>${kubun}</td>
        <td>${rec.in ? timeStr(rec.in) : '—'}</td>
        <td>${rec.out ? timeStr(rec.out) : '—'}</td>
        <td>${hm(breakMinutes(rec))}</td>
        <td>${hm(awayMinutes(rec))}</td>
        <td class="kt-table__work">${rec.out ? hm(w) : '勤務中'}</td>
        <td>${showsSales ? mask(rec.salesGross != null ? yen(rec.salesGross) + '円' : (rec.sales != null ? yen(rec.sales) + '円' : '—')) : '—'}</td>
        <td>${showsSales ? mask(rec.uncollected ? yen(rec.uncollected) + '円' : '—') : '—'}</td>
        <td>${showsSales ? mask(rec.cardFee != null ? yen(rec.cardFee) + '円' : '—') : '—'}</td>
        <td>${mask(rec.out || rec.shiftType ? yen(p.base) + '円' : '—')}</td>
        <td>${mask(rec.out ? yen(p.extra) + '円' : '—')}</td>
        <td class="kt-table__total">${rec.out ? mask(yen(totalPay(rec)) + '円') : '—'}</td>
        <td>${mask(rate !== null ? yen(rate) + '円' + (belowMin ? ' ⚠️最低賃金未満' : '') : '—')}</td>
        <td></td>
      `;
      if (rec.out && showsSales) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'kt-btn kt-btn--ghost';
        btn.textContent = rec.sales != null ? '売上を修正' : '売上を入力';
        btn.onclick = () => openSalesModal(rec.staffId, rec.date);
        tr.lastElementChild.appendChild(btn);
      }
      body.appendChild(tr);
    }
  }

  // ── 月次給与サマリー ──
  function renderWage() {
    const month = currentMonth();
    const body = $('wageBody');
    body.innerHTML = '';
    const recs = log.filter(r => r.date.startsWith(month) && r.out);
    const totals = {};
    for (const rec of recs) {
      if (!totals[rec.staffId]) totals[rec.staffId] = { days: 0, minutes: 0, wage: 0, sales: 0, commission: 0, empType: recEmpType(rec), monthlyWage: 0 };
      const t = totals[rec.staffId];
      const p = payParts(rec);
      t.days += 1;
      t.minutes += workMinutes(rec);
      t.wage += p.base;
      t.sales += (rec.sales || 0);
      t.commission += p.extra;
      if (isMonthlyType(t.empType)) t.monthlyWage = recMonthlyWage(rec);
    }
    const ids = Object.keys(totals);
    $('wageEmpty').hidden = ids.length > 0;
    $('wageTable').style.display = ids.length ? '' : 'none';
    for (const id of ids) {
      const s = staff.find(x => x.id === id);
      const t = totals[id];
      const baseDisplay = isMonthlyType(t.empType) ? t.monthlyWage : t.wage;
      const total = baseDisplay + t.commission;
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${s ? s.name : '（削除済み）'}</td>
        <td>${EMP_LABEL[t.empType]}</td>
        <td>${t.days}日</td>
        <td>${hm(t.minutes)}</td>
        <td>${mask(yen(baseDisplay) + '円')}</td>
        <td>${hasCommission(t.empType) ? mask(yen(t.sales) + '円') : '—'}</td>
        <td>${mask(yen(t.commission) + '円')}</td>
        <td class="kt-table__total">${mask(yen(total) + '円')}</td>
      `;
      body.appendChild(tr);
    }
  }

  $('monthPick').onchange = async () => {
    try {
      log = await fetchMonth(currentMonth());
    } catch (e) {
      alert('データの取得に失敗しました。通信状況を確認してください。');
