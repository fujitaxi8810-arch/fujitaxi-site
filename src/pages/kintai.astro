  // ── CSV出力 ──
  $('csvBtn').onclick = async () => {
    if (!(await requireAdmin())) return;
    renderAdminBar();
    const month = currentMonth();
    const recs = log.filter(r => r.date.startsWith(month)).sort((a, b) => a.date.localeCompare(b.date));
    if (!recs.length) { alert('この月の記録がありません'); return; }
    const methodHeaders = PAY_METHODS.map(m => `${m.label}(円)`).join(',');
    let csv = `﻿日付,名前,区分,電話番,出勤,退勤,休憩(分),時間内外出(分),実働(分),実働(時:分),売上税込(円),売上税抜(円),未収(円),カード手数料等(円),基本給(円),歩合・手当(円),合計支給額(円),時給換算(円),最低賃金判定,${methodHeaders}\n`;
    for (const rec of recs) {
      const payments = rec.payments || {};
      csv += [...excelRowFromRec(rec), ...PAY_METHODS.map(m => payments[m.id] || '')].join(',') + '\n';
    }

    const rateNote = PAY_METHODS.map(m => `${m.label}${settings.feeRates[m.id]}%`).join('／');
    csv += `\n設定：普通番日給${settings.normalWage}円／遅番日給${settings.lateWage + settings.lateBonus}円／電話番手当${settings.phoneAllowance}円／歩合率${settings.commissionRate}%／最低賃金${settings.minWage}円\n`;
    csv += `時給制（パート・正社員(時給)）：時間給×実働＋残業割増(8時間超×${OT_RATE * 100}%)＋深夜割増(${NIGHT_START_HOUR}時以降×${NIGHT_RATE * 100}%)＋交通費(日額)\n`;
    csv += `月給制（正社員(月給)）：総支給額＝月給（固定）＋交通費(日額)\n`;
    csv += `正社員（基本給のみ）：総支給額＝シフト日給＋電話番手当＋交通費(日額)（歩合給なし）\n`;
    csv += `手数料率：${rateNote}\n`;
    csv += '\n月次サマリー\n名前,区分,出勤日数,実働合計(分),実働合計(時:分),基本給合計(円),売上合計(円),歩合・手当合計(円),総支給額(円)\n';
    const totals = {};
    for (const rec of recs) {
      if (!rec.out) continue;
      if (!totals[rec.staffId]) totals[rec.staffId] = { days: 0, minutes: 0, wage: 0, sales: 0, commission: 0, empType: recEmpType(rec), monthlyWage: 0 };
      const t = totals[rec.staffId];
      const p = payParts(rec);
      t.days += 1;
      t.minutes += workMinutes(rec);
      t.wage += p.base;
      t.sales += (rec.sales || 0);
      t.commission += p.extra;
      if (isMonthlyType(t.empType)) t.monthlyWage = recMonthlyWage(rec);
    }
    for (const id of Object.keys(totals)) {
      const s = staff.find(x => x.id === id);
      const t = totals[id];
      const baseDisplay = isMonthlyType(t.empType) ? t.monthlyWage : t.wage;
      csv += [
        s ? s.name : '削除済み',
        EMP_LABEL[t.empType],
        t.days,
        t.minutes,
        hm(t.minutes),
        Math.round(baseDisplay),
        Math.round(t.sales),
        Math.round(t.commission),
        Math.round(baseDisplay + t.commission),
      ].join(',') + '\n';
    }

    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `勤怠給与_${month}.csv`;
    a.click();
    URL.revokeObjectURL(a.href);
  };

  // ── 給与計算Excel出力（タイムカード形式：スタッフ別シート＋数式で自動計算） ──
  const TC_TABLE_START = 11; // 日別テーブルの先頭行（1始まり）

  function tcSetCell(ws, addr, value, opts) {
    const cell = Object.assign({}, opts);
    if (typeof value === 'number') { cell.t = 'n'; cell.v = value; }
    else if (value != null && value !== '') { cell.t = 's'; cell.v = String(value); }
    else if (!cell.f) return;
    ws[addr] = cell;
  }
  // 数式セル。vはダミーのキャッシュ値（v無しだとSheetJSが書き出し時にセルを捨てる）。
  // SheetJSはfullCalcOnLoadを立てて出力するため、Excelで開いた時点で全数式が再計算される。
  function tcFormula(ws, addr, f, z) {
    const cell = { t: 'n', v: 0, f };
    if (z) cell.z = z;
    ws[addr] = cell;
  }
  function tcFinalize(ws, lastRow, lastCol) {
    ws['!ref'] = `A1:${XLSX.utils.encode_col(lastCol)}${lastRow}`;
  }
  function tcSheetName(name, used) {
    let base = name.replace(/[:\\\/?*\[\]]/g, '・').slice(0, 25) || 'スタッフ';
    let candidate = base;
    let n = 2;
    while (used.has(candidate)) candidate = `${base}(${n++})`;
    used.add(candidate);
    return candidate;
  }
  function tcQuote(sheetName) {
    return `'${sheetName.replace(/'/g, "''")}'`;
  }
  function tcTimeSerial(iso) {
    const d = new Date(iso);
    return (d.getHours() * 3600 + d.getMinutes() * 60 + d.getSeconds()) / 86400;
  }

  function buildStaffSheet(name, recsByDay, year, monthNum, daysInMonth, dailyWageOverride) {
    const ws = {};
    const endRow = TC_TABLE_START + daysInMonth - 1;

    tcSetCell(ws, 'A1', `${year}年${monthNum}月 勤務表`);
    tcSetCell(ws, 'D1', name);
    tcSetCell(ws, 'A2', '交通費合計（円）');
    tcFormula(ws, 'B2', `SUM(N${TC_TABLE_START}:N${endRow})`, '#,##0');
    if (dailyWageOverride != null) {
      tcSetCell(ws, 'C3', '基本日給（固定・円）');
      ws['D3'] = { t: 'n', v: dailyWageOverride, z: '#,##0' };
    }
    tcSetCell(ws, 'A3', '勤務日数');
    tcFormula(ws, 'B3', `COUNT(O${TC_TABLE_START}:O${endRow})`);
    tcSetCell(ws, 'A4', '実働合計（時間）');
    tcFormula(ws, 'B4', `SUM(I${TC_TABLE_START}:I${endRow})`, '0.00');
    tcSetCell(ws, 'A5', 'シフト日給合計（電話番手当込・円）');
    tcFormula(ws, 'B5', `SUM(L${TC_TABLE_START}:L${endRow})`, '#,##0');
    tcSetCell(ws, 'A6', '歩合給合計（円）');
    tcFormula(ws, 'B6', `SUM(M${TC_TABLE_START}:M${endRow})`, '#,##0');
    tcSetCell(ws, 'A7', '売上合計（税抜・円）');
    tcFormula(ws, 'B7', `SUM(J${TC_TABLE_START}:J${endRow})`, '#,##0');
    tcSetCell(ws, 'A8', '総支給額（円）');
    tcFormula(ws, 'B8', `SUM(O${TC_TABLE_START}:O${endRow})`, '#,##0');

    const headers = ['日', '曜日', 'シフト', '電話番', '出勤', '退勤', '休憩(分)', '外出(分)', '実働(時間)', '売上税抜(円)', 'カード手数料(円)', 'シフト日給(円)', '歩合給(円)', '交通費(円)', '日合計(円)', '時給換算(円)', '最低賃金判定'];
    headers.forEach((h, i) => tcSetCell(ws, XLSX.utils.encode_cell({ r: TC_TABLE_START - 2, c: i }), h));

    const WEEKDAYS = ['日', '月', '火', '水', '木', '金', '土'];
    for (let day = 1; day <= daysInMonth; day++) {
      const row = TC_TABLE_START + day - 1;
      const date = new Date(year, monthNum - 1, day);
      tcSetCell(ws, `A${row}`, day);
      tcSetCell(ws, `B${row}`, WEEKDAYS[date.getDay()]);
      const rec = recsByDay[day];
      if (rec) {
        tcSetCell(ws, `C${row}`, rec.shiftType ? SHIFT_LABEL[rec.shiftType] : '');
        tcSetCell(ws, `D${row}`, rec.phoneDuty ? '有' : '');
        if (rec.in) ws[`E${row}`] = { t: 'n', v: tcTimeSerial(rec.in), z: 'h:mm' };
        if (rec.out) ws[`F${row}`] = { t: 'n', v: tcTimeSerial(rec.out), z: 'h:mm' };
        tcSetCell(ws, `G${row}`, breakMinutes(rec));
        tcSetCell(ws, `H${row}`, awayMinutes(rec));
        if (rec.sales != null) ws[`J${row}`] = { t: 'n', v: rec.sales, z: '#,##0' };
        if (rec.cardFee != null) ws[`K${row}`] = { t: 'n', v: rec.cardFee, z: '#,##0' };
        if (rec.in) ws[`N${row}`] = { t: 'n', v: recCommute(rec), z: '#,##0' };
      }
      tcFormula(ws, `I${row}`, `IF(OR($E${row}="",$F${row}=""),"",ROUND(($F${row}-$E${row}+IF($F${row}<$E${row},1,0))*24-IF($G${row}="",0,$G${row})/60-IF($H${row}="",0,$H${row})/60,2))`, '0.00');
      const dayWageFormula = dailyWageOverride != null
        ? `IF($C${row}="","",$D$3+IF($D${row}="有",設定!$B$5,0))`
        : `IF($C${row}="","",IF($C${row}="遅番",設定!$B$3+設定!$B$4,設定!$B$2)+IF($D${row}="有",設定!$B$5,0))`;
      tcFormula(ws, `L${row}`, dayWageFormula, '#,##0');
      tcFormula(ws, `M${row}`, `IF($J${row}="","",ROUND(MAX(0,$J${row}-IF($K${row}="",0,$K${row}))*設定!$B$6/100,0))`, '#,##0');
      tcFormula(ws, `O${row}`, `IF($L${row}="","",$L${row}+IF($M${row}="",0,$M${row})+IF($N${row}="",0,$N${row}))`, '#,##0');
      tcFormula(ws, `P${row}`, `IF(OR($I${row}="",$I${row}=0,$O${row}=""),"",ROUND($O${row}/$I${row},0))`, '#,##0');
      tcFormula(ws, `Q${row}`, `IF($P${row}="","",IF($P${row}<設定!$B$7,"最低賃金未満","OK"))`);
    }

    ws['!cols'] = [{ wch: 4 }, { wch: 5 }, { wch: 8 }, { wch: 7 }, { wch: 7 }, { wch: 7 }, { wch: 8 }, { wch: 8 }, { wch: 10 }, { wch: 12 }, { wch: 14 }, { wch: 13 }, { wch: 11 }, { wch: 11 }, { wch: 11 }, { wch: 12 }, { wch: 14 }];
    tcFinalize(ws, endRow, headers.length - 1);
    return ws;
  }

  // パート（時給制）用シート。サマリーは正社員シートと同じ番地（B3〜B8）に置き、全体集計から共通参照する
  function buildPartSheet(name, recsByDay, year, monthNum, daysInMonth, hourlyWage, commute) {
    const ws = {};
    const endRow = TC_TABLE_START + daysInMonth - 1;

    tcSetCell(ws, 'A1', `${year}年${monthNum}月 勤務表（時給制）`);
    tcSetCell(ws, 'D1', name);
    tcSetCell(ws, 'A3', '勤務日数');
    tcFormula(ws, 'B3', `COUNT(L${TC_TABLE_START}:L${endRow})`);
    tcSetCell(ws, 'A4', '実働合計（時間）');
    tcFormula(ws, 'B4', `SUM(G${TC_TABLE_START}:G${endRow})`, '0.00');
    tcSetCell(ws, 'A5', '基本賃金合計（円）');
    tcFormula(ws, 'B5', `SUM(H${TC_TABLE_START}:H${endRow})`, '#,##0');
    tcSetCell(ws, 'A6', '割増・交通費合計（円）');
    tcFormula(ws, 'B6', `SUM(I${TC_TABLE_START}:I${endRow})+SUM(J${TC_TABLE_START}:J${endRow})+SUM(K${TC_TABLE_START}:K${endRow})`, '#,##0');
    tcSetCell(ws, 'A7', '売上合計（時給制は対象外）');
    tcSetCell(ws, 'B7', 0);
    tcSetCell(ws, 'A8', '総支給額（円）');
    tcFormula(ws, 'B8', `SUM(L${TC_TABLE_START}:L${endRow})`, '#,##0');
    tcSetCell(ws, 'C3', '時間給（円）');
    ws['D3'] = { t: 'n', v: hourlyWage, z: '#,##0' };
    tcSetCell(ws, 'C4', '交通費（1日・円）');
    ws['D4'] = { t: 'n', v: commute, z: '#,##0' };

    const headers = ['日', '曜日', '出勤', '退勤', '休憩(分)', '外出(分)', '実働(時間)', '基本賃金(円)', '残業割増(円)', '深夜割増(円)', '交通費(円)', '日合計(円)', '時給換算(円)', '最低賃金判定'];
    headers.forEach((h, i) => tcSetCell(ws, XLSX.utils.encode_cell({ r: TC_TABLE_START - 2, c: i }), h));

    const WEEKDAYS = ['日', '月', '火', '水', '木', '金', '土'];
    for (let day = 1; day <= daysInMonth; day++) {
      const row = TC_TABLE_START + day - 1;
      const date = new Date(year, monthNum - 1, day);
      tcSetCell(ws, `A${row}`, day);
      tcSetCell(ws, `B${row}`, WEEKDAYS[date.getDay()]);
      const rec = recsByDay[day];
      if (rec) {
        if (rec.in) ws[`C${row}`] = { t: 'n', v: tcTimeSerial(rec.in), z: 'h:mm' };
        if (rec.out) ws[`D${row}`] = { t: 'n', v: tcTimeSerial(rec.out), z: 'h:mm' };
        tcSetCell(ws, `E${row}`, breakMinutes(rec));
        tcSetCell(ws, `F${row}`, awayMinutes(rec));
      }
      tcFormula(ws, `G${row}`, `IF(OR($C${row}="",$D${row}=""),"",ROUND(($D${row}-$C${row}+IF($D${row}<$C${row},1,0))*24-IF($E${row}="",0,$E${row})/60-IF($F${row}="",0,$F${row})/60,2))`, '0.00');
      tcFormula(ws, `H${row}`, `IF($G${row}="","",ROUND($G${row}*$D$3,0))`, '#,##0');
      tcFormula(ws, `I${row}`, `IF($G${row}="","",ROUND(MAX(0,$G${row}-8)*$D$3*設定!$B$8/100,0))`, '#,##0');
      tcFormula(ws, `J${row}`, `IF($D${row}="","",ROUND(MAX(0,($D${row}-${NIGHT_START_HOUR}/24))*24*$D$3*設定!$B$8/100,0))`, '#,##0');
      tcFormula(ws, `K${row}`, `IF($G${row}="","",$D$4)`, '#,##0');
      tcFormula(ws, `L${row}`, `IF($H${row}="","",$H${row}+$I${row}+$J${row}+$K${row})`, '#,##0');
      tcFormula(ws, `M${row}`, `IF(OR($G${row}="",$G${row}=0,$L${row}=""),"",ROUND($L${row}/$G${row},0))`, '#,##0');
      tcFormula(ws, `N${row}`, `IF($M${row}="","",IF($M${row}<設定!$B$7,"最低賃金未満","OK"))`);
    }

    ws['!cols'] = [{ wch: 4 }, { wch: 5 }, { wch: 7 }, { wch: 7 }, { wch: 8 }, { wch: 8 }, { wch: 10 }, { wch: 12 }, { wch: 11 }, { wch: 11 }, { wch: 10 }, { wch: 11 }, { wch: 12 }, { wch: 14 }];
    tcFinalize(ws, endRow, headers.length - 1);
    return ws;
  }

  // 月給制（正社員(月給)）用シート。給与は固定額のため日別には計算せず、勤怠記録＋交通費のみ日別に集計する。
  // サマリーは他シートと同じ番地（B3〜B8）に置き、全体集計から共通参照する
  function buildMonthlySheet(name, recsByDay, year, monthNum, daysInMonth, monthlyWage, commute) {
    const ws = {};
    const endRow = TC_TABLE_START + daysInMonth - 1;

    tcSetCell(ws, 'A1', `${year}年${monthNum}月 勤務表（月給制）`);
    tcSetCell(ws, 'D1', name);
    tcSetCell(ws, 'A3', '勤務日数');
    tcFormula(ws, 'B3', `COUNT(G${TC_TABLE_START}:G${endRow})`);
    tcSetCell(ws, 'A4', '実働合計（時間）');
    tcFormula(ws, 'B4', `SUM(G${TC_TABLE_START}:G${endRow})`, '0.00');
    tcSetCell(ws, 'A5', '月給（円）');
    tcFormula(ws, 'B5', '$D$3', '#,##0');
    tcSetCell(ws, 'A6', '交通費合計（円）');
    tcFormula(ws, 'B6', `SUM(H${TC_TABLE_START}:H${endRow})`, '#,##0');
    tcSetCell(ws, 'A7', '売上合計（月給制は対象外）');
    tcSetCell(ws, 'B7', 0);
    tcSetCell(ws, 'A8', '総支給額（円）');
    tcFormula(ws, 'B8', '$B$5+$B$6', '#,##0');
    tcSetCell(ws, 'C3', '月給（円）');
    ws['D3'] = { t: 'n', v: monthlyWage, z: '#,##0' };
    tcSetCell(ws, 'C4', '交通費（1日・円）');
    ws['D4'] = { t: 'n', v: commute, z: '#,##0' };

    const headers = ['日', '曜日', '出勤', '退勤', '休憩(分)', '外出(分)', '実働(時間)', '交通費(円)'];
    headers.forEach((h, i) => tcSetCell(ws, XLSX.utils.encode_cell({ r: TC_TABLE_START - 2, c: i }), h));

    const WEEKDAYS = ['日', '月', '火', '水', '木', '金', '土'];
    for (let day = 1; day <= daysInMonth; day++) {
      const row = TC_TABLE_START + day - 1;
      const date = new Date(year, monthNum - 1, day);
      tcSetCell(ws, `A${row}`, day);
      tcSetCell(ws, `B${row}`, WEEKDAYS[date.getDay()]);
      const rec = recsByDay[day];
      if (rec) {
        if (rec.in) ws[`C${row}`] = { t: 'n', v: tcTimeSerial(rec.in), z: 'h:mm' };
        if (rec.out) ws[`D${row}`] = { t: 'n', v: tcTimeSerial(rec.out), z: 'h:mm' };
        tcSetCell(ws, `E${row}`, breakMinutes(rec));
        tcSetCell(ws, `F${row}`, awayMinutes(rec));
      }
      tcFormula(ws, `G${row}`, `IF(OR($C${row}="",$D${row}=""),"",ROUND(($D${row}-$C${row}+IF($D${row}<$C${row},1,0))*24-IF($E${row}="",0,$E${row})/60-IF($F${row}="",0,$F${row})/60,2))`, '0.00');
      tcFormula(ws, `H${row}`, `IF($G${row}="","",$D$4)`, '#,##0');
    }

    ws['!cols'] = [{ wch: 4 }, { wch: 5 }, { wch: 7 }, { wch: 7 }, { wch: 8 }, { wch: 8 }, { wch: 10 }, { wch: 11 }];
    tcFinalize(ws, endRow, headers.length - 1);
    return ws;
  }

  $('timecardBtn').onclick = async () => {
    if (!(await requireAdmin())) return;
    renderAdminBar();
    const month = currentMonth(); // "YYYY-MM"
    const [year, monthNum] = month.split('-').map(Number);
    const daysInMonth = new Date(year, monthNum, 0).getDate();
    const monthRecs = log.filter(r => r.date.startsWith(month));
    if (!monthRecs.length) { alert('この月の記録がありません'); return; }

    const wb = XLSX.utils.book_new();

    // 設定シート（各シートの数式がここを参照。値を変えると全シート再計算される）
    const settingRows = [
      ['項目', '数値', '備考'],
      ['普通番 基本日給（円）', settings.normalWage, '勤怠アプリ「給与設定」の値を出力時に転記'],
      ['遅番 基本日給（円）', settings.lateWage, ''],
      ['遅番 割増賃金（円）', settings.lateBonus, ''],
      ['電話番手当（円）', settings.phoneAllowance, ''],
      ['歩合率（％）', settings.commissionRate, '（売上税抜−カード手数料）に掛ける率'],
      ['最低賃金（円・確認用）', settings.minWage, '福島県の地域別最低賃金'],
      ['残業・深夜割増率（％）', OT_RATE * 100, `パート用：8時間超と${NIGHT_START_HOUR}時以降に時間給へ上乗せする率（法定25%）`],
    ];
    const wsSettings = XLSX.utils.aoa_to_sheet(settingRows);
    wsSettings['!cols'] = [{ wch: 24 }, { wch: 10 }, { wch: 40 }];
    XLSX.utils.book_append_sheet(wb, wsSettings, '設定');

    // スタッフごとに日別レコードを整理（1日1レコード）
    const usedNames = new Set(['設定', '全体集計', '使い方']);
    const staffSheets = []; // { name, sheetName }
    const byStaff = {};
    for (const rec of monthRecs) byStaff[rec.staffId] = byStaff[rec.staffId] || {};
    for (const rec of monthRecs) byStaff[rec.staffId][Number(rec.date.slice(8, 10))] = rec;

    // 区分と時給・月給・交通費は打刻時のスナップショット（rec）優先、無ければスタッフの現在値
    function targetOf(name, days, staffObj) {
      const recs = Object.values(days);
      const isPart = recs.some(r => isHourlyType(recEmpType(r)));
      const isMonthly = recs.some(r => isMonthlyType(recEmpType(r)));
      const src = recs.find(r => r.hourlyWage != null) || {};
      const monthlySrc = recs.find(r => r.monthlyWage != null) || {};
      const dailyWageSrc = recs.find(r => r.dailyWage != null);
      return {
        name, days,
        isPart, isMonthly,
        hourlyWage: src.hourlyWage ?? (staffObj && staffObj.hourlyWage) ?? settings.minWage,
        monthlyWage: monthlySrc.monthlyWage ?? (staffObj && staffObj.monthlyWage) ?? 0,
        dailyWage: dailyWageSrc ? dailyWageSrc.dailyWage : ((staffObj && staffObj.dailyWage != null) ? staffObj.dailyWage : null),
        commute: src.commute ?? monthlySrc.commute ?? (staffObj && staffObj.commuteAllowance) ?? 0,
      };
    }
    const targets = staff.filter(s => byStaff[s.id]).map(s => targetOf(s.name, byStaff[s.id], s));
    const orphanIds = Object.keys(byStaff).filter(id => !staff.some(s => s.id === id));
    orphanIds.forEach((id, i) => targets.push(targetOf(`削除済みスタッフ${i + 1}`, byStaff[id], null)));

    for (const t of targets) {
      const sheetName = tcSheetName(t.name, usedNames);
      staffSheets.push({ name: t.name, sheetName, isPart: t.isPart || t.isMonthly });
      const sheet = t.isMonthly
        ? buildMonthlySheet(t.name, t.days, year, monthNum, daysInMonth, t.monthlyWage, t.commute)
        : t.isPart
          ? buildPartSheet(t.name, t.days, year, monthNum, daysInMonth, t.hourlyWage, t.commute)
          : buildStaffSheet(t.name, t.days, year, monthNum, daysInMonth, t.dailyWage);
      XLSX.utils.book_append_sheet(wb, sheet, sheetName);
    }

    // 全体集計シート（各スタッフシートのサマリーを参照）
    const wsAll = {};
    tcSetCell(wsAll, 'A1', `${year}年${monthNum}月 給与集計`);
    ['名前', '勤務日数', '実働合計(時間)', '基本給合計(円)', '歩合・手当合計(円)', '売上合計(円)', '総支給額(円)'].forEach((h, i) => {
      tcSetCell(wsAll, XLSX.utils.encode_cell({ r: 2, c: i }), h);
    });
    staffSheets.forEach((s, i) => {
      const row = 4 + i;
      const q = tcQuote(s.sheetName);
      tcSetCell(wsAll, `A${row}`, s.name);
      tcFormula(wsAll, `B${row}`, `${q}!$B$3`);
      tcFormula(wsAll, `C${row}`, `${q}!$B$4`, '0.00');
      tcFormula(wsAll, `D${row}`, `${q}!$B$5`, '#,##0');
      tcFormula(wsAll, `E${row}`, `${q}!$B$6`, '#,##0');
      tcFormula(wsAll, `F${row}`, `${q}!$B$7`, '#,##0');
      tcFormula(wsAll, `G${row}`, `${q}!$B$8`, '#,##0');
    });
    const totalRow = 4 + staffSheets.length + 1;
    tcSetCell(wsAll, `A${totalRow}`, '合計');
    for (const col of ['B', 'C', 'D', 'E', 'F', 'G']) {
      tcFormula(wsAll, `${col}${totalRow}`, `SUM(${col}4:${col}${totalRow - 1})`, col === 'C' ? '0.00' : '#,##0');
    }
    wsAll['!cols'] = [{ wch: 14 }, { wch: 9 }, { wch: 13 }, { wch: 16 }, { wch: 13 }, { wch: 13 }, { wch: 13 }];
    tcFinalize(wsAll, totalRow, 6);
    XLSX.utils.book_append_sheet(wb, wsAll, '全体集計');
    // 全体集計を設定の直後（2番目）に移動
    wb.SheetNames.splice(wb.SheetNames.indexOf('全体集計'), 1);
    wb.SheetNames.splice(1, 0, '全体集計');

    // 使い方シート
    const usage = [
      ['【このファイルについて】'],
      ['勤怠アプリ（/kintai）の打刻データから自動生成した給与計算ブックです。'],
      [`対象月：${year}年${monthNum}月`],
      [''],
      ['【給与の計算式】（勤怠アプリと同じ）'],
      ['◎ 正社員：総支給額 ＝ シフト日給（普通番／遅番）＋ 電話番手当 ＋ 歩合給 ＋ 交通費（設定した場合）'],
      ['　　歩合給 ＝（売上税抜 − カード手数料等）× 歩合率'],
      ['◎ 正社員（基本給のみ）：総支給額 ＝ シフト日給（普通番／遅番）＋ 電話番手当 ＋ 交通費（設定した場合）（歩合給はなし）'],
      ['◎ 時給制（パート・正社員(時給)）：総支給額 ＝ 時間給 × 実働時間 ＋ 残業割増（8時間超×25%）＋ 深夜割増（22時以降×25%）＋ 交通費（日額）'],
      ['　　時間給・交通費は各スタッフのシート右上（D3・D4）で変更できます。'],
      ['◎ 月給制（正社員(月給)）：総支給額 ＝ 月給（固定額）＋ 交通費（日額）'],
      ['　　月給・交通費は各スタッフのシート右上（D3・D4）で変更できます。実働時間は勤怠記録として参考表示のみで、金額には影響しません。'],
      [''],
      ['【シートの見方】'],
      ['・スタッフごとに1シート（正社員・パート・月給制で列構成が異なります）。出勤・退勤・休憩などは打刻データを転記済みです。'],
      ['・実働時間・日給・歩合給・日合計は数式です。時刻や売上を手で修正すると自動で再計算されます。'],
      ['・「設定」シートの数値（日給・歩合率など）を変更すると、全シートが再計算されます。'],
      ['・「全体集計」シートに全員の勤務日数・総支給額がまとまります。'],
      [''],
      ['【注意】'],
      ['・出力時点の打刻データのスナップショットです。以後の打刻は反映されないため、月末に再出力してください。'],
      ['・カード手数料は決済明細の実績と異なる場合があります。必要に応じてK列を手修正してください。'],
    ];
    const wsUsage = XLSX.utils.aoa_to_sheet(usage);
    wsUsage['!cols'] = [{ wch: 90 }];
    XLSX.utils.book_append_sheet(wb, wsUsage, '使い方');

    const reiwa = year - 2018;
    XLSX.writeFile(wb, `タイムカードR${reiwa}.${monthNum}月分_給与計算.xlsx`);
  };

  // ── 起動処理（Supabaseへのログイン→データ読み込み） ──
  async function boot() {
    const authResult = await initAuth();
    if (!authResult.ok) {
      alert(authResult.error || 'ログインできませんでした。ページを再読み込みしてもう一度お試しください。');
      return;
    }
    try {
      settings = await fetchSettings();
      staff = await fetchStaff();
      await refreshData();
    } catch (e) {
      alert('データの読み込みに失敗しました。通信状況を確認してページを再読み込みしてください。');
      return;
    }
    renderAdminBar();
    renderStaff();
    renderPunch();
    renderToday();
    renderHist();
    renderWage();
  }
  boot();
</script>

