---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';
import type { NewsItem } from '../../lib/microcms';

export async function getStaticPaths() {
  const data = await client.get({ endpoint: 'news', queries: { limit: 100 } });
  return data.contents.map((item: NewsItem) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props as { item: NewsItem };

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}年${String(d.getMonth() + 1).padStart(2, '0')}月${String(d.getDate()).padStart(2, '0')}日`;
}
---

<Layout
  title={item.title}
  description={item.title + ' ｜ 富士タクシーからのお知らせ'}
>

  <section class="page-hero bg-black">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <ol>
          <li><a href="/">ホーム</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/news">お知らせ</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">{item.title}</li>
        </ol>
      </nav>
      <p class="eyebrow">News</p>
      <h1>{item.title}</h1>
      <div class="meta">
        <time datetime={item.publishedAt}>
          {formatDate(item.publishedAt || item.createdAt)}
        </time>
        <span class={`badge ${item.category === '重要' ? 'badge--yellow' : 'badge--outline'}`}>
          {item.category}
        </span>
      </div>
    </div>
  </section>

  <section class="section bg-soft">
    <div class="container">
      <article class="article-body" set:html={item.body} />
      <div class="back-link">
        <a href="/news">← お知らせ一覧に戻る</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding-block: 5rem 4rem;
  }
  .page-hero h1 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 900;
    color: var(--fuji-white);
    margin-block: 1rem;
    line-height: 1.4;
  }
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--fuji-gray-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fuji-yellow); }
  .breadcrumb li:last-child {
    color: var(--fuji-white);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 20rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .meta time {
    font-family: var(--font-en);
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
  }
  .badge {
    display: inline-block;
    padding: 0.2rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
  }
  .badge--yellow { background: var(--fuji-yellow); color: var(--fuji-black); }
  .badge--outline { border: 1px solid #555; color: #ccc; }

  .article-body {
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.9;
    font-size: var(--text-base);
    color: var(--fuji-black);
  }
  .article-body :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin-block: 2rem 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--fuji-yellow);
  }
  .article-body :global(h3) {
    font-size: 1.15rem;
    font-weight: 700;
    margin-block: 1.5rem 0.75rem;
  }
  .article-body :global(p) { margin-bottom: 1.25rem; }
  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .article-body :global(li) { margin-bottom: 0.4rem; }
  .article-body :global(a) {
    color: var(--fuji-yellow-dark);
    text-decoration: underline;
  }
  .article-body :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    margin-block: 1rem;
  }

  .back-link {
    max-width: 720px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--fuji-gray-light);
  }
  .back-link a {
    color: var(--fuji-yellow-dark);
    text-decoration: none;
    font-weight: 600;
  }
  .back-link a:hover { text-decoration: underline; }
</style>
