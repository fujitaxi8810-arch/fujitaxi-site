---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';
import type { NewsItem } from '../../lib/microcms';

let newsItems: NewsItem[] = [];
let fetchError = false;

try {
  const data = await client.get({
    endpoint: 'news',
    queries: { orders: '-publishedAt', limit: 20 },
  });
  newsItems = data.contents;
} catch (e) {
  fetchError = true;
}

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return {
    year:  d.getFullYear(),
    month: String(d.getMonth() + 1).padStart(2, '0'),
    day:   String(d.getDate()).padStart(2, '0'),
  };
}
---

<Layout
  title="お知らせ"
  description="富士タクシーからのお知らせ。営業時間変更・新サービス・地域イベント情報などを掲載。"
>

  <!-- ヒーロー -->
  <section class="news-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <ol>
          <li><a href="/">ホーム</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">お知らせ</li>
        </ol>
      </nav>
      <div class="news-hero__content reveal">
        <p class="news-hero__en">News</p>
        <h1>お知らせ</h1>
        <p class="news-hero__desc">富士タクシーからの最新情報をお届けします</p>
      </div>
    </div>
  </section>

  <!-- お知らせ一覧 -->
  <section class="news-section">
    <div class="container">

      <!-- 常時掲載 -->
      <div class="pinned-section reveal">
        <p class="pinned-section__label">いつでも確認できる基本情報</p>
        <ul class="pinned-cards">
          <li class="pinned-card pinned-card--highlight">
            <div class="pinned-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="pinned-card__body">
              <p class="pinned-card__label">営業時間</p>
              <p class="pinned-card__value">年中無休</p>
              <p class="pinned-card__sub">7:00 〜 24:00</p>
            </div>
          </li>
          <li class="pinned-card">
            <div class="pinned-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="pinned-card__body">
              <p class="pinned-card__label">拠点</p>
              <p class="pinned-card__value">2拠点</p>
              <p class="pinned-card__sub">小高区・原町区</p>
            </div>
          </li>
          <li class="pinned-card">
            <div class="pinned-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </div>
            <div class="pinned-card__body">
              <p class="pinned-card__label">お支払い</p>
              <p class="pinned-card__value">10種類以上</p>
              <p class="pinned-card__sub">クレカ・QR・電子マネー</p>
            </div>
          </li>
          <li class="pinned-card">
            <div class="pinned-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div class="pinned-card__body">
              <p class="pinned-card__label">ジャンボタクシー</p>
              <p class="pinned-card__value">最大9名</p>
              <p class="pinned-card__sub">事前予約制</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- microCMS記事 -->
      <div class="news-block">
        <h2 class="news-block__title reveal">最新のお知らせ</h2>

        {fetchError ? (
          <div class="notice notice--error reveal">
            現在お知らせを読み込めません。お急ぎの場合は<a href="tel:0244442543">0244-44-2543</a>までお電話ください。
          </div>
        ) : newsItems.length === 0 ? (
          <div class="notice reveal">現在お知らせはありません。</div>
        ) : (
          <ul class="article-list">
            {newsItems.map((item, i) => {
              const d = formatDate(item.publishedAt || item.createdAt);
              const isImportant = item.category === '重要';
              return (
                <li class="article-card reveal" style={`transition-delay:${i * 60}ms`}>
                  <a href={`/news/${item.id}`} class="article-card__link">
                    <div class="article-card__left">
                      <time class="article-card__date" datetime={item.publishedAt}>
                        <span class="article-card__month">{d.year}.{d.month}</span>
                        <span class="article-card__day">{d.day}</span>
                      </time>
                    </div>
                    <div class="article-card__body">
                      <span class={`article-card__tag${isImportant ? ' article-card__tag--yellow' : ''}`}>{item.category}</span>
                      <p class="article-card__title">{item.title}</p>
                    </div>
                    <div class="article-card__arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>

    </div>
  </section>

</Layout>

<style>
  /* ── ヒーロー ── */
  .news-hero {
    background: var(--fuji-black);
    padding-block: 5rem 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
    margin-bottom: 2rem;
  }
  .breadcrumb a { color: var(--fuji-gray-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fuji-yellow); }

  .news-hero__content { max-width: 640px; }
  .news-hero__en {
    font-family: var(--font-en);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fuji-yellow);
    margin-bottom: 0.75rem;
  }
  .news-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    color: var(--fuji-white);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .news-hero__desc {
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
  }

  /* ── メインセクション ── */
  .news-section {
    background: #f8f8f6;
    padding-block: 4rem 6rem;
    min-height: 60vh;
  }

  /* ── 常時掲載 ── */
  .pinned-section {
    margin-bottom: 3rem;
  }
  .pinned-section__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #999;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .pinned-cards {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .pinned-card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 10px;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    cursor: default;
  }
  .pinned-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    border-color: var(--fuji-yellow);
    background: #fffdf0;
  }
  .pinned-card:hover .pinned-card__icon { color: var(--fuji-yellow-dark); }
  .pinned-card:hover .pinned-card__value { color: #000; }

  .pinned-card--highlight {
    background: var(--fuji-black);
    border-color: var(--fuji-black);
    color: var(--fuji-white);
  }
  .pinned-card--highlight:hover {
    background: #1a1a00;
    border-color: var(--fuji-yellow);
    box-shadow: 0 8px 32px rgba(245,200,0,0.3);
  }
  .pinned-card--highlight:hover .pinned-card__icon { color: var(--fuji-yellow); }
  .pinned-card--highlight:hover .pinned-card__value { color: var(--fuji-yellow); }
  .pinned-card__icon {
    color: #bbb;
    line-height: 1;
  }
  .pinned-card--highlight .pinned-card__icon {
    color: var(--fuji-yellow);
  }
  .pinned-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .pinned-card__label {
    font-size: 0.68rem;
    font-weight: 700;
    color: #aaa;
    letter-spacing: 0.05em;
  }
  .pinned-card--highlight .pinned-card__label { color: rgba(255,255,255,0.5); }
  .pinned-card__value {
    font-size: 1.15rem;
    font-weight: 900;
    color: #111;
    line-height: 1.1;
  }
  .pinned-card--highlight .pinned-card__value { color: var(--fuji-white); }
  .pinned-card__sub {
    font-size: 0.75rem;
    color: #888;
    margin-top: 0.1rem;
  }
  .pinned-card--highlight .pinned-card__sub { color: rgba(255,255,255,0.5); }

  @media (max-width: 700px) {
    .pinned-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 400px) {
    .pinned-cards { grid-template-columns: 1fr 1fr; }
  }

  /* ── タグ ── */
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 700;
    border: 1px solid #d0d0cc;
    color: #555;
    white-space: nowrap;
  }
  .tag--yellow {
    background: var(--fuji-yellow);
    color: var(--fuji-black);
    border-color: var(--fuji-yellow);
  }
  .flex-shrink { flex-shrink: 0; }

  /* ── 記事ブロック ── */
  .news-block__title {
    font-size: 1rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #111;
    letter-spacing: 0.02em;
  }

  /* ── 記事カード ── */
  .article-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .article-card__link {
    display: flex;
    align-items: stretch;
    text-decoration: none;
    background: var(--fuji-black);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .article-card__link:hover {
    border-color: var(--fuji-yellow);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }

  .article-card__left {
    background: rgba(255,255,255,0.04);
    border-right: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    min-width: 90px;
  }
  .article-card__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }
  .article-card__month {
    font-family: var(--font-en);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--fuji-gray-muted);
    line-height: 1;
  }
  .article-card__day {
    font-family: var(--font-en);
    font-size: 2rem;
    font-weight: 900;
    color: var(--fuji-white);
    line-height: 1;
  }

  .article-card__body {
    flex: 1;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
  }
  .article-card__tag {
    display: inline-block;
    width: fit-content;
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius-full);
    font-size: 0.68rem;
    font-weight: 700;
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--fuji-gray-muted);
  }
  .article-card__tag--yellow {
    background: var(--fuji-yellow);
    color: var(--fuji-black);
    border-color: var(--fuji-yellow);
  }
  .article-card__title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fuji-white);
    line-height: 1.5;
  }
  .article-card__link:hover .article-card__title {
    color: var(--fuji-yellow);
  }

  .article-card__arrow {
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    flex-shrink: 0;
    color: rgba(255,255,255,0.2);
    transition: color 0.2s, transform 0.2s;
  }
  .article-card__link:hover .article-card__arrow {
    color: var(--fuji-yellow);
    transform: translateX(3px);
  }

  @media (max-width: 600px) {
    .article-card__left { min-width: 70px; padding: 1rem; }
    .article-card__day { font-size: 1.5rem; }
    .article-card__body { padding: 1rem; }
    .article-card__arrow { padding: 0 0.75rem; }
  }

  /* ── notices ── */
  .notice {
    padding: 2rem;
    text-align: center;
    color: #666;
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    background: #fff;
    border: 1px solid #e0e0dc;
  }
  .notice--error { background: #fff8f8; border-color: #fdd; }
  .notice a { color: #333; font-weight: 600; }

  /* ── reveal ── */
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.is-visible { opacity: 1; transform: none; }

  /* ── SP ── */
  @media (max-width: 600px) {
    .pinned { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .article-item__link { gap: 0.75rem; padding: 1rem 0.5rem; }
    .article-item__arrow { display: none; }
  }
</style>
