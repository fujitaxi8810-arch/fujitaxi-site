---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';
import type { NewsItem } from '../../lib/microcms';

let newsItems: NewsItem[] = [];
let fetchError = false;

try {
  const data = await client.get({
    endpoint: 'news',
    queries: { orders: '-publishedAt', limit: 20 },
  });
  newsItems = data.contents;
} catch (e) {
  fetchError = true;
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}年${String(d.getMonth() + 1).padStart(2, '0')}月${String(d.getDate()).padStart(2, '0')}日`;
}
---

<Layout
  title="お知らせ"
  description="富士タクシーからのお知らせ。営業時間変更・新サービス・地域イベント情報などを掲載。"
>

  <!-- ページヒーロー -->
  <section class="page-hero bg-black">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <ol>
          <li><a href="/">ホーム</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">お知らせ</li>
        </ol>
      </nav>
      <p class="eyebrow reveal">News</p>
      <h1 class="reveal">お知らせ</h1>
    </div>
  </section>

  <!-- 固定お知らせ -->
  <section class="section bg-soft" style="padding-bottom: 0;">
    <div class="container">
      <p class="eyebrow reveal" style="color: var(--fuji-yellow-dark);">固定のお知らせ</p>
      <ul class="news-list reveal" role="list" style="margin-top: 1rem;">
        <li class="news-item">
          <div class="news-item__link">
            <span class="news-item__badge badge--yellow">営業</span>
            <span class="news-item__title">年中無休 7:00〜24:00 営業中</span>
          </div>
        </li>
        <li class="news-item">
          <div class="news-item__link">
            <span class="news-item__badge badge--outline">拠点</span>
            <span class="news-item__title">小高区・原町区 2拠点でお待ちしています</span>
          </div>
        </li>
        <li class="news-item">
          <div class="news-item__link">
            <span class="news-item__badge badge--outline">予約</span>
            <span class="news-item__title">ジャンボタクシー（最大9名）は事前予約制</span>
          </div>
        </li>
        <li class="news-item">
          <div class="news-item__link">
            <span class="news-item__badge badge--outline">決済</span>
            <span class="news-item__title">クレカ・QR・電子マネーなど10種類以上の決済対応</span>
          </div>
        </li>
        <li class="news-item">
          <div class="news-item__link">
            <span class="news-item__badge badge--outline">電話</span>
            <span class="news-item__title">本社 0244-44-2543 ／ 原町待機所 0244-32-0030</span>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- お知らせ一覧 -->
  <section class="section bg-soft">
    <div class="container">
      {fetchError ? (
        <div class="error-message">
          <p>現在お知らせを読み込めません。しばらく時間をおいて再度アクセスしてください。</p>
          <p class="error-contact">お急ぎの場合はお電話（0244-44-2543）にてご連絡ください。</p>
        </div>
      ) : newsItems.length === 0 ? (
        <div class="empty-message">
          <p>現在お知らせはありません。</p>
        </div>
      ) : (
        <ul class="news-list reveal" role="list">
          {newsItems.map((item) => (
            <li class="news-item">
              <a href={`/news/${item.id}`} class="news-item__link">
                <time class="news-item__date" datetime={item.publishedAt}>
                  {formatDate(item.publishedAt || item.createdAt)}
                </time>
                <span class={`news-item__badge ${item.category === '重要' ? 'badge--yellow' : 'badge--outline'}`}>
                  {item.category}
                </span>
                <span class="news-item__title">{item.title}</span>
                <span class="news-item__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding-block: 5rem 4rem;
  }
  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: var(--fuji-white);
    margin-block: 1rem;
  }
  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--fuji-gray-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--fuji-yellow); }

  .news-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .news-item {
    border-bottom: 1px solid var(--fuji-gray-light);
  }
  .news-item:first-child {
    border-top: 1px solid var(--fuji-gray-light);
  }
  .news-item__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0.5rem;
    text-decoration: none;
    transition: background-color var(--transition-fast);
    flex-wrap: wrap;
  }
  .news-item__link:hover {
    background: var(--fuji-white);
    padding-left: 1rem;
  }
  .news-item__date {
    font-family: var(--font-en);
    font-size: var(--text-sm);
    color: var(--fuji-gray-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .news-item__badge {
    display: inline-block;
    padding: 0.2rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
  }
  .badge--yellow {
    background: var(--fuji-yellow);
    color: var(--fuji-black);
  }
  .badge--outline {
    border: 1px solid var(--fuji-gray-light);
    color: #555;
  }
  .news-item__title {
    flex: 1;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--fuji-black);
  }
  .news-item__arrow {
    color: var(--fuji-yellow-dark);
    font-weight: 700;
    flex-shrink: 0;
  }

  .error-message,
  .empty-message {
    text-align: center;
    padding: 4rem 2rem;
    color: #555;
  }
  .error-contact {
    margin-top: 0.75rem;
    font-size: var(--text-sm);
    color: #777;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }
</style>
