---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="乗務日報 – 富士タクシー（社内用）"
  description="富士タクシー社内用のデジタル乗務日報。乗車ごとの記録、現収・未収の自動集計、勤怠アプリへの売上反映ができます。"
>

  <section class="page-hero bg-black">
    <div class="container">
      <p class="eyebrow">Staff Only</p>
      <h1>乗務<span class="text-yellow">日報</span></h1>
      <p class="page-hero__lead">1乗車ずつ入力するだけで、現収・未収・回数を自動集計します。このページは社内用です。</p>
      <p class="np-clock" id="clock" aria-live="polite">--:--:--</p>
      <p class="np-date" id="todayLabel"></p>
    </div>
  </section>

  <section class="section bg-black" style="padding-top: 1rem;">
    <div class="container nippo-wrap">

      <div class="np-toolbar">
        <a class="np-btn np-btn--ghost" href="/kintai">⏱ 勤怠管理へ</a>
      </div>

      <!-- 乗務員・基本情報 -->
      <div class="np-panel">
        <div class="np-panel__head">
          <h2 class="np-title">① 乗務員を選ぶ</h2>
        </div>
        <div class="np-staff-list" id="staffList"></div>
        <div class="np-headfields" id="headFields" hidden>
          <label class="np-field np-field--sm">
            <span>日付</span>
            <input type="date" id="datePick" class="np-input" />
          </label>
          <label class="np-field np-field--sm">
            <span>車両番号</span>
            <input type="text" id="vehicleInput" class="np-input" placeholder="例: 33-48" />
          </label>
        </div>
      </div>

      <!-- 乗車入力 -->
      <div class="np-panel np-panel--main" id="ridePanel" hidden>
        <h2 class="np-title">② 乗車を記録する</h2>
        <div class="np-ride-grid">
          <label class="np-field">
            <span>発時刻</span>
            <div class="np-timegroup">
              <input type="time" id="depTime" class="np-input" />
              <button type="button" class="np-btn np-btn--now" id="depNowBtn">今</button>
            </div>
          </label>
          <label class="np-field">
            <span>着時刻</span>
            <div class="np-timegroup">
              <input type="time" id="arrTime" class="np-input" />
              <button type="button" class="np-btn np-btn--now" id="arrNowBtn">今</button>
            </div>
          </label>
          <label class="np-field">
            <span>乗車地</span>
            <input type="text" id="fromInput" class="np-input" list="spotList" placeholder="例: 原ノ町駅" />
          </label>
          <label class="np-field">
            <span>降車地</span>
            <input type="text" id="toInput" class="np-input" list="spotList" placeholder="例: 市立病院" />
          </label>
          <label class="np-field np-field--sm">
            <span>人員</span>
            <input type="number" id="paxInput" class="np-input" min="1" value="1" inputmode="numeric" />
          </label>
          <label class="np-field np-field--sm">
            <span>メーター額（税込・円）</span>
            <input type="number" id="fareInput" class="np-input" min="0" inputmode="numeric" placeholder="例: 2400" />
          </label>
          <label class="np-field">
            <span>お支払い方法</span>
            <select id="payInput" class="np-input">
              <option value="cash">現金（現収）</option>
              <option value="machine">決済機（カード・IC等）</option>
              <option value="qr">QRコード（PayPay・d払い等）</option>
              <option value="ticket">タクシーチケット</option>
              <option value="minataku">みなタク</option>
              <option value="billing">未収（掛け・請求書）</option>
            </select>
          </label>
          <label class="np-field">
            <span>割引</span>
            <select id="discountInput" class="np-input">
              <option value="">なし</option>
              <option value="障がい">障がい割引</option>
              <option value="遠距離">遠距離割引</option>
              <option value="免許返納">免許返納割引</option>
            </select>
          </label>
          <label class="np-field" id="ticketNoField" hidden>
            <span>チケット番号</span>
            <input type="text" id="ticketNoInput" class="np-input" placeholder="例: B01234" />
          </label>
          <label class="np-field" id="customerField" hidden>
            <span>顧客名（敬称略）</span>
            <input type="text" id="customerInput" class="np-input" placeholder="例: 〇〇様" />
          </label>
        </div>
        <datalist id="spotList"></datalist>
        <button type="button" class="np-addbtn" id="addRideBtn">＋ この乗車を記録する</button>
        <p class="np-msg" id="rideMsg" aria-live="polite"></p>
      </div>

      <!-- 本日の乗車一覧 -->
      <div class="np-panel" id="listPanel" hidden>
        <h2 class="np-title">③ 本日の乗車一覧</h2>
        <div class="np-table-wrap">
          <table class="np-table" id="rideTable">
            <thead>
              <tr><th>No.</th><th>発</th><th>着</th><th>乗車地</th><th>降車地</th><th>人員</th><th>金額</th><th>支払</th><th>区分</th><th>割引</th><th>チケット/顧客</th><th>操作</th></tr>
            </thead>
            <tbody id="rideBody"></tbody>
          </table>
        </div>
        <p class="np-empty" id="rideEmpty">まだ乗車の記録がありません。</p>

        <div class="np-summary" id="summaryBox">
          <div class="np-summary__item"><span>回数</span><strong id="sumCount">0回</strong></div>
          <div class="np-summary__item"><span>輸送人員</span><strong id="sumPax">0人</strong></div>
          <div class="np-summary__item"><span>現収計</span><strong id="sumCash">0円</strong></div>
          <div class="np-summary__item"><span>未収計</span><strong id="sumUncollected">0円</strong></div>
          <div class="np-summary__item np-summary__item--total"><span>合計</span><strong id="sumTotal">0円</strong></div>
        </div>
      </div>

      <!-- 車両・メーター -->
      <div class="np-panel" id="meterPanel" hidden>
        <h2 class="np-title">④ 車両メーター・給油（任意）</h2>
        <div class="np-headfields">
          <label class="np-field np-field--sm">
            <span>出庫時 指数（km）</span>
            <input type="number" id="odoStartInput" class="np-input" min="0" inputmode="numeric" />
          </label>
          <label class="np-field np-field--sm">
            <span>帰庫時 指数（km）</span>
            <input type="number" id="odoEndInput" class="np-input" min="0" inputmode="numeric" />
          </label>
          <label class="np-field np-field--sm">
            <span>走行km（自動）</span>
            <input type="text" id="odoDiffLabel" class="np-input" readonly value="—" />
          </label>
          <label class="np-field np-field--sm">
            <span>燃料給油（ℓ）</span>
            <input type="number" id="fuelInput" class="np-input" min="0" step="0.01" inputmode="decimal" />
          </label>
        </div>
      </div>

      <!-- 出力 -->
      <div class="np-panel" id="exportPanel" hidden>
        <h2 class="np-title">⑤ 出力・連携</h2>
        <div class="np-actions">
          <button type="button" class="np-btn" id="printBtn">🖨 日報を印刷する</button>
          <button type="button" class="np-btn" id="csvBtn">CSV出力</button>
          <button type="button" class="np-btn" id="syncBtn">⏱ 勤怠アプリへ売上を反映</button>
        </div>
        <p class="np-note">※ 「勤怠アプリへ売上を反映」は、その日の合計（税込）と未収を勤怠管理の売上入力に自動転記します（先に勤怠側で出勤打刻が必要）。決済方法ごとの内訳・手数料は事務所で確認してください。<br />※ データはこの端末のブラウザ内にのみ保存されます。乗務記録は印刷して1年間保存してください。</p>
      </div>

    </div>
  </section>

</Layout>

<script>
  const LS_NIPPO = 'fuji-nippo-log';
  const LS_STAFF = 'fuji-kintai-staff';
  const LS_KINTAI_LOG = 'fuji-kintai-log';
  const LS_VEHICLE = 'fuji-nippo-vehicle';

  const PAY_LABEL = {
    cash: '現金', machine: '決済機', qr: 'QR・Pay', ticket: 'チケット', minataku: 'みなタク', billing: '未収・掛け',
  };
  // 現金のみ現収、それ以外（決済機・QR・チケット・みなタク・掛け）は当日未回収＝未収として集計（紙の日報と同じ区分）
  const CASH_KINDS = ['cash'];

  const QUICK_SPOTS = [
    '原ノ町駅', '小高駅', '鹿島駅', '南相馬市立総合病院', '渡辺病院', '小野田病院', '大町病院',
    'イオンスーパーセンター南相馬店', 'ヨークベニマル原町店', '道の駅 南相馬', '南相馬市役所',
    '小高区役所', '鹿島区役所', '富士タクシー本社', '原町待機所', '雲雀ヶ原祭場地', '福島ロボットテストフィールド',
    'セデッテかしま', '相馬駅', '浪江駅', '仙台空港', '福島駅',
  ];

  const $ = (id) => document.getElementById(id);
  const yen = (n) => Math.round(n).toLocaleString('ja-JP');

  // ── 時計 ──
  function tick() {
    const now = new Date();
    $('clock').textContent = now.toLocaleTimeString('ja-JP');
    $('todayLabel').textContent = now.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
  }
  tick();
  setInterval(tick, 1000);

  // ── データ ──
  const staff = JSON.parse(localStorage.getItem(LS_STAFF) || '[]');
  let nippo = JSON.parse(localStorage.getItem(LS_NIPPO) || '{}');
  let vehicles = JSON.parse(localStorage.getItem(LS_VEHICLE) || '{}');
  let selectedId = null;

  function saveNippo() { localStorage.setItem(LS_NIPPO, JSON.stringify(nippo)); }
  function dateKey() { return $('datePick').value; }
  function entryKey() { return `${selectedId}|${dateKey()}`; }
  function currentEntry() {
    if (!selectedId || !dateKey()) return null;
    if (!nippo[entryKey()]) nippo[entryKey()] = { vehicle: '', rides: [], odoStart: null, odoEnd: null, fuel: null };
    return nippo[entryKey()];
  }
  function todayStr() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }
  function nowHM() {
    const d = new Date();
    return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
  }

  // ── スタッフ選択 ──
  function renderStaff() {
    const list = $('staffList');
    list.innerHTML = '';
    if (!staff.length) {
      const p = document.createElement('p');
      p.className = 'np-empty';
      p.textContent = 'スタッフが登録されていません。先に勤怠管理ページを開いてください。';
      list.appendChild(p);
      return;
    }
    for (const s of staff) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'np-staff' + (s.id === selectedId ? ' is-active' : '');
      btn.textContent = s.name;
      btn.onclick = () => {
        selectedId = (selectedId === s.id) ? null : s.id;
        if (selectedId && vehicles[selectedId]) $('vehicleInput').value = vehicles[selectedId];
        renderStaff(); renderAll();
      };
      list.appendChild(btn);
    }
  }

  function renderAll() {
    const show = !!selectedId;
    $('headFields').hidden = !show;
    $('ridePanel').hidden = !show;
    $('listPanel').hidden = !show;
    $('meterPanel').hidden = !show;
    $('exportPanel').hidden = !show;
    if (!show) return;
    const e = currentEntry();
    $('vehicleInput').value = e.vehicle || vehicles[selectedId] || '';
    $('odoStartInput').value = e.odoStart != null ? e.odoStart : '';
    $('odoEndInput').value = e.odoEnd != null ? e.odoEnd : '';
    $('fuelInput').value = e.fuel != null ? e.fuel : '';
    updateOdoDiff();
    renderRides();
  }

  // ── 乗車一覧・集計 ──
  function isCashRide(r) { return CASH_KINDS.includes(r.pay); }
  function renderRides() {
    const e = currentEntry();
    if (!e) return;
    const body = $('rideBody');
    body.innerHTML = '';
    $('rideEmpty').hidden = e.rides.length > 0;
    $('rideTable').style.display = e.rides.length ? '' : 'none';
    e.rides.forEach((r, i) => {
      const tr = document.createElement('tr');
      const kubun = isCashRide(r) ? '現収' : '未収';
      tr.innerHTML = `
        <td>${i + 1}</td>
        <td>${r.dep || '—'}</td>
        <td>${r.arr || '—'}</td>
        <td>${r.from || '—'}</td>
        <td>${r.to || '—'}</td>
        <td>${r.pax}人</td>
        <td class="np-table__fare">${yen(r.fare)}円</td>
        <td>${PAY_LABEL[r.pay] || r.pay}</td>
        <td class="${isCashRide(r) ? 'np-cash' : 'np-uncollected'}">${kubun}</td>
        <td>${r.discount || '—'}</td>
        <td>${[r.ticketNo, r.customer].filter(Boolean).join(' / ') || '—'}</td>
        <td></td>
      `;
      const ops = tr.lastElementChild;
      const editBtn = document.createElement('button');
      editBtn.type = 'button';
      editBtn.className = 'np-btn np-btn--ghost np-btn--xs';
      editBtn.textContent = '修正';
      editBtn.onclick = () => {
        $('depTime').value = r.dep || '';
        $('arrTime').value = r.arr || '';
        $('fromInput').value = r.from || '';
        $('toInput').value = r.to || '';
        $('paxInput').value = r.pax;
        $('fareInput').value = r.fare;
        $('payInput').value = r.pay;
        $('discountInput').value = r.discount || '';
        $('ticketNoInput').value = r.ticketNo || '';
        $('customerInput').value = r.customer || '';
        updateOptionalFields();
        e.rides.splice(i, 1);
        saveNippo(); renderRides();
        $('rideMsg').textContent = `No.${i + 1} を修正モードにしました。内容を直して「＋ この乗車を記録する」を押してください。`;
        $('fareInput').focus();
      };
      const delBtn = document.createElement('button');
      delBtn.type = 'button';
      delBtn.className = 'np-btn np-btn--ghost np-btn--xs';
      delBtn.textContent = '削除';
      delBtn.onclick = () => {
        if (!confirm(`No.${i + 1}（${yen(r.fare)}円）を削除しますか？`)) return;
        e.rides.splice(i, 1);
        saveNippo(); renderRides();
      };
      ops.appendChild(editBtn);
      ops.appendChild(delBtn);
      body.appendChild(tr);
    });
    const cash = e.rides.filter(isCashRide).reduce((s, r) => s + r.fare, 0);
    const uncollected = e.rides.filter(r => !isCashRide(r)).reduce((s, r) => s + r.fare, 0);
    const pax = e.rides.reduce((s, r) => s + r.pax, 0);
    $('sumCount').textContent = `${e.rides.length}回`;
    $('sumPax').textContent = `${pax}人`;
    $('sumCash').textContent = `${yen(cash)}円`;
    $('sumUncollected').textContent = `${yen(uncollected)}円`;
    $('sumTotal').textContent = `${yen(cash + uncollected)}円`;
  }

  // ── 乗車の追加 ──
  function updateOptionalFields() {
    const pay = $('payInput').value;
    const needsDetail = pay === 'ticket' || pay === 'billing' || pay === 'minataku';
    $('ticketNoField').hidden = !(pay === 'ticket');
    $('customerField').hidden = !needsDetail;
  }
  $('payInput').addEventListener('change', updateOptionalFields);
  $('depNowBtn').onclick = () => { $('depTime').value = nowHM(); };
  $('arrNowBtn').onclick = () => { $('arrTime').value = nowHM(); };

  $('addRideBtn').onclick = () => {
    const e = currentEntry();
    if (!e) return;
    const fare = parseInt($('fareInput').value, 10);
    if (isNaN(fare) || fare < 0) { alert('メーター額（円）を入力してください。'); $('fareInput').focus(); return; }
    const pax = parseInt($('paxInput').value, 10);
    const ride = {
      dep: $('depTime').value || '',
      arr: $('arrTime').value || '',
      from: $('fromInput').value.trim(),
      to: $('toInput').value.trim(),
      pax: (!isNaN(pax) && pax > 0) ? pax : 1,
      fare,
      pay: $('payInput').value,
      discount: $('discountInput').value,
      ticketNo: $('ticketNoInput').value.trim(),
      customer: $('customerInput').value.trim(),
    };
    e.rides.push(ride);
    e.vehicle = $('vehicleInput').value.trim();
    if (e.vehicle) { vehicles[selectedId] = e.vehicle; localStorage.setItem(LS_VEHICLE, JSON.stringify(vehicles)); }
    saveNippo();
    // 入力欄をリセット（次の乗車に備えて発時刻には着時刻を引き継ぎ）
    $('depTime').value = '';
    $('arrTime').value = '';
    $('fromInput').value = '';
    $('toInput').value = '';
    $('paxInput').value = '1';
    $('fareInput').value = '';
    $('payInput').value = 'cash';
    $('discountInput').value = '';
    $('ticketNoInput').value = '';
    $('customerInput').value = '';
    updateOptionalFields();
    renderRides();
    $('rideMsg').textContent = `✅ No.${e.rides.length}（${yen(fare)}円・${PAY_LABEL[ride.pay]}）を記録しました`;
  };

  // ── 車両メーター ──
  function updateOdoDiff() {
    const s = parseFloat($('odoStartInput').value);
    const en = parseFloat($('odoEndInput').value);
    $('odoDiffLabel').value = (!isNaN(s) && !isNaN(en) && en >= s) ? `${yen(en - s)} km` : '—';
  }
  for (const id of ['odoStartInput', 'odoEndInput', 'fuelInput', 'vehicleInput']) {
    $(id).addEventListener('input', () => {
      const e = currentEntry();
      if (!e) return;
      const s = parseFloat($('odoStartInput').value);
      const en = parseFloat($('odoEndInput').value);
      const f = parseFloat($('fuelInput').value);
      e.odoStart = !isNaN(s) ? s : null;
      e.odoEnd = !isNaN(en) ? en : null;
      e.fuel = !isNaN(f) ? f : null;
      e.vehicle = $('vehicleInput').value.trim();
      saveNippo();
      updateOdoDiff();
    });
  }
  $('datePick').addEventListener('change', renderAll);

  // ── 勤怠情報の参照（出庫・帰庫・休憩） ──
  function kintaiRec() {
    const log = JSON.parse(localStorage.getItem(LS_KINTAI_LOG) || '[]');
    return log.find(r => r.staffId === selectedId && r.date === dateKey());
  }
  function hmOf(iso) {
    const d = new Date(iso);
    return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
  }

  // ── 印刷 ──
  $('printBtn').onclick = () => {
    const e = currentEntry();
    const s = staff.find(x => x.id === selectedId);
    if (!e || !s) return;
    const rec = kintaiRec();
    const cash = e.rides.filter(isCashRide).reduce((sum, r) => sum + r.fare, 0);
    const uncollected = e.rides.filter(r => !isCashRide(r)).reduce((sum, r) => sum + r.fare, 0);
    const pax = e.rides.reduce((sum, r) => sum + r.pax, 0);
    const breaks = rec ? rec.breaks.filter(b => b.end).map(b => `${hmOf(b.start)}〜${hmOf(b.end)}`).join('、') : '';
    const rows = e.rides.map((r, i) => `
      <tr><td>${i + 1}</td><td>${r.dep || ''}</td><td>${r.arr || ''}</td><td>${r.from || ''}</td><td>${r.to || ''}</td>
      <td>${r.pax}</td><td class="r">${yen(r.fare)}</td><td>${PAY_LABEL[r.pay]}</td><td>${isCashRide(r) ? '現収' : '未収'}</td>
      <td>${r.discount || ''}</td><td>${[r.ticketNo, r.customer].filter(Boolean).join(' / ')}</td></tr>`).join('');
    const html = `<!DOCTYPE html><html lang="ja"><head><meta charset="utf-8"><title>乗務日報 ${dateKey()} ${s.name}</title>
      <style>
        body { font-family: "Yu Gothic", sans-serif; font-size: 12px; margin: 16px; color: #000; }
        h1 { font-size: 16px; margin: 0 0 4px; }
        .head { display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 8px; }
        table { border-collapse: collapse; width: 100%; margin-top: 6px; }
        th, td { border: 1px solid #000; padding: 3px 5px; text-align: center; }
        td.r { text-align: right; }
        .sums td { font-weight: bold; }
        .foot { margin-top: 8px; display: flex; gap: 24px; flex-wrap: wrap; }
      </style></head><body>
      <h1>乗務日報（乗用）　有限会社富士タクシー</h1>
      <div class="head">
        <span>日付：${dateKey()}</span>
        <span>乗務員名：${s.name}</span>
        <span>車両番号：${e.vehicle || '　　　'}</span>
        <span>出庫：${rec && rec.in ? hmOf(rec.in) : '　:　'}</span>
        <span>帰庫：${rec && rec.out ? hmOf(rec.out) : '　:　'}</span>
        <span>休憩：${breaks || 'なし'}</span>
      </div>
      <table>
        <thead><tr><th>No.</th><th>発</th><th>着</th><th>乗車地</th><th>降車地</th><th>人員</th><th>金額(円)</th><th>支払</th><th>区分</th><th>割引</th><th>チケット番号／顧客名</th></tr></thead>
        <tbody>${rows}</tbody>
        <tbody class="sums"><tr><td colspan="5">合計</td><td>${pax}</td><td class="r">${yen(cash + uncollected)}</td><td colspan="4">現収 ${yen(cash)}円 ／ 未収 ${yen(uncollected)}円 ／ 回数 ${e.rides.length}回</td></tr></tbody>
      </table>
      <div class="foot">
        <span>出庫時指数：${e.odoStart != null ? yen(e.odoStart) + ' km' : '　　　'}</span>
        <span>帰庫時指数：${e.odoEnd != null ? yen(e.odoEnd) + ' km' : '　　　'}</span>
        <span>走行：${(e.odoStart != null && e.odoEnd != null && e.odoEnd >= e.odoStart) ? yen(e.odoEnd - e.odoStart) + ' km' : '　　　'}</span>
        <span>給油：${e.fuel != null ? e.fuel + ' ℓ' : '　　　'}</span>
        <span>事務確認印：　　　</span>
      </div>
      <script>window.onload = () => window.print();<\/script>
      </body></html>`;
    const w = window.open('', '_blank');
    if (!w) { alert('ポップアップがブロックされました。ブラウザの設定でこのサイトのポップアップを許可してください。'); return; }
    w.document.write(html);
    w.document.close();
  };

  // ── CSV出力 ──
  $('csvBtn').onclick = () => {
    const e = currentEntry();
    const s = staff.find(x => x.id === selectedId);
    if (!e || !s) return;
    if (!e.rides.length) { alert('この日の乗車記録がありません。'); return; }
    let csv = '﻿No.,発,着,乗車地,降車地,人員,金額(円),支払,区分,割引,チケット番号,顧客名\n';
    e.rides.forEach((r, i) => {
      csv += [i + 1, r.dep, r.arr, r.from, r.to, r.pax, r.fare, PAY_LABEL[r.pay], isCashRide(r) ? '現収' : '未収', r.discount, r.ticketNo, r.customer].join(',') + '\n';
    });
    const cash = e.rides.filter(isCashRide).reduce((sum, r) => sum + r.fare, 0);
    const uncollected = e.rides.filter(r => !isCashRide(r)).reduce((sum, r) => sum + r.fare, 0);
    csv += `\n日付,${dateKey()}\n乗務員,${s.name}\n車両番号,${e.vehicle}\n回数,${e.rides.length}\n輸送人員,${e.rides.reduce((sum, r) => sum + r.pax, 0)}\n現収計(円),${cash}\n未収計(円),${uncollected}\n合計(円),${cash + uncollected}\n`;
    if (e.odoStart != null) csv += `出庫時指数(km),${e.odoStart}\n`;
    if (e.odoEnd != null) csv += `帰庫時指数(km),${e.odoEnd}\n`;
    if (e.fuel != null) csv += `給油(ℓ),${e.fuel}\n`;
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `乗務日報_${dateKey()}_${s.name}.csv`;
    a.click();
    URL.revokeObjectURL(a.href);
  };

  // ── 勤怠アプリへ売上反映 ──
  $('syncBtn').onclick = () => {
    const e = currentEntry();
    const s = staff.find(x => x.id === selectedId);
    if (!e || !s) return;
    if (!e.rides.length) { alert('この日の乗車記録がありません。'); return; }
    const log = JSON.parse(localStorage.getItem(LS_KINTAI_LOG) || '[]');
    const rec = log.find(r => r.staffId === selectedId && r.date === dateKey());
    if (!rec) {
      alert(`勤怠管理に ${s.name} さんの ${dateKey()} の打刻がありません。\n先に勤怠管理ページで出勤打刻をしてください。`);
      return;
    }
    const cash = e.rides.filter(isCashRide).reduce((sum, r) => sum + r.fare, 0);
    const uncollected = e.rides.filter(r => !isCashRide(r)).reduce((sum, r) => sum + r.fare, 0);
    const gross = cash + uncollected;
    if (rec.salesGross != null && !confirm(`勤怠側に既に売上（税込 ${yen(rec.salesGross)}円）が入力されています。\n日報の合計（税込 ${yen(gross)}円・未収 ${yen(uncollected)}円）で上書きしますか？`)) return;
    rec.salesGross = gross;
    rec.sales = Math.round(gross / 1.1); // 税抜（歩合給の計算に使用）
    rec.uncollected = uncollected;
    localStorage.setItem(LS_KINTAI_LOG, JSON.stringify(log));
    alert(`✅ 勤怠管理へ反映しました。\n売上合計（税込）：${yen(gross)}円\n（税抜 ${yen(rec.sales)}円）\n未収：${yen(uncollected)}円\n※ カード手数料の内訳は事務所で「売上を修正」から確認してください。`);
  };

  // ── 初期化 ──
  $('datePick').value = todayStr();
  const dl = $('spotList');
  for (const name of QUICK_SPOTS) {
    const opt = document.createElement('option');
    opt.value = name;
    dl.appendChild(opt);
  }
  renderStaff();
  renderAll();
</script>

