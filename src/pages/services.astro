---
import Layout from '../layouts/Layout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '富士タクシー サービス一覧',
  itemListElement: [
    { '@type': 'ListItem', position: 1, item: { '@type': 'Service', name: '一般乗用タクシー', description: '初乗り700円〜、南相馬市全域・県外対応' } },
    { '@type': 'ListItem', position: 2, item: { '@type': 'Service', name: 'ジャンボタクシー（特大車）', description: '初乗り980円〜、最大9名乗車、7台保有' } },
    { '@type': 'ListItem', position: 3, item: { '@type': 'Service', name: 'デマンドタクシー（乗合）', description: '小高区内・小高区⇔原町区、要予約' } },
    { '@type': 'ListItem', position: 4, item: { '@type': 'Service', name: 'スクールタクシー', description: '小高区通学送迎、毎日運行' } },
    { '@type': 'ListItem', position: 5, item: { '@type': 'Service', name: '観光タクシー', description: '相馬野馬追・小高神社ほか、貸切料金' } },
    { '@type': 'ListItem', position: 6, item: { '@type': 'Service', name: '法人・空港送迎', description: '冠婚葬祭・ビジネス利用、事前予約制' } },
  ],
};
---

<Layout
  title="サービス・料金 – 一般乗用・ジャンボ・デマンド・観光タクシー"
  description="南相馬市のタクシーサービス一覧。一般乗用（初乗り700円〜）・ジャンボタクシー（最大9名）・デマンド乗合・スクール送迎・観光タクシー・法人送迎。クレカ・QR・電子マネー全対応。"
  structuredData={structuredData}
>

  <!-- ページヒーロー -->
  <section class="page-hero bg-black">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <ol>
          <li><a href="/">ホーム</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page">サービス・料金</li>
        </ol>
      </nav>
      <p class="eyebrow reveal">Services & Pricing</p>
      <h1 class="reveal">すべての移動に、<br />富士タクシーがいる。</h1>
      <p class="page-hero__lead reveal">
        日常の通院から、VIPの送迎まで。南相馬の地で半世紀以上、あらゆる移動のニーズに応え続けています。
      </p>
      <!-- アンカーリンク -->
      <nav class="service-anchors reveal" aria-label="サービス一覧">
        <a href="#general">一般乗用</a>
        <a href="#jumbo">ジャンボ</a>
        <a href="#demand">デマンド</a>
        <a href="#school">スクール</a>
        <a href="#sightseeing">観光</a>
      </nav>
    </div>
  </section>

  <!-- 選ばれる理由 -->
  <section class="section bg-black" aria-labelledby="why-heading">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:var(--space-12);">
        <p class="eyebrow">Why Fuji Taxi</p>
        <h2 id="why-heading" style="color:var(--fuji-white);">富士タクシーが<span style="color:var(--fuji-yellow);">選ばれる理由</span></h2>
        <div class="divider" style="margin:1rem auto;"></div>
      </div>
      <div class="why-grid">
        <div class="why-card reveal">
          <div class="why-card__num">50<span class="why-card__unit">年以上</span></div>
          <h3 class="why-card__title">半世紀の実績と信頼</h3>
          <p class="why-card__desc">昭和46年創業。地域とともに歩み続けてきた歴史が、富士タクシーの最大の強みです。</p>
        </div>
        <div class="why-card reveal" style="transition-delay:80ms">
          <div class="why-card__num">7<span class="why-card__unit">台</span></div>
          <h3 class="why-card__title">ジャンボタクシー地域最多</h3>
          <p class="why-card__desc">最大9名乗車のジャンボタクシーを7台保有。大人数の移動も分乗不要でまとめて対応。</p>
        </div>
        <div class="why-card reveal" style="transition-delay:160ms">
          <div class="why-card__num" style="font-size:clamp(1.8rem,5vw,2.4rem);">7〜24<span class="why-card__unit">時</span></div>
          <h3 class="why-card__title">年中無休・長時間営業</h3>
          <p class="why-card__desc">毎日7:00〜24:00営業、365日対応。急な移動や深夜の帰宅も安心してお任せください。</p>
        </div>
        <div class="why-card reveal" style="transition-delay:240ms">
          <div class="why-card__num">10<span class="why-card__unit">種類以上</span></div>
          <h3 class="why-card__title">あらゆる決済に対応</h3>
          <p class="why-card__desc">現金・クレカ・QR・IC・各種タクシーチケット。お客様のお財布を選びません。</p>
        </div>
        <div class="why-card reveal" style="transition-delay:320ms">
          <div class="why-card__num" style="font-size:2rem;">VIP</div>
          <h3 class="why-card__title">著名人・VIP送迎実績</h3>
          <p class="why-card__desc">有名芸能人・ミュージシャンの送迎実績多数。プライバシーと品格を守る信頼の対応。</p>
        </div>
        <div class="why-card reveal" style="transition-delay:400ms">
          <div class="why-card__num" style="font-size:1.6rem;">📺📰</div>
          <h3 class="why-card__title">メディア取材実績多数</h3>
          <p class="why-card__desc">テレビ局・新聞社からの取材対応実績を多数有する、地域で注目されるタクシー会社。</p>
        </div>
      </div>

      <!-- 配車システムバナー -->
      <div class="system-banner reveal" style="margin-top:2rem;">
        <div class="system-banner__left">
          <p class="system-banner__eyebrow">Technology</p>
          <h3 class="system-banner__title">電脳交通「DS」<br class="sp-only" />クラウド配車システム採用</h3>
          <p class="system-banner__desc">株式会社電脳交通が提供する<strong>クラウド型タクシー配車システム「DS」</strong>を採用。AIを活用したスマートな配車管理で、より迅速・確実にお客様のもとへ向かいます。</p>
        </div>
        <div class="system-banner__tags">
          <span class="why-system-tag">📱 スマート配車</span>
          <span class="why-system-tag">📍 リアルタイム位置把握</span>
          <span class="why-system-tag">🔔 現着通知サービス</span>
          <span class="why-system-tag">☁️ クラウド管理</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 車両紹介 -->
  <section class="section bg-black" aria-labelledby="fleet-heading">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:var(--space-12);">
        <p class="eyebrow">Our Fleet</p>
        <h2 id="fleet-heading" style="color:var(--fuji-white);">富士タクシーの<span style="color:var(--fuji-yellow);">車両紹介</span></h2>
        <div class="divider" style="margin:1rem auto;"></div>
        <p style="color:var(--fuji-gray-muted); max-width:600px; margin:0 auto; line-height:1.8;">
          普通タクシー9台・ジャンボタクシー7台、計16台体制。<br />お客様の用途・人数・荷物量に合わせた最適な車両をご用意しています。
        </p>
      </div>

      <!-- 普通タクシー -->
      <div class="fleet-type-label reveal">
        <span class="fleet-type-badge">普通タクシー（定員4名）</span>
        <span class="fleet-type-count">9台保有</span>
      </div>
      <div class="fleet-grid reveal">
        <!-- JP小型 -->
        <div class="fleet-card">
          <div class="fleet-card__img-wrap">
            <img src="/images/uploads/S__2123735048_0.jpg" alt="富士タクシー JPタクシー 南相馬市" class="fleet-card__img" loading="lazy" />
          </div>
          <div class="fleet-card__body">
            <span class="fleet-card__badge">一般乗用</span>
            <h3 class="fleet-card__title">JP 普通タクシー</h3>
            <p class="fleet-card__desc">乗車席空間が広く、車内装備も充実。USB充電・シートヒーター完備で長距離移動も快適。</p>
            <div class="fleet-card__features">
              <span>🔌 USB充電</span>
              <span>🌡 シートヒーター</span>
              <span>↔ 広い乗降口</span>
            </div>
            <div class="fleet-card__specs">
              <span>定員 最大4名</span>
              <span>初乗り 700円〜</span>
            </div>
          </div>
        </div>

        <!-- NV小型 -->
        <div class="fleet-card">
          <div class="fleet-card__img-wrap">
            <img src="/images/uploads/S__2123735047_0.jpg" alt="富士タクシー NVタクシー 荷室広大 南相馬市" class="fleet-card__img" loading="lazy" />
          </div>
          <div class="fleet-card__body">
            <span class="fleet-card__badge">一般乗用</span>
            <h3 class="fleet-card__title">NV 普通タクシー</h3>
            <p class="fleet-card__desc">大型スーツケースを複数積載できる広大な荷室が最大の特徴。空港・駅への送迎や出張利用に最適。自動ステップ・手摺装備で高齢の方にも安心です。</p>
            <div class="fleet-card__features">
              <span>🧳 大型スーツケース複数積載</span>
              <span>🤝 自動ステップ</span>
              <span>🦯 手摺装備</span>
            </div>
            <div class="fleet-card__specs">
              <span>定員 最大4名</span>
              <span>初乗り 700円〜</span>
            </div>
          </div>
        </div>

        <!-- シエンタ -->
        <div class="fleet-card">
          <div class="fleet-card__img-wrap">
            <img src="/images/uploads/S__2123735046_0.jpg" alt="富士タクシー シエンタタクシー 低段差 南相馬市" class="fleet-card__img" loading="lazy" />
          </div>
          <div class="fleet-card__body">
            <span class="fleet-card__badge">一般乗用</span>
            <h3 class="fleet-card__title">シエンタ 普通タクシー</h3>
            <p class="fleet-card__desc">低段差乗降口でスムーズな乗り降り。USB充電・シートヒーター完備の快適な車内空間。</p>
            <div class="fleet-card__features">
              <span>🔌 USB充電</span>
              <span>🌡 シートヒーター</span>
              <span>⬇ 低段差</span>
            </div>
            <div class="fleet-card__specs">
              <span>定員 最大4名</span>
              <span>初乗り 700円〜</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ジャンボタクシー -->
      <div class="fleet-type-label reveal" style="margin-top:3rem;">
        <span class="fleet-type-badge fleet-type-badge--yellow">ジャンボタクシー（定員9名）</span>
        <span class="fleet-type-count">7台保有 / 地域最多</span>
      </div>
      <div class="fleet-grid reveal">
        <!-- 通常 -->
        <div class="fleet-card">
          <div class="fleet-card__img-wrap">
            <img src="/images/uploads/S__2123735044_0.jpg" alt="富士タクシー ジャンボタクシー通常 9名乗車 南相馬市" class="fleet-card__img" loading="lazy" />
          </div>
          <div class="fleet-card__body">
            <span class="fleet-card__badge fleet-card__badge--yellow">ジャンボ</span>
            <h3 class="fleet-card__title">ジャンボタクシー<br /><small style="font-size:0.85em; font-weight:600;">通常タイプ</small></h3>
            <p class="fleet-card__desc">荷物の積載能力に優れた大容量モデル。リアモニター・100V電源装備でビジネス利用にも対応。</p>
            <div class="fleet-card__features">
              <span>📦 大容量積載</span>
              <span>📺 リアモニター</span>
              <span>🔌 100V電源</span>
            </div>
            <div class="fleet-card__specs">
              <span>定員 最大9名</span>
              <span>初乗り 980円〜</span>
            </div>
          </div>
        </div>

        <!-- プレミアム -->
        <div class="fleet-card fleet-card--premium">
          <div class="fleet-card__img-wrap">
            <img src="/images/uploads/S__2123735045_0.jpg" alt="富士タクシー ジャンボタクシープレミアム リクライニング 南相馬市" class="fleet-card__img" loading="lazy" />
          </div>
          <div class="fleet-card__body">
            <span class="fleet-card__badge fleet-card__badge--gold">✦ プレミアム</span>
            <h3 class="fleet-card__title">ジャンボタクシー<br /><small style="font-size:0.85em; font-weight:600;">プレミアムタイプ</small></h3>
            <p class="fleet-card__desc">リクライニング・オットマン・リアモニター装備。座席アレンジで少人数の贅沢な移動にも対応。</p>
            <div class="fleet-card__features">
              <span>🛋 リクライニング</span>
              <span>📺 リアモニター</span>
              <span>🪑 オットマン</span>
            </div>
            <div class="fleet-card__specs">
              <span>定員 最大9名</span>
              <span>初乗り 980円〜</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 一般乗用タクシー -->
  <section id="general" class="section bg-black">
    <div class="container">
      <div class="service-split reveal">
        <div class="service-split__info">
          <p class="eyebrow">General Taxi</p>
          <h3 style="color:var(--fuji-white); font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight:900; margin-block: 0.75rem;">一般乗用タクシー</h3>
          <div class="divider"></div>
          <p style="color:var(--fuji-gray-muted); line-height:1.9; margin-bottom:1.5rem;">
            電話一本で、どこへでも。南相馬市全域はもちろん、県外・長距離にも対応しています。車両が到着すると「050-3102-4350」より自動音声でお知らせする<strong style="color:var(--fuji-yellow);">現着通知サービス</strong>を完備。外の寒さや雨を気にせず、室内でゆっくりお待ちいただけます。
          </p>
          <ul class="general-features">
            <li>
              <div class="gf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="10" r="3"/>
                  <path d="M12 2a8 8 0 0 1 8 8c0 5.25-8 14-8 14S4 15.25 4 10a8 8 0 0 1 8-8z"/>
                </svg>
              </div>
              <div>
                <p class="gf-title">対応エリア</p>
                <p class="gf-desc">南相馬市全域・県外・長距離</p>
              </div>
            </li>
            <li>
              <div class="gf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                  <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
              </div>
              <div>
                <p class="gf-title">現着通知サービス</p>
                <p class="gf-desc">050-3102-4350より自動音声でお知らせ</p>
              </div>
            </li>
            <li>
              <div class="gf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <p class="gf-title">営業時間</p>
                <p class="gf-desc">年中無休 7:00〜24:00</p>
              </div>
            </li>
          </ul>
          <div style="margin-top:2rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
            <a href="tel:0244442543" class="btn btn--primary">📞 電話で予約する</a>
            <a href="/contact" class="btn btn--outline">お問い合わせ</a>
          </div>
        </div>
        <div class="service-split__price">
          <div class="price-card">
            <p class="price-card__label">初乗り</p>
            <p class="price-card__amount"><span class="price-card__num">700</span>円〜</p>
            <p class="price-card__note">距離制メーター</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ジャンボタクシー -->
  <section id="jumbo" class="section bg-black">
    <div class="container">
      <div class="service-split reveal">
        <div class="service-split__info">
          <p class="eyebrow">Jumbo Taxi</p>
          <h3 style="color:var(--fuji-white); font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight:900; margin-block: 0.75rem;">ジャンボタクシー <span class="badge badge--yellow">7台保有 / 地域最多</span></h3>
          <div class="divider"></div>
          <p>1台で9名まで。分乗なし、待ち合わせなし。地域最多7台を誇るジャンボタクシーが、冠婚葬祭・家族旅行・企業研修・グループ送迎など、あらゆる大人数の移動をひとつにまとめます。</p>
          <ul class="service-features">
            <li>✓ 最大乗車定員: 9名</li>
            <li>✓ 保有台数: 7台（地域最多）</li>
            <li>✓ 用途: 冠婚葬祭・家族旅行・企業研修・空港・駅送迎</li>
            <li>✓ 事前予約必須</li>
          </ul>
          <div class="jumbo-vip-note">
            <span class="jumbo-vip-note__icon">⭐</span>
            <p>南相馬を訪れる<strong>有名芸能人・ミュージシャン</strong>の送迎実績も多数。プライバシーと品格を守る、信頼のVIP対応です。</p>
          </div>
        </div>
        <div class="service-split__price">
          <div class="price-card">
            <p class="price-card__label">初乗り</p>
            <p class="price-card__amount"><span class="price-card__num">980</span>円〜</p>
            <p class="price-card__note">最大9名乗車</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- デマンドタクシー -->
  <section id="demand" class="section bg-black">
    <div class="container">
      <div class="service-split reveal">
        <div class="service-split__info">
          <p class="eyebrow">Demand Taxi</p>
          <h3 style="color:var(--fuji-white); font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight:900; margin-block: 0.75rem;">デマンドタクシー（乗合）</h3>
          <div class="divider"></div>
          <p style="color:var(--fuji-gray-muted); line-height:1.9; margin-bottom:1.5rem;">
            故郷に戻った人たちの、日常を守る移動。旧避難指示区域の帰還住民・高齢者の皆さまに向けた乗合タクシーです。通院・買い物など生活に欠かせない移動を、リーズナブルな定額でご提供。<strong style="color:var(--fuji-yellow);">事前予約制</strong>で安心してご利用いただけます。
          </p>
          <ul class="general-features">
            <li>
              <div class="gf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="10" r="3"/>
                  <path d="M12 2a8 8 0 0 1 8 8c0 5.25-8 14-8 14S4 15.25 4 10a8 8 0 0 1 8-8z"/>
                </svg>
              </div>
              <div>
                <p class="gf-title">運行エリア</p>
                <p class="gf-desc">小高区内・小高区⇔原町区</p>
              </div>
            </li>
            <li>
              <div class="gf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              </div>
              <div>
                <p class="gf-title">対象</p>
                <p class="gf-desc">帰還住民・高齢者の方</p>
              </div>
            </li>
            <li>
              <div class="gf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <div>
                <p class="gf-title">用途</p>
                <p class="gf-desc">通院・買い物・日常移動</p>
              </div>
            </li>
            <li>
              <div class="gf-icon" aria-hidden="true">
